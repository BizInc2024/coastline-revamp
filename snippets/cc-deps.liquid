{% comment %}
  CC-DEPS: Shared dependencies for custom Coastline sections
  Loads Google Fonts, Tailwind CSS, and Alpine.js
  Safe to render multiple times — each resource only loads once per page
{% endcomment %}

{% unless cc_deps_loaded %}
  {% assign cc_deps_loaded = true %}

  <!-- Google Fonts: Space Grotesk + Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Space+Grotesk:wght@400;500;600&display=swap" rel="stylesheet">

  <!-- Tailwind CSS (preflight disabled to avoid conflicting with theme styles) -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = tailwind.config || {};
    tailwind.config.corePlugins = tailwind.config.corePlugins || {};
    tailwind.config.corePlugins.preflight = false;
  </script>

  <!-- Prevent Tailwind from overriding theme header styles -->
  <style>
    @media (min-width: 1024px) {
      .header__icons--start .menu-drawer-button {
        display: none !important;
      }
    }
  </style>

  <!-- Alpine.js -->
  <script defer src="https://cdn.jsdelivr.net/npm/@alpinejs/intersect@3.x.x/dist/cdn.min.js"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/@alpinejs/collapse@3.x.x/dist/cdn.min.js"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
{% endunless %}
