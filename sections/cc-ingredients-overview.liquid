<style>
  .ccio * { box-sizing: border-box; }
  .ccio p { max-width: none !important; }
  .ccio h1, .ccio h2 { text-wrap: balance; }

  /* Product header: image + info side by side */
  .ccio-product-header {
    display: flex;
    align-items: center;
    gap: 40px;
    margin-bottom: 40px;
    padding-bottom: 40px;
    border-bottom: 1px solid #E8E8E8;
  }

  .ccio-product-img {
    flex-shrink: 0;
    width: 180px;
    height: 180px;
  }

  .ccio-product-info {
    flex: 1;
  }

  /* Ingredient rows */
  .ccio-list {
    display: flex;
    flex-direction: column;
  }

  .ccio-row {
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 24px 0;
    border-bottom: 1px solid #E8E8E8;
    text-decoration: none;
    transition: background-color 0.3s ease;
    margin: 0 -16px;
    padding-left: 16px;
    padding-right: 16px;
  }

  .ccio-row:first-child {
    border-top: 1px solid #E8E8E8;
  }

  .ccio-row:hover {
    background-color: rgba(0, 0, 0, 0.035);
  }

  .ccio-row-thumb {
    flex-shrink: 0;
    width: 64px;
    height: 64px;
    object-fit: cover;
    display: block;
  }

  .ccio-row-left {
    flex-shrink: 0;
    width: 180px;
  }

  .ccio-row-name {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 18px;
    font-weight: 500;
    color: #0A0A0A;
    margin: 0 0 4px;
    letter-spacing: -0.01em;
  }

  .ccio-row-dose {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    color: #6B6B6B;
    margin: 0;
  }

  .ccio-row-desc {
    flex: 1;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    color: #6B6B6B;
    line-height: 1.6;
    margin: 0;
  }

  .ccio-row-link {
    flex-shrink: 0;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    color: #0A0A0A;
    text-decoration: underline;
    text-underline-offset: 3px;
    opacity: 0.5;
    transition: opacity 0.3s ease;
    white-space: nowrap;
  }

  .ccio-row:hover .ccio-row-link {
    opacity: 1;
  }

  /* Tablet */
  @media (max-width: 767px) {
    .ccio-product-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
    }

    .ccio-product-img {
      width: 120px;
      height: 120px;
    }

    .ccio-row {
      flex-wrap: wrap;
      gap: 12px;
    }

    .ccio-row-thumb {
      width: 48px;
      height: 48px;
    }

    .ccio-row-left {
      width: auto;
      flex: 1;
      min-width: 0;
    }

    .ccio-row-name {
      font-size: 16px;
    }

    .ccio-row-dose {
      font-size: 12px;
    }

    .ccio-row-desc {
      font-size: 13px;
      flex-basis: 100%;
      padding-left: 60px;
    }

    .ccio-row-link {
      opacity: 1;
      font-size: 12px;
      flex-basis: 100%;
      padding-left: 60px;
    }

    .ccio-row {
      position: relative;
    }
  }

  /* Scroll reveal */
  .ccio .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }
  .ccio .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var reveals = document.querySelectorAll('.ccio .reveal');
    if (!reveals.length) return;
    var obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
      });
    }, { threshold: 0.15 });
    reveals.forEach(function(el) { obs.observe(el); });
  });
</script>

