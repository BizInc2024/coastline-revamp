{% comment %}
  Save as: sections/customer-reviews.liquid
  Usage: Add to any page via the theme editor
  Enhanced version with full customization options
{% endcomment %}

<style>

  

  
  /* Hide review blocks beyond the first 5 */
  .review-block:nth-child(n+6) {
    display: none;
  }
</style>

<section class="w-full" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; background-color: {{ section.settings.background_color }};">
  <div style="max-width: {{ section.settings.container_max_width }}px; margin-left: auto; margin-right: auto; padding-left: {{ section.settings.container_padding_x }}px; padding-right: {{ section.settings.container_padding_x }}px;">
    
    {%- comment -%} Header {%- endcomment -%}
    <div style="margin-bottom: {{ section.settings.header_spacing }}px;">
      <h2 class="customer-reviews-heading" style="font-size: {{ section.settings.heading_size }}px; font-weight: {{ section.settings.heading_weight }}; margin-bottom: {{ section.settings.heading_margin_bottom }}px; color: {{ section.settings.heading_color }};">
        {{ section.settings.heading }}
      </h2>
      <div class="flex items-center gap-2" style="margin-bottom: {{ section.settings.rating_margin_bottom }}px;">
        {%- comment -%} Star Rating {%- endcomment -%}
        <div class="flex" style="gap: {{ section.settings.star_gap }}px;">
          {%- for i in (1..5) -%}
            <svg width="{{ section.settings.star_size }}" height="{{ section.settings.star_size }}" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M8 0L10.163 5.63L16 6.51L12 10.41L12.926 16L8 13.63L3.074 16L4 10.41L0 6.51L5.837 5.63L8 0Z" fill="{% if i <= section.settings.average_rating %}{{ section.settings.star_filled_color }}{% else %}{{ section.settings.star_empty_color }}{% endif %}"/>
            </svg>
          {%- endfor -%}
        </div>
        <span style="font-size: {{ section.settings.review_count_size }}px; font-weight: {{ section.settings.review_count_weight }}; color: {{ section.settings.review_count_color }};">{{ section.settings.total_reviews }} reviews</span>
      </div>
    </div>

    {%- comment -%} Reviews Grid {%- endcomment -%}
    <div>
      <div class="reviews-grid-container grid grid-cols-1 md:grid-cols-2" style="gap: {{ section.settings.grid_gap }}px;">
        {%- for block in section.blocks -%}
          
          {%- if block.type == 'image' -%}
            {%- comment -%} Image Block {%- endcomment -%}
            <div class="review-block overflow-hidden rounded-lg" style="aspect-ratio: {{ block.settings.aspect_ratio }}; border: {{ section.settings.card_border_width }}px solid {{ section.settings.card_border_color }}; border-radius: {{ section.settings.card_border_radius }}px; box-shadow: {{ section.settings.card_shadow }};">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 800 | image_tag: class: 'w-full h-full object-cover', alt: block.settings.alt_text }}
              {%- else -%}
                <div class="w-full h-full flex items-center justify-center" style="background-color: {{ section.settings.placeholder_bg_color }}; color: {{ section.settings.placeholder_text_color }};">
                  Image placeholder
                </div>
              {%- endif -%}
            </div>
          
          {%- elsif block.type == 'review' -%}
            {%- comment -%} Review Card {%- endcomment -%}
            <div class="review-block rounded-lg transition-colors duration-200" style="border: {{ section.settings.card_border_width }}px solid {{ section.settings.card_border_color }}; background-color: {{ section.settings.card_bg_color }}; color: {{ section.settings.card_text_color }}; box-shadow: {{ section.settings.card_shadow }}; padding: {{ section.settings.card_padding }}px; border-radius: {{ section.settings.card_border_radius }}px;" onmouseover="this.style.backgroundColor='{{ section.settings.card_hover_bg_color }}'" onmouseout="this.style.backgroundColor='{{ section.settings.card_bg_color }}'">
              <div class="flex flex-col" style="gap: {{ section.settings.card_content_gap }}px;">
                <div class="flex items-start justify-between" style="gap: {{ section.settings.card_content_gap }}px;">
                  <div class="flex-1">
                    
                    {%- comment -%} Rating and Date {%- endcomment -%}
                    <div class="flex items-center" style="gap: {{ section.settings.rating_date_gap }}px; margin-bottom: {{ section.settings.rating_margin_bottom_card }}px;">
                      <div class="flex" style="gap: {{ section.settings.star_gap }}px;">
                        {%- for i in (1..5) -%}
                          <svg width="{{ section.settings.star_size_card }}" height="{{ section.settings.star_size_card }}" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M8 0L10.163 5.63L16 6.51L12 10.41L12.926 16L8 13.63L3.074 16L4 10.41L0 6.51L5.837 5.63L8 0Z" fill="{% if i <= block.settings.rating %}{{ section.settings.star_filled_color }}{% else %}{{ section.settings.star_empty_color }}{% endif %}"/>
                          </svg>
                        {%- endfor -%}
                      </div>
                      <span style="font-size: {{ section.settings.date_size }}px; color: {{ section.settings.date_color }};">{{ block.settings.date }}</span>
                    </div>
                    
                    {%- comment -%} Name and Badge {%- endcomment -%}
                    <div class="flex items-center" style="gap: {{ section.settings.name_badge_gap }}px; margin-bottom: {{ section.settings.name_margin_bottom }}px;">
                      <span style="font-weight: {{ section.settings.name_weight }}; font-size: {{ section.settings.name_size }}px; color: {{ section.settings.name_color }};">{{ block.settings.name }}</span>
                      {%- if block.settings.verified -%}
                        <div class="inline-flex items-center rounded-full" style="background-color: {{ section.settings.badge_bg_color }}; color: {{ section.settings.badge_text_color }}; padding: {{ section.settings.badge_padding_y }}px {{ section.settings.badge_padding_x }}px; font-size: {{ section.settings.badge_size }}px; font-weight: {{ section.settings.badge_weight }}; border: 1px solid {{ section.settings.badge_border_color }};">
                          Verified buyer
                        </div>
                      {%- endif -%}
                    </div>
                    
                    <p style="font-size: {{ section.settings.location_size }}px; color: {{ section.settings.location_color }}; margin-bottom: {{ section.settings.location_margin_bottom }}px;">{{ block.settings.location }}</p>
                  </div>
                </div>
                
                {%- comment -%} Review Text {%- endcomment -%}
                <p style="font-size: {{ section.settings.review_text_size }}px; color: {{ section.settings.review_text_color }}; line-height: {{ section.settings.review_line_height }};">{{ block.settings.text }}</p>
              </div>
            </div>
          {%- endif -%}
          
        {%- endfor -%}
      </div>
    </div>

    {%- comment -%} Show More Button {%- endcomment -%}
    {%- if section.settings.show_more_button -%}
      <div class="text-center" id="show-more-container" style="margin-top: {{ section.settings.button_margin_top }}px;">
        <button id="show-more-btn" class="inline-flex items-center justify-center whitespace-nowrap rounded-md transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2" style="font-size: {{ section.settings.button_text_size }}px; font-weight: {{ section.settings.button_font_weight }}; border: {{ section.settings.button_border_width }}px solid {{ section.settings.button_border_color }}; background-color: {{ section.settings.button_bg_color }}; color: {{ section.settings.button_text_color }}; height: {{ section.settings.button_height }}px; padding-left: {{ section.settings.button_padding_x }}px; padding-right: {{ section.settings.button_padding_x }}px; border-radius: {{ section.settings.button_border_radius }}px;" onmouseover="this.style.backgroundColor='{{ section.settings.button_hover_bg_color }}'; this.style.color='{{ section.settings.button_hover_text_color }}'" onmouseout="this.style.backgroundColor='{{ section.settings.button_bg_color }}'; this.style.color='{{ section.settings.button_text_color }}'">
          {{ section.settings.show_more_text }}
        </button>
        <button id="show-less-btn" class="inline-flex items-center justify-center whitespace-nowrap rounded-md transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2" style="display: none; font-size: {{ section.settings.button_text_size }}px; font-weight: {{ section.settings.button_font_weight }}; border: {{ section.settings.button_border_width }}px solid {{ section.settings.button_border_color }}; background-color: {{ section.settings.button_bg_color }}; color: {{ section.settings.button_text_color }}; height: {{ section.settings.button_height }}px; padding-left: {{ section.settings.button_padding_x }}px; padding-right: {{ section.settings.button_padding_x }}px; border-radius: {{ section.settings.button_border_radius }}px; margin-left: 12px;" onmouseover="this.style.backgroundColor='{{ section.settings.button_hover_bg_color }}'; this.style.color='{{ section.settings.button_hover_text_color }}'" onmouseout="this.style.backgroundColor='{{ section.settings.button_bg_color }}'; this.style.color='{{ section.settings.button_text_color }}'">
          Show less
        </button>
      </div>
    {%- endif -%}
    
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const reviewsGrid = document.querySelector('.reviews-grid-container');
    if (!reviewsGrid) return;
    
    const reviewBlocks = Array.from(reviewsGrid.children);
    const showMoreBtn = document.getElementById('show-more-btn');
    const showLessBtn = document.getElementById('show-less-btn');
    const showMoreContainer = document.getElementById('show-more-container');
    const itemsPerLoad = 5;
    let currentlyShowing = itemsPerLoad;

    console.log('Total review blocks:', reviewBlocks.length);

    // Hide button container if 5 or fewer reviews total
    if (reviewBlocks.length <= itemsPerLoad && showMoreContainer) {
      showMoreContainer.style.display = 'none';
    }

    // Show more on click
    if (showMoreBtn) {
      showMoreBtn.addEventListener('click', function(e) {
        e.preventDefault();
        console.log('Show more clicked. Currently showing:', currentlyShowing);
        
        // Show the next 5 hidden blocks
        for (let i = currentlyShowing; i < currentlyShowing + itemsPerLoad && i < reviewBlocks.length; i++) {
          reviewBlocks[i].style.display = 'block';
          console.log('Showing block', i);
        }

        currentlyShowing += itemsPerLoad;

        // Show the "Show less" button once expanded
        if (showLessBtn && currentlyShowing > itemsPerLoad) {
          showLessBtn.style.display = 'inline-flex';
        }

        // Hide "Show more" button if all reviews are now shown
        if (currentlyShowing >= reviewBlocks.length) {
          showMoreBtn.style.display = 'none';
          console.log('All reviews shown, hiding Show more button');
        }
      });
    }

    // Show less on click
    if (showLessBtn) {
      showLessBtn.addEventListener('click', function(e) {
        e.preventDefault();
        console.log('Show less clicked');
        
        // Hide all blocks after the first 5
        for (let i = itemsPerLoad; i < reviewBlocks.length; i++) {
          reviewBlocks[i].style.display = 'none';
        }

        // Reset counter
        currentlyShowing = itemsPerLoad;

        // Hide "Show less" button
        showLessBtn.style.display = 'none';

        // Show "Show more" button again
        if (showMoreBtn && reviewBlocks.length > itemsPerLoad) {
          showMoreBtn.style.display = 'inline-flex';
        }

        // Scroll to top of reviews section
        reviewsGrid.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    }
  });
</script>

