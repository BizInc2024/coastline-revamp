{%- comment -%}==============================================
  QUIZ JAVASCRIPT
================================================{%- endcomment -%}

<script>
  // Quiz state
  let currentQuestion = 1;
  const totalQuestions = 5;
  const answers = {};

  // Category mapping for results
  const categoryMap = {
    1: 'cognitive',
    2: 'visual',
    3: 'recovery',
    4: 'metabolic',
    5: 'capacity'
  };

  // Start the quiz
  function startQuiz() {
    document.getElementById('quiz-hero').style.display = 'none';
    document.querySelector('.quiz-trust-bar').style.display = 'none';
    document.getElementById('quiz-container').classList.add('active');
    updateProgress(); // Add this line here
  }

  // Select an option
  function selectOption(element) {
    const question = element.closest('.quiz-question');
    const options = question.querySelectorAll('.quiz-option');

    // Remove selected from all options
    options.forEach(opt => opt.classList.remove('selected'));

    // Add selected to clicked option
    element.classList.add('selected');

    // Store answer
    const questionNum = parseInt(question.dataset.question);
    answers[questionNum] = parseInt(element.dataset.value);

    // Enable next button
    document.getElementById('next-btn').disabled = false;
  }

  // Go to next question
  function nextQuestion() {
    if (currentQuestion < totalQuestions) {
      // Hide current question
      document.querySelector(`.quiz-question[data-question="${currentQuestion}"]`).classList.remove('active');

      // Show next question
      currentQuestion++;
      document.querySelector(`.quiz-question[data-question="${currentQuestion}"]`).classList.add('active');

      // Update progress
      updateProgress();

      // Show/hide back button
      document.getElementById('back-btn').style.visibility = currentQuestion > 1 ? 'visible' : 'hidden';

      // Update next button text
      if (currentQuestion === totalQuestions) {
        document.getElementById('next-btn').textContent = 'See My Results';
      }

      // Disable next button until answer selected
      if (!answers[currentQuestion]) {
        document.getElementById('next-btn').disabled = true;
      }

      // Scroll to top
    } else {
      // Show results
      showResults();
    }
  }

  // Go to previous question
  function prevQuestion() {
    if (currentQuestion > 1) {
      // Hide current question
      document.querySelector(`.quiz-question[data-question="${currentQuestion}"]`).classList.remove('active');

      // Show previous question
      currentQuestion--;
      document.querySelector(`.quiz-question[data-question="${currentQuestion}"]`).classList.add('active');

      // Update progress
      updateProgress();

      // Show/hide back button
      document.getElementById('back-btn').style.visibility = currentQuestion > 1 ? 'visible' : 'hidden';

      // Reset next button text
      document.getElementById('next-btn').textContent = 'Next Question';

      // Enable next button (previous answer exists)
      document.getElementById('next-btn').disabled = false;

      // Scroll to top
    }
  }
// Update progress bar
  function updateProgress() {
    const progress = (currentQuestion / totalQuestions) * 100;
    const progressBar = document.getElementById('progress-fill');
    const questionNum = document.getElementById('current-question');
    
    console.log('=== UPDATE PROGRESS ===');
    console.log('Current Question:', currentQuestion);
    console.log('Total Questions:', totalQuestions);
    console.log('Progress Percentage:', progress + '%');
    console.log('Progress Bar Element:', progressBar);
    console.log('Setting width to:', progress + '%');
    
    if (progressBar) {
      progressBar.style.width = `${progress}%`;
      console.log('Width after setting:', progressBar.style.width);
      console.log('Computed style:', window.getComputedStyle(progressBar).width);
    } else {
      console.error('PROGRESS BAR ELEMENT NOT FOUND!');
    }
    
    if (questionNum) {
      questionNum.textContent = currentQuestion;
    }
    
    console.log('======================');
  }

  // Show results
  function showResults() {
    // Hide quiz container
    document.getElementById('quiz-container').classList.remove('active');

    // Calculate total score (out of 28 possible, display as percentage)
    const totalScore = Object.values(answers).reduce((sum, val) => sum + val, 0);
    const maxScore = totalQuestions * 4;
    const percentage = Math.round((totalScore / maxScore) * 100);

    // Determine score label and description
    let scoreLabel, scoreDesc, recommendationText; // Add this line
   if (percentage >= 85) {
      scoreLabel = 'Sustaining Excellence';
      scoreDesc = 'Your audit confirms an elite baseline. You are currently aging better than average, likely due to a combination of genetics and proactive habits.';
      recommendationText = 'At this stage, your goal is maintenance. Biological decline is compounding; the work you do now is about protecting these margins so you can stay at this peak through the next decade.';
    } else if (percentage >= 75) {
      scoreLabel = 'The Optimization Path';
      scoreDesc = 'You have a solid foundation, but you are likely starting to feel the "friction" of natural biological shifts.';
      recommendationText = 'Your results suggest you are in the "transition zone"—where small changes in clarity or recovery time are becoming noticeable. This is the ideal time to refine your routine to ensure your daily performance keeps pace with your demands.';
    } else {
      scoreLabel = 'Baseline Restoration';
      scoreDesc = 'Your audit indicates that certain natural declines are currently outpacing your body\'s ability to recover.';
      recommendationText = 'It\'s common to feel "hit" by these shifts all at once. This score is a signal that your body is "borrowing" energy from tomorrow to pay for today. The focus here is on a baseline reset—giving your system the raw materials it needs to reclaim its rhythm.';
    }

    // Update results UI
    document.getElementById('final-score').textContent = percentage;
    document.getElementById('score-label').textContent = scoreLabel;
    document.getElementById('score-desc').textContent = scoreDesc;
    document.getElementById('recommendation-text').textContent = recommendationText;

   // Update breakdown bars
    const categories = ['cognitive', 'visual', 'recovery', 'metabolic', 'capacity'];
    categories.forEach((cat, index) => {
      const score = answers[index + 1] || 0;
      const catPercentage = (score / 4) * 100;
      const bar = document.getElementById(`${cat}-bar`);
      const status = document.getElementById(`${cat}-status`);

      if (bar && status) {
        // RESET: Remove old color classes first
        bar.className = 'quiz-results__breakdown-fill'; 
        
        // Set width
        bar.style.width = `${catPercentage}%`;
        
        if (catPercentage >= 90) {
          bar.classList.add('quiz-results__breakdown-fill--excellent');
          status.textContent = 'Excellent';
        } else if (catPercentage >= 75) {
          bar.classList.add('quiz-results__breakdown-fill--strong');
          status.textContent = 'Strong';
        } else if (catPercentage >= 60) {
          bar.classList.add('quiz-results__breakdown-fill--good');
          status.textContent = 'Good';
        } else if (catPercentage >= 40) {
          bar.classList.add('quiz-results__breakdown-fill--fair');
          status.textContent = 'Fair';
        } else {
          bar.classList.add('quiz-results__breakdown-fill--needs-support');
          status.textContent = 'Needs Support';
        }
      }
    });

    // Show results sections
    document.getElementById('quiz-results').classList.add('active');
    document.getElementById('quiz-product').classList.add('active');
    document.getElementById('quiz-final-cta').classList.add('active');

    // Scroll to results

    // Animate score number
    animateScore(percentage);
  }

  // Animate score counting up
  function animateScore(target) {
    const element = document.getElementById('final-score');
    let current = 0;
    const increment = target / 30;
    const timer = setInterval(() => {
      current += increment;
      if (current >= target) {
        current = target;
        clearInterval(timer);
      }
      element.textContent = Math.round(current);
    }, 30);
  }
</script>

