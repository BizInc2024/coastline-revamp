{% render 'cc-deps' %}
{% comment %}
  Coastline Landing Page v9 -- 5 Reasons This Is the Ultimate Longevity System
  The Ultimate Longevity Solution

  Variant IDs:
  - Unflavored Blend: 42179764453445
  - Coastal Lemonade: 42179764486213

  ReCharge Selling Plan IDs:
  - Monthly (34% off): 1862631493
  - 2-Month (20% off): 1892712517
  - One-time: no selling_plan
{% endcomment %}

<style>
    :root {
        --parchment: #FAF9F6;
        --deep-ink: #0A0A0A;
        --warm-gray: #6B6B6B;
        --light-gray: #E8E8E8;
        --forest: #1A3A2F;
        --forest-light: #2D5A47;
        --ocean: #062F3D;
    }

    .cc-landing-v9 {
        font-family: 'Inter', system-ui, sans-serif;
        background-color: #FAF9F6;
        color: #6B6B6B;
    }

    .cc-landing-v9 * {
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }

    .cc-landing-v9 p { max-width: none !important; }
    .cc-landing-v9 h1, .cc-landing-v9 h2 { text-wrap: balance; }

    .cc-landing-v9 h1, .cc-landing-v9 h2, .cc-landing-v9 h3, .cc-landing-v9 h4 {
        font-family: 'Space Grotesk', system-ui, sans-serif;
        color: #0A0A0A;
        letter-spacing: -0.02em;
    }

    .cc-landing-v9 .btn-primary {
        display: inline-block;
        background-color: #0A0A0A;
        color: #FAF9F6;
        font-family: 'Space Grotesk', sans-serif;
        font-weight: 500;
        font-size: 12px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        padding: 20px 48px;
        text-decoration: none;
        transition: opacity 0.3s ease;
    }

    .cc-landing-v9 .btn-primary:hover {
        opacity: 0.8;
    }

    .cc-landing-v9 .ingredient-tag {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-family: 'Inter', sans-serif;
        font-size: 13px;
        font-weight: 500;
        letter-spacing: 0.02em;
        color: #0A0A0A;
        border: 1px solid #E8E8E8;
        padding: 12px 20px;
        margin: 4px;
        cursor: pointer;
        transition: all 0.3s ease;
        background: white;
    }

    .cc-landing-v9 .ingredient-tag:hover {
        border-color: #0A0A0A;
        background: #0A0A0A;
        color: white;
    }

    .cc-landing-v9 .ingredient-tag svg {
        width: 16px;
        height: 16px;
        transition: transform 0.3s ease;
    }

    .cc-landing-v9 .ingredient-tag[aria-expanded="true"] svg {
        transform: rotate(180deg);
    }
    .cc-landing-v9 .ingredient-tag.system-row {
        display: flex;
        border: none;
        margin: 0;
        padding: 12px 0;
        background: transparent;
        width: 100%;
        justify-content: space-between;
    }
    .cc-landing-v9 .ingredient-tag.system-row:hover {
        background: transparent;
        border: none;
        color: #0A0A0A;
        opacity: 0.6;
    }

    .cc-landing-v9 [x-cloak] { display: none !important; }

    .cc-landing-v9 .reveal {
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.8s ease, transform 0.8s ease;
    }

    .cc-landing-v9 .reveal.visible {
        opacity: 1;
        transform: translateY(0);
    }

    @media (prefers-reduced-motion: reduce) {
        .cc-landing-v9 .reveal {
            opacity: 1;
            transform: none;
        }
    }

    .cc-landing-v9 .reveal-stagger > * {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.6s ease, transform 0.6s ease;
    }

    .cc-landing-v9 .reveal-stagger.visible > *:nth-child(1) { transition-delay: 0s; opacity: 1; transform: translateY(0); }
    .cc-landing-v9 .reveal-stagger.visible > *:nth-child(2) { transition-delay: 0.1s; opacity: 1; transform: translateY(0); }
    .cc-landing-v9 .reveal-stagger.visible > *:nth-child(3) { transition-delay: 0.2s; opacity: 1; transform: translateY(0); }
    .cc-landing-v9 .reveal-stagger.visible > *:nth-child(4) { transition-delay: 0.3s; opacity: 1; transform: translateY(0); }
    .cc-landing-v9 .reveal-stagger.visible > *:nth-child(5) { transition-delay: 0.4s; opacity: 1; transform: translateY(0); }

    .cc-landing-v9 .editorial-divider {
        width: 60px;
        height: 1px;
        background: #0A0A0A;
    }

    .cc-landing-v9 .section-counter {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 11px;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: #6B6B6B;
    }

    .cc-landing-v9 .sticky-cta {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        background: white;
        border-top: 1px solid #E8E8E8;
        padding: 16px 24px;
        transform: translateY(100%);
        transition: transform 0.4s ease;
        z-index: 100;
    }

    .cc-landing-v9 .sticky-cta.visible {
        transform: translateY(0);
    }

    .cc-landing-v9 .pull-quote {
        font-family: 'Space Grotesk', sans-serif;
        font-size: clamp(24px, 4vw, 42px);
        font-weight: 400;
        line-height: 1.3;
        letter-spacing: -0.02em;
        color: #0A0A0A;
    }

    .cc-landing-v9 .img-zoom {
        overflow: hidden;
    }

    .cc-landing-v9 .img-zoom img {
        transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .cc-landing-v9 .img-zoom:hover img {
        transform: scale(1.05);
    }

    .cc-landing-v9 .ingredient-detail {
        background: #FAF9F6;
        border: 1px solid #E8E8E8;
        padding: 32px;
    }

    .cc-landing-v9 .benefits-dark {
        background-color: #0A0A0A !important;
    }
    .cc-landing-v9 .benefits-dark + .benefits-dark {
        border-top: 1px solid #1A1A1A;
    }
    .cc-landing-v9 .benefits-dark h2 {
        color: #FAF9F6;
    }
    .cc-landing-v9 .benefits-dark .section-counter {
        color: #555555;
    }
    .cc-landing-v9 .benefits-dark .editorial-divider {
        background-color: #333333;
    }
    .cc-landing-v9 .benefits-dark .text-warm-gray {
        color: #9A9A9A !important;
    }
    .cc-landing-v9 .benefits-dark .text-deep-ink,
    .cc-landing-v9 .benefits-dark strong.text-deep-ink {
        color: #FAF9F6 !important;
    }
    .cc-landing-v9 .benefits-dark .border-deep-ink {
        border-color: #FAF9F6 !important;
    }
    .cc-landing-v9 .benefits-dark .text-forest {
        color: #2D5A47;
    }

    .cc-landing-v9 .benefit-nav-btn {
        border: 2px solid rgba(250, 249, 246, 0.35);
        color: #FAF9F6;
    }
    .cc-landing-v9 .benefit-nav-btn:hover {
        background-color: #E7FF56;
        border-color: #E7FF56;
        color: #0A0A0A;
    }

    .cc-landing-v9 .benefits-dark .ingredient-tag {
        background: #111111;
        border-color: #333333;
        color: #FAF9F6;
    }
    .cc-landing-v9 .benefits-dark .ingredient-tag:hover {
        background: #E7FF56;
        border-color: #E7FF56;
        color: #0A0A0A;
    }
    .cc-landing-v9 .benefits-dark .ingredient-detail {
        background: #111111;
        border-color: #333333;
    }

    .cc-landing-v9 .benefit-toggle {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-family: 'Space Grotesk', sans-serif;
        font-size: 12px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #9A9A9A;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
        margin-top: 1rem;
    }
    .cc-landing-v9 .benefit-toggle svg {
        width: 16px;
        height: 16px;
        transition: transform 0.3s ease;
    }
    .cc-landing-v9 .benefit-toggle[aria-expanded="true"] svg {
        transform: rotate(180deg);
    }
    @media (min-width: 1024px) {
        .cc-landing-v9 .benefit-toggle { display: none !important; }
        .cc-landing-v9 .benefit-body {
            display: block !important;
            height: auto !important;
            overflow: visible !important;
            opacity: 1 !important;
        }
    }

    .cc-landing-v9 .benefit-number {
        font-family: 'Space Grotesk', sans-serif;
        font-size: clamp(64px, 10vw, 120px);
        font-weight: 600;
        line-height: 1;
        letter-spacing: -0.04em;
        color: rgba(231, 255, 86, 0.2);
        margin-bottom: 0.5rem;
    }

    /* Hero — white text overrides (layout globals set dark colors) */
    .cc-landing-v9 #hero h1,
    .cc-landing-v9 #hero p,
    .cc-landing-v9 #hero span,
    .cc-landing-v9 #hero a,
    .cc-landing-v9 #hero div {
        color: #FFFFFF !important;
    }
    .cc-landing-v9 #hero .hero-subheadline { color: rgba(255,255,255,0.7) !important; }
    .cc-landing-v9 #hero .section-counter { color: rgba(255,255,255,0.7) !important; }
    .cc-landing-v9 #hero h1 span { color: rgba(255,255,255,0.6) !important; }
    .cc-landing-v9 #hero .btn-primary { background-color: #FAF9F6 !important; color: #0A0A0A !important; }
    .cc-landing-v9 #hero a.inline-block { color: rgba(255,255,255,0.6) !important; }
    .cc-landing-v9 #hero a.inline-block:hover { color: rgba(255,255,255,0.9) !important; }

    /* Hero — MOBILE: full-bleed bg image with gradient overlay */
    .cc-landing-v9 #hero::after {
        display: block;
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        z-index: 1;
        background: linear-gradient(180deg, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.35) 35%, rgba(0,0,0,0.25) 55%, rgba(0,0,0,0.7) 100%);
        pointer-events: none;
    }
    .cc-landing-v9 .hero-bg-desktop { display: none; }
    .cc-landing-v9 .hero-bg-mobile { display: block; }
    .cc-landing-v9 .hero-mobile-image { display: none; }

    .cc-landing-v9 .hero-content {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        min-height: 100vh;
        text-align: center;
    }
    .cc-landing-v9 .hero-content-top {
        padding: calc(2.5rem + 6vh) 1.5rem 0;
        max-width: 32rem;
        margin-left: auto;
        margin-right: auto;
    }
    .cc-landing-v9 .hero-content-bottom {
        padding: 0 1.5rem 2.5rem;
        max-width: 32rem;
        margin-left: auto;
        margin-right: auto;
    }
    .cc-landing-v9 .hero-container { padding: 0; }
    .cc-landing-v9 .hero-content .section-counter { margin-bottom: 0.75rem; }
    .cc-landing-v9 .hero-content .editorial-divider {
        margin-bottom: 1rem;
        margin-left: auto;
        margin-right: auto;
    }
    .cc-landing-v9 .hero-headline { font-size: 2.063rem !important; margin-bottom: 0; }
    .cc-landing-v9 .hero-subheadline {
        font-size: 0.875rem !important;
        max-width: 28rem !important;
        margin-bottom: 1rem;
        margin-left: auto;
        margin-right: auto;
    }
    .cc-landing-v9 .hero-stars { justify-content: center; margin-bottom: 1rem; }
    .cc-landing-v9 .hero-cta-row { flex-direction: column; align-items: center; }

    @media (min-width: 640px) {
        .cc-landing-v9 .hero-cta-row { flex-direction: row; justify-content: center; }
    }

    /* Hero — DESKTOP: full-bleed bg with left-to-right gradient, all copy together */
    @media (min-width: 768px) {
        .cc-landing-v9 #hero { background-color: transparent; }
        .cc-landing-v9 #hero::after {
            display: block;
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            z-index: 1;
            background: linear-gradient(90deg, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0.5) 35%, rgba(0,0,0,0.15) 65%, rgba(0,0,0,0.05) 100%);
            pointer-events: none;
        }
        .cc-landing-v9 .hero-bg-desktop { display: block; }
        .cc-landing-v9 .hero-bg-mobile { display: none; }
        .cc-landing-v9 .hero-mobile-image { display: none !important; }
        .cc-landing-v9 .hero-outer { align-items: center; }
        .cc-landing-v9 .hero-container { padding: 5rem 2rem; }
        .cc-landing-v9 .hero-content {
            display: block !important;
            min-height: auto !important;
            text-align: left;
            max-width: 32rem;
        }
        .cc-landing-v9 .hero-content-top,
        .cc-landing-v9 .hero-content-bottom {
            padding: 0;
            max-width: none;
            margin-left: 0;
            margin-right: 0;
        }
        .cc-landing-v9 .hero-content .section-counter { margin-bottom: 2rem; }
        .cc-landing-v9 .hero-content .editorial-divider {
            margin-bottom: 3rem;
            margin-left: 0;
            margin-right: 0;
        }
        .cc-landing-v9 .hero-headline { font-size: 3rem !important; margin-bottom: 1.5rem; }
        .cc-landing-v9 .hero-subheadline {
            font-size: 1.125rem !important;
            max-width: none !important;
            margin-bottom: 2rem;
            margin-left: 0;
            margin-right: 0;
        }
        .cc-landing-v9 .hero-stars { justify-content: flex-start; margin-bottom: 3rem; }
        .cc-landing-v9 .hero-cta-row { align-items: flex-start; flex-direction: row; justify-content: flex-start; }
    }

    @media (min-width: 1024px) {
        .cc-landing-v9 .hero-container { padding: 5rem 4rem; }
        .cc-landing-v9 .hero-subheadline { font-size: 1.25rem !important; }
    }

    @media (min-width: 1280px) {
        .cc-landing-v9 .hero-content { max-width: 42rem; }
    }

    .cc-landing-v9 .system-col-am {
        border-bottom: 1px solid #E8E8E8;
        padding-bottom: 2rem;
    }
    .cc-landing-v9 .system-col-pm {
        padding-top: 1rem;
    }
    @media (min-width: 768px) {
        .cc-landing-v9 .system-col-am {
            border-bottom: none;
            border-right: 1px solid #E8E8E8;
            padding-bottom: 0;
            padding-right: 3rem;
        }
        .cc-landing-v9 .system-col-pm {
            padding-top: 0;
            padding-left: 3rem;
        }
    }

    .cc-landing-v9 .product-circle {
        width: 32px;
        height: 32px;
        min-width: 32px;
        min-height: 32px;
        border-radius: 50%;
        object-fit: cover;
        flex-shrink: 0;
    }

    .cc-landing-v9 .text-center p,
    .cc-landing-v9 p.text-center,
    .cc-landing-v9 .logo-bar-section p {
        max-width: none;
        width: 100%;
    }
    .cc-landing-v9 .logo-bar-section {
        text-align: center;
    }
    .cc-landing-v9 .review-avatar {
        width: 96px;
        height: 96px;
        border-radius: 50%;
        object-fit: cover;
        flex-shrink: 0;
    }
</style>

<noscript>
    <style>
        .cc-landing-v9 .reveal { opacity: 1 !important; transform: none !important; }
        .cc-landing-v9 [x-cloak] { display: block !important; }
    </style>
</noscript>

<div class="cc-landing-v9" x-data="{ showStickyCta: false, scrolled: false }"
     x-init=""
     @scroll.window="showStickyCta = window.scrollY > 800; scrolled = window.scrollY > 100">

    <!-- ============================================================ -->
    <!-- SECTION 1: HERO -->
    <!-- ============================================================ -->
    <section id="hero" style="min-height: 100vh; position: relative; overflow: hidden;">
        <div class="hero-bg-container" style="position: absolute; top: 0; left: 0; right: 0; bottom: 0;">
            <img
                src="{{ 'cc-v8-hero-mobile.jpg' | asset_url }}"
                alt="Coastline product family"
                class="w-full h-full object-cover hero-bg-mobile"
                style="object-position: center 40%;"
            >
            <img
                src="{{ 'cc-v8-hero-desktop.jpg' | asset_url }}"
                alt="Coastline product family"
                class="w-full h-full object-cover object-center hero-bg-desktop"
            >
        </div>

        <div class="hero-overlay" style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; z-index: 1; background: linear-gradient(180deg, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0.45) 40%, rgba(0,0,0,0.35) 60%, rgba(0,0,0,0.60) 100%);"></div>

        <div class="hero-outer" style="position: relative; z-index: 10; display: flex;">
            <div class="max-w-7xl mx-auto w-full hero-container">
                <div class="hero-content">
                    <div class="hero-content-top">
                        <div class="section-counter" style="color: rgba(255, 255, 255, 0.7);">{{ section.settings.hero_badge }}</div>
                        <div class="editorial-divider" style="background-color: rgba(255,255,255,0.3);"></div>
                        <h1 class="hero-headline font-grotesk font-medium leading-[1.1] text-white">
                            {{ section.settings.hero_headline }}
                        </h1>
                    </div>

                    <div class="hero-mobile-image">
                        <img
                            src="{{ 'cc-v8-hero-mobile.jpg' | asset_url }}"
                            alt="Coastline product family"
                            class="w-full"
                            style="max-height: 50vh; object-fit: cover; object-position: center 40%;"
                        >
                    </div>

                    <div class="hero-content-bottom">
                        <p class="hero-subheadline text-white/70 max-w-lg leading-relaxed">
                            {{ section.settings.hero_subheadline }}
                        </p>
                        <div class="flex items-center gap-2 hero-stars">
                            <span class="text-white text-sm tracking-wide">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
                            <span class="text-sm text-white/70">2,000+ Five-Star Reviews</span>
                        </div>
                        <p class="text-xs font-grotesk uppercase tracking-widest text-white/80 mb-3" style="letter-spacing: 0.15em;">{{ section.settings.hero_urgency_text }}</p>
                        <div class="flex gap-4 hero-cta-row">
                            <a href="{{ section.settings.hero_cta_url }}" class="btn-primary" style="background-color: #FAF9F6; color: #0A0A0A;">{{ section.settings.hero_cta_text }}</a>
                        </div>
                        <a href="#cta-selector" class="inline-block mt-4 text-sm text-white/60 hover:text-white/90 transition-colors font-grotesk tracking-wider uppercase" style="font-size: 11px; letter-spacing: 0.15em;">Skip to options &darr;</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ============================================================ -->
    <!-- SECTION 2: PRESS LOGOS -->
    <!-- ============================================================ -->
    {% if section.settings.show_press_logos %}
    <section class="py-5 sm:py-10 bg-white border-b border-light-gray logo-bar-section">
        <div class="max-w-7xl mx-auto px-4 sm:px-8 lg:px-16">
            <p class="text-xs tracking-widest uppercase text-warm-gray mb-4 sm:mb-8">As Featured On</p>
            <div class="flex flex-wrap justify-center items-center gap-6 sm:gap-12 lg:gap-20">
                <img src="{{ 'cc-v8-press-logo-1.png' | asset_url }}" alt="Uncrate" class="h-16 sm:h-32 lg:h-40 opacity-60 hover:opacity-100 transition-opacity">
                <img src="{{ 'cc-v8-press-logo-2.png' | asset_url }}" alt="Vice" class="h-16 sm:h-32 lg:h-40 opacity-60 hover:opacity-100 transition-opacity">
                <img src="{{ 'cc-v8-press-logo-3.png' | asset_url }}" alt="Daily Beast" class="h-16 sm:h-32 lg:h-40 opacity-60 hover:opacity-100 transition-opacity">
                <img src="{{ 'cc-v8-press-logo-4.png' | asset_url }}" alt="Us Weekly" class="h-16 sm:h-32 lg:h-40 opacity-60 hover:opacity-100 transition-opacity">
                <img src="{{ 'cc-v8-logo-man-of-many.png' | asset_url }}" alt="Man of Many" class="h-8 sm:h-12 lg:h-14 opacity-60 hover:opacity-100 transition-opacity">
            </div>
        </div>
    </section>
    {% endif %}

    <!-- ============================================================ -->
    <!-- SECTION: ONE SYSTEM -->
    <!-- ============================================================ -->
    <section class="py-16 lg:py-24 bg-parchment">
        <div class="max-w-5xl mx-auto px-8 lg:px-16">
            <div class="text-center mb-12 reveal" x-intersect="$el.classList.add('visible')">
                <p class="section-counter mb-6">The Coastline System</p>
                <div class="editorial-divider mx-auto mb-10"></div>
                <h2 class="text-4xl md:text-5xl lg:text-6xl font-grotesk font-medium mb-6 leading-tight">
                    Complete Upgrade.<br>
                    <span class="text-warm-gray">Day and Night.</span>
                </h2>
                <p class="text-lg lg:text-xl text-warm-gray mb-4 max-w-2xl mx-auto leading-relaxed">
                    Comprehensive support that's easy to stick with.
                </p>
            </div>

            <!-- AM / PM two-column layout -->
            <div class="grid grid-cols-1 md:grid-cols-2 max-w-5xl mx-auto reveal" x-intersect="$el.classList.add('visible')" style="transition-delay: 0.2s">
                <!-- AM STEP -->
                <div class="system-col-am">
                    <p class="font-grotesk text-xs uppercase tracking-widest text-warm-gray mb-4" style="letter-spacing: 0.18em;">Step 01 &mdash; Morning</p>
                    <h3 class="font-grotesk text-deep-ink font-medium mb-2" style="font-size: 1.375rem; letter-spacing: -0.01em;">Morning Blend + Softgels</h3>
                    <p class="text-sm text-warm-gray mb-8">With breakfast &middot; 10 ingredients</p>

                    <div class="overflow-hidden mb-10" style="aspect-ratio: 3/2;">
                        <img src="{{ 'cc-v8-morning-scene.png' | asset_url }}" alt="Morning Blend shaker and softgels on counter" class="w-full h-full object-cover" loading="lazy">
                    </div>

