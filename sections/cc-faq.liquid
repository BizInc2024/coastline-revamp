{% render 'cc-deps' %}
{% comment %}
  CC-FAQ: Comprehensive FAQ page organized by category
  Layout: theme.liquid (deps loaded via cc-deps snippet)
{% endcomment %}

<noscript>
  <style>
    .cc-faq .reveal { opacity: 1 !important; transform: none !important; }
  </style>
</noscript>

<div class="cc-faq" x-data="{ openQ: null }">

  {%- comment -%} === HERO === {%- endcomment -%}
  <section style="padding: 80px 24px 40px; background-color: var(--parchment); text-align: center;">
    <div style="max-width: 680px; margin: 0 auto;">
      <p class="reveal" style="font-family: 'Inter', sans-serif; font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--warm-gray); margin: 0 0 16px;">
        ASK AWAY
      </p>
      <h1 class="reveal" style="font-family: 'Space Grotesk', sans-serif; font-size: clamp(32px, 5vw, 56px); font-weight: 500; letter-spacing: -0.02em; line-height: 1.1; color: var(--deep-ink); margin: 0 0 16px;">
        Frequently asked questions
      </h1>
      <p class="reveal" style="font-family: 'Inter', sans-serif; font-size: 17px; color: var(--warm-gray); line-height: 1.7; margin: 0;">
        Everything you need to know about the Coastline system, our ingredients, and how it all works.
      </p>
    </div>
  </section>

  {%- comment -%} === CATEGORY NAV === {%- endcomment -%}
  <section style="padding: 0 24px 48px; background-color: var(--parchment);">
    <div style="max-width: 680px; margin: 0 auto; display: flex; flex-wrap: wrap; gap: 8px; justify-content: center;">
      {%- assign categories = "the-system,ingredients,benefits,usage,ordering,safety" | split: "," -%}
      {%- assign category_labels = "The System,Ingredients,Benefits & Expectations,How to Take,Ordering & Shipping,Safety & Compatibility" | split: "," -%}
      {%- for cat in categories -%}
        <a href="#faq-{{ cat }}" class="reveal" style="font-family: 'Inter', sans-serif; font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--deep-ink); text-decoration: none; border: 1px solid var(--light-gray); padding: 10px 20px; transition: all 0.3s ease;" onmouseover="this.style.backgroundColor='#0A0A0A';this.style.color='#FAF9F6'" onmouseout="this.style.backgroundColor='transparent';this.style.color='#0A0A0A'">
          {{ category_labels[forloop.index0] }}
        </a>
      {%- endfor -%}
    </div>
  </section>

  {%- comment -%} === FAQ CATEGORIES === {%- endcomment -%}
  {%- assign all_blocks = section.blocks -%}

  {%- for cat in categories -%}
    {%- assign cat_blocks = "" -%}
    {%- assign cat_count = 0 -%}
    {%- for block in all_blocks -%}
      {%- if block.settings.category == cat -%}
        {%- assign cat_count = cat_count | plus: 1 -%}
      {%- endif -%}
    {%- endfor -%}

    {%- if cat_count > 0 -%}
    <section id="faq-{{ cat }}" style="padding: 60px 24px; background-color: {% cycle 'var(--parchment)', '#F7F7F7' %};">
      <div style="max-width: 680px; margin: 0 auto;">

        <h2 class="reveal" style="font-family: 'Space Grotesk', sans-serif; font-size: clamp(22px, 3.5vw, 32px); font-weight: 500; letter-spacing: -0.02em; color: var(--deep-ink); margin: 0 0 32px;">
          {{ category_labels[forloop.index0] }}
        </h2>

        {%- assign q_index = 0 -%}
        {%- for block in all_blocks -%}
          {%- if block.settings.category == cat -%}
            {%- assign q_index = q_index | plus: 1 -%}
            {%- assign unique_id = cat | append: "_" | append: q_index -%}
            <div class="reveal" style="border-top: 1px solid var(--light-gray); {% if forloop.last %}border-bottom: 1px solid var(--light-gray);{% endif %}" {{ block.shopify_attributes }}>
              <button
                @click="openQ === '{{ unique_id }}' ? openQ = null : openQ = '{{ unique_id }}'"
                style="width: 100%; display: flex; align-items: center; justify-content: space-between; padding: 20px 0; background: none; border: none; cursor: pointer; text-align: left;"
              >
                <span style="font-family: 'Space Grotesk', sans-serif; font-size: 16px; font-weight: 500; color: var(--deep-ink); line-height: 1.4; padding-right: 16px;">
                  {{ block.settings.question }}
                </span>
                <svg :style="openQ === '{{ unique_id }}' ? 'transform: rotate(45deg)' : ''" class="cc-faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              </button>
              <div x-show="openQ === '{{ unique_id }}'" x-collapse>
                <div style="padding: 0 0 24px; font-family: 'Inter', sans-serif; font-size: 15px; color: var(--warm-gray); line-height: 1.7;">
                  {{ block.settings.answer }}
                </div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}

      </div>
    </section>
    {%- endif -%}
  {%- endfor -%}

  {%- comment -%} === CONTACT CTA === {%- endcomment -%}
  <section style="padding: 80px 24px; background-color: var(--parchment);">
    <div style="max-width: 480px; margin: 0 auto; text-align: center;">
      <h2 class="reveal" style="font-family: 'Space Grotesk', sans-serif; font-size: clamp(22px, 3.5vw, 32px); font-weight: 500; letter-spacing: -0.02em; color: var(--deep-ink); margin: 0 0 12px;">
        Still have questions?
      </h2>
      <p class="reveal" style="font-family: 'Inter', sans-serif; font-size: 17px; color: var(--warm-gray); line-height: 1.7; margin: 0 0 28px;">
        Our team is here to help. Reach out anytime.
      </p>
      <a href="/pages/contact" class="reveal" style="display: inline-block; background: #0A0A0A; color: #FAF9F6; font-family: 'Space Grotesk', sans-serif; font-weight: 500; font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; padding: 20px 48px; text-decoration: none; transition: opacity 0.3s ease;" onmouseover="this.style.opacity='0.8'" onmouseout="this.style.opacity='1'">
        Contact us
      </a>
    </div>
  </section>

  {%- comment -%} === BOTTOM SELL === {%- endcomment -%}
  <section style="padding: 80px 24px; background-color: #0A0A0A;">
    <div style="max-width: 600px; margin: 0 auto; text-align: center;">
      <p class="reveal" style="font-family: 'Inter', sans-serif; font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: #9A9A9A; margin: 0 0 20px;">
        THE COMPLETE LONGEVITY SYSTEM
      </p>
      <h2 class="reveal" style="font-family: 'Space Grotesk', sans-serif; font-size: clamp(24px, 4vw, 36px); font-weight: 500; letter-spacing: -0.02em; color: #FAF9F6; margin: 0 0 12px; line-height: 1.15;">
        Ready to get started?
      </h2>
      <p class="reveal" style="font-family: 'Inter', sans-serif; font-size: 14px; color: #9A9A9A; margin: 0 0 28px;">
        $99/month (save 34%) &middot; Free shipping &middot; 60-day money-back guarantee
      </p>
      <a href="/products/coastline-welcome-pack" target="_blank" class="reveal" style="display: inline-block; background: #FAF9F6; color: #0A0A0A; font-family: 'Space Grotesk', sans-serif; font-weight: 500; font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; padding: 20px 48px; text-decoration: none; transition: opacity 0.3s ease;" onmouseover="this.style.opacity='0.8'" onmouseout="this.style.opacity='1'">
        Start my system
      </a>
    </div>
  </section>

</div>

{%- comment -%} === STYLES === {%- endcomment -%}
<style>
  .cc-faq { --parchment: #FAF9F6; --deep-ink: #0A0A0A; --warm-gray: #6B6B6B; --light-gray: #E8E8E8; --forest: #1A3A2F; }
  .cc-faq * { box-sizing: border-box; }
  .cc-faq p { max-width: none !important; }
  .cc-faq h1, .cc-faq h2 { text-wrap: balance; }

  .cc-faq-icon {
    flex-shrink: 0 !important;
    width: 20px !important;
    height: 20px !important;
    min-width: 20px !important;
    max-width: 20px !important;
    transition: transform 0.3s ease;
    color: var(--warm-gray);
  }

  .cc-faq .reveal {
    opacity: 0; transform: translateY(24px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }
  .cc-faq .reveal.visible { opacity: 1; transform: translateY(0); }

  @media (min-width: 1024px) {
    .header__icons--start .menu-drawer-button { display: none !important; }
  }
</style>

{%- comment -%} === SCROLL REVEAL + SMOOTH ANCHOR === {%- endcomment -%}
<script>
  document.addEventListener('DOMContentLoaded', function() {
    var reveals = document.querySelectorAll('.cc-faq .reveal');
    if (reveals.length) {
      var obs = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) {
          if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
        });
      }, { threshold: 0.15 });
      reveals.forEach(function(el) { obs.observe(el); });
    }
    // Smooth scroll for category nav
    document.querySelectorAll('.cc-faq a[href^="#faq-"]').forEach(function(link) {
      link.addEventListener('click', function(e) {
        e.preventDefault();
        var target = document.querySelector(this.getAttribute('href'));
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });
  });
</script>

{% schema %}
{
  "name": "CC FAQ Page",
  "tag": "div",
  "class": "cc-faq-wrapper",
  "settings": [],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "select",
          "id": "category",
          "label": "Category",
          "options": [
            { "value": "the-system", "label": "The System" },
            { "value": "ingredients", "label": "Ingredients" },
            { "value": "benefits", "label": "Benefits & Expectations" },
            { "value": "usage", "label": "How to Take" },
            { "value": "ordering", "label": "Ordering & Shipping" },
            { "value": "safety", "label": "Safety & Compatibility" }
          ],
          "default": "the-system"
        },
        { "type": "text", "id": "question", "label": "Question", "default": "Question" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Answer</p>" }
      ]
    }
  ],
  "max_blocks": 50,
  "presets": [
    { "name": "CC FAQ Page" }
  ]
}
{% endschema %}
