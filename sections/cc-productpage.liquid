{% render 'cc-deps' %}
{% comment %}
  CC-PRODUCTPAGE: Monolithic product page section
  Contains all 8 product page sections inline.
  Layout: theme.liquid (deps loaded via cc-deps snippet)
{% endcomment %}

<style>
    [x-cloak] { display: none !important; }

    /* ================================================
       COASTLINE DESIGN SYSTEM OVERRIDES
       Scoped to .cc-home, .cc-product, and .cc-productpage
       to avoid breaking theme header/footer styles
       ================================================ */

    :root {
      --parchment: #FAF9F6;
      --deep-ink: #0A0A0A;
      --warm-gray: #6B6B6B;
      --light-gray: #E8E8E8;
      --forest: #1A3A2F;
      --forest-light: #2D5A47;
    }

    /* Override theme.css p max-width inside our sections */
    .cc-home p,
    .cc-product p,
    .cc-productpage p {
      max-width: none !important;
    }

    /* Typography overrides */
    .cc-home h1, .cc-home h2, .cc-home h3,
    .cc-product h1, .cc-product h2, .cc-product h3,
    .cc-productpage h1, .cc-productpage h2, .cc-productpage h3 {
      font-family: 'Space Grotesk', system-ui, sans-serif !important;
      color: var(--deep-ink) !important;
      font-weight: 500 !important;
    }

    .cc-home h1, .cc-product h1, .cc-productpage h1 {
      font-size: clamp(32px, 6vw, 64px) !important;
      letter-spacing: -0.03em !important;
      line-height: 1.1 !important;
    }

    .cc-home h2, .cc-product h2, .cc-productpage h2 {
      font-size: clamp(28px, 5vw, 48px) !important;
      letter-spacing: -0.02em !important;
      line-height: 1.15 !important;
    }

    .cc-home h3, .cc-product h3, .cc-productpage h3 {
      font-size: clamp(20px, 3vw, 24px) !important;
      letter-spacing: -0.01em !important;
      line-height: 1.3 !important;
    }

    .cc-home p, .cc-home li,
    .cc-product p, .cc-product li,
    .cc-productpage p, .cc-productpage li {
      font-family: 'Inter', system-ui, sans-serif !important;
      color: var(--warm-gray) !important;
      font-size: 17px !important;
      line-height: 1.7 !important;
    }

    /* Badge / label */
    .cc-home .badge-minimal,
    .cc-product .badge-minimal,
    .cc-productpage .badge-minimal {
      font-size: 11px !important;
      letter-spacing: 0.15em !important;
      text-transform: uppercase !important;
      color: var(--warm-gray) !important;
      font-family: 'Inter', system-ui, sans-serif !important;
      font-weight: 400 !important;
    }

    /* Editorial divider */
    .cc-home .editorial-divider,
    .cc-product .editorial-divider,
    .cc-productpage .editorial-divider {
      width: 60px;
      height: 1px;
      background: var(--deep-ink);
    }

    /* Hairline */
    .cc-home .hairline,
    .cc-product .hairline,
    .cc-productpage .hairline {
      height: 1px;
      background-color: var(--light-gray);
    }

    /* Primary button */
    .cc-home .btn-primary,
    .cc-product .btn-primary,
    .cc-productpage .btn-primary {
      display: inline-block !important;
      background-color: var(--deep-ink) !important;
      color: var(--parchment) !important;
      font-family: 'Space Grotesk', sans-serif !important;
      font-weight: 500 !important;
      font-size: 12px !important;
      letter-spacing: 0.18em !important;
      text-transform: uppercase !important;
      padding: 20px 48px !important;
      border: none !important;
      border-radius: 0 !important;
      cursor: pointer !important;
      transition: opacity 0.3s ease !important;
      text-decoration: none !important;
      text-align: center !important;
      line-height: 1 !important;
    }

    .cc-home .btn-primary:hover,
    .cc-product .btn-primary:hover,
    .cc-productpage .btn-primary:hover {
      opacity: 0.8 !important;
    }

    /* Secondary button */
    .cc-home .btn-secondary,
    .cc-product .btn-secondary,
    .cc-productpage .btn-secondary {
      display: inline-block !important;
      background-color: transparent !important;
      color: var(--deep-ink) !important;
      border: 1px solid var(--deep-ink) !important;
      font-family: 'Space Grotesk', sans-serif !important;
      font-weight: 500 !important;
      font-size: 12px !important;
      letter-spacing: 0.18em !important;
      text-transform: uppercase !important;
      padding: 20px 48px !important;
      border-radius: 0 !important;
      cursor: pointer !important;
      transition: background-color 0.3s ease, color 0.3s ease !important;
      text-decoration: none !important;
      text-align: center !important;
      line-height: 1 !important;
    }

    .cc-home .btn-secondary:hover,
    .cc-product .btn-secondary:hover,
    .cc-productpage .btn-secondary:hover {
      background-color: var(--deep-ink) !important;
      color: var(--parchment) !important;
    }

    /* Primary button on dark */
    .cc-home .btn-primary-dark,
    .cc-product .btn-primary-dark,
    .cc-productpage .btn-primary-dark {
      display: inline-block !important;
      background: var(--parchment) !important;
      color: var(--deep-ink) !important;
      font-family: 'Space Grotesk', sans-serif !important;
      font-weight: 500 !important;
      font-size: 12px !important;
      letter-spacing: 0.18em !important;
      text-transform: uppercase !important;
      padding: 20px 48px !important;
      border: none !important;
      border-radius: 0 !important;
      cursor: pointer !important;
      transition: opacity 0.3s ease !important;
      text-decoration: none !important;
      text-align: center !important;
      line-height: 1 !important;
    }

    .cc-home .btn-primary-dark:hover,
    .cc-product .btn-primary-dark:hover,
    .cc-productpage .btn-primary-dark:hover {
      opacity: 0.8 !important;
    }

    /* Link underline */
    .cc-home .link-underline,
    .cc-product .link-underline,
    .cc-productpage .link-underline {
      position: relative !important;
      font-size: 13px !important;
      letter-spacing: 0.1em !important;
      text-transform: uppercase !important;
      text-decoration: none !important;
      color: var(--deep-ink) !important;
      font-family: 'Space Grotesk', sans-serif !important;
    }

    .cc-home .link-underline::after,
    .cc-product .link-underline::after,
    .cc-productpage .link-underline::after {
      content: '' !important;
      position: absolute !important;
      bottom: -2px !important;
      left: 0 !important;
      width: 100% !important;
      height: 1px !important;
      background-color: currentColor !important;
      transition: transform 0.3s ease !important;
    }

    .cc-home .link-underline:hover::after,
    .cc-product .link-underline:hover::after,
    .cc-productpage .link-underline:hover::after {
      transform: scaleX(0) !important;
    }

    /* Quote editorial */
    .cc-home .quote-editorial,
    .cc-product .quote-editorial,
    .cc-productpage .quote-editorial {
      font-family: 'Space Grotesk', sans-serif !important;
      font-weight: 400 !important;
      line-height: 1.4 !important;
      letter-spacing: -0.01em !important;
      color: var(--deep-ink) !important;
    }

    /* Stars */
    .cc-home .stars-minimal,
    .cc-product .stars-minimal,
    .cc-productpage .stars-minimal {
      letter-spacing: 4px !important;
      color: var(--deep-ink) !important;
      font-size: 14px !important;
    }

    /* Editorial image filter */
    .cc-home .img-editorial,
    .cc-product .img-editorial,
    .cc-productpage .img-editorial {
      filter: contrast(1.05) brightness(0.98) !important;
    }

    /* Section editorial spacing */
    .cc-home .section-editorial,
    .cc-product .section-editorial,
    .cc-productpage .section-editorial {
      padding: 80px 16px;
    }

    @media (min-width: 768px) {
      .cc-home .section-editorial,
      .cc-product .section-editorial,
      .cc-productpage .section-editorial {
        padding: 120px 32px;
      }
    }

    @media (min-width: 1024px) {
      .cc-home .section-editorial,
      .cc-product .section-editorial,
      .cc-productpage .section-editorial {
        padding: 160px 64px;
      }
    }

    /* Scroll reveal */
    .cc-home .reveal,
    .cc-product .reveal,
    .cc-productpage .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.8s ease, transform 0.8s ease;
    }

    .cc-home .reveal.visible,
    .cc-product .reveal.visible,
    .cc-productpage .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* Stagger children */
    .cc-home .reveal-stagger > *,
    .cc-product .reveal-stagger > *,
    .cc-productpage .reveal-stagger > * {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }

    .cc-home .reveal-stagger.visible > *:nth-child(1),
    .cc-product .reveal-stagger.visible > *:nth-child(1),
    .cc-productpage .reveal-stagger.visible > *:nth-child(1) { transition-delay: 0s; opacity: 1; transform: translateY(0); }
    .cc-home .reveal-stagger.visible > *:nth-child(2),
    .cc-product .reveal-stagger.visible > *:nth-child(2),
    .cc-productpage .reveal-stagger.visible > *:nth-child(2) { transition-delay: 0.1s; opacity: 1; transform: translateY(0); }
    .cc-home .reveal-stagger.visible > *:nth-child(3),
    .cc-product .reveal-stagger.visible > *:nth-child(3),
    .cc-productpage .reveal-stagger.visible > *:nth-child(3) { transition-delay: 0.15s; opacity: 1; transform: translateY(0); }
    .cc-home .reveal-stagger.visible > *:nth-child(4),
    .cc-product .reveal-stagger.visible > *:nth-child(4),
    .cc-productpage .reveal-stagger.visible > *:nth-child(4) { transition-delay: 0.2s; opacity: 1; transform: translateY(0); }
    .cc-home .reveal-stagger.visible > *:nth-child(5),
    .cc-product .reveal-stagger.visible > *:nth-child(5),
    .cc-productpage .reveal-stagger.visible > *:nth-child(5) { transition-delay: 0.25s; opacity: 1; transform: translateY(0); }
    .cc-home .reveal-stagger.visible > *:nth-child(6),
    .cc-product .reveal-stagger.visible > *:nth-child(6),
    .cc-productpage .reveal-stagger.visible > *:nth-child(6) { transition-delay: 0.3s; opacity: 1; transform: translateY(0); }

    /* Reduced motion */
    @media (prefers-reduced-motion: reduce) {
      .cc-home .reveal,
      .cc-product .reveal,
      .cc-productpage .reveal {
        opacity: 1;
        transform: none;
      }
      .cc-home .reveal-stagger > *,
      .cc-product .reveal-stagger > *,
      .cc-productpage .reveal-stagger > * {
        opacity: 1;
        transform: none;
      }
    }

    /* Filter tab */
    .cc-home .filter-tab,
    .cc-product .filter-tab,
    .cc-productpage .filter-tab {
      padding: 8px 16px;
      font-size: 12px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--warm-gray);
      border-bottom: 2px solid transparent;
      transition: color 0.2s ease, border-color 0.2s ease;
      cursor: pointer;
      background: none;
      border-top: none;
      border-left: none;
      border-right: none;
      font-family: 'Space Grotesk', sans-serif;
    }

    .cc-home .filter-tab.active,
    .cc-product .filter-tab.active,
    .cc-productpage .filter-tab.active {
      color: var(--deep-ink);
      border-bottom-color: var(--deep-ink);
    }

    /* Accordion */
    .cc-home .accordion-content,
    .cc-product .accordion-content,
    .cc-productpage .accordion-content {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .cc-home .accordion-content.open,
    .cc-product .accordion-content.open,
    .cc-productpage .accordion-content.open {
      max-height: 1000px;
    }

    /* Section counter */
    .cc-home .section-counter,
    .cc-product .section-counter,
    .cc-productpage .section-counter {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--warm-gray);
    }
</style>

{%- comment -%} === NOSCRIPT FALLBACK === {%- endcomment -%}
<noscript>
  <style>
    .cc-productpage .reveal,
    .cc-productpage .reveal-stagger > * {
      opacity: 1 !important;
      transform: none !important;
    }
  </style>
</noscript>

{%- comment -%} === ASSIGN HERO VARIABLES === {%- endcomment -%}
{%- assign hero_title = section.settings.hero_title | default: "Coastline Complete System" -%}
{%- assign hero_review_text = section.settings.hero_review_text | default: "2,000+ reviews" -%}
{%- assign hero_trust_badges = section.settings.hero_trust_badges | default: "VEGAN, SUGAR-FREE, CAFFEINE-FREE, GMP CERTIFIED" -%}
{%- if section.settings.hero_gallery_image_1 != blank -%}
  {%- assign gallery_img_1 = section.settings.hero_gallery_image_1 | image_url: width: 800 -%}
{%- else -%}
  {%- assign gallery_img_1 = "https://cdn.shopify.com/s/files/1/0619/6861/3445/files/Family_Vert_-_CL_2_20aeec91-5477-425f-84e0-5ea21f9239ad.png?v=1769186113" -%}
{%- endif -%}
{%- if section.settings.hero_gallery_image_2 != blank -%}
  {%- assign gallery_img_2 = section.settings.hero_gallery_image_2 | image_url: width: 800 -%}
{%- else -%}
  {%- assign gallery_img_2 = "https://cdn.shopify.com/s/files/1/0619/6861/3445/files/Creatine_Front2.png?v=1769024194" -%}
{%- endif -%}
{%- if section.settings.hero_gallery_image_3 != blank -%}
  {%- assign gallery_img_3 = section.settings.hero_gallery_image_3 | image_url: width: 800 -%}
{%- else -%}
  {%- assign gallery_img_3 = "https://cdn.shopify.com/s/files/1/0619/6861/3445/files/SOFTGELBOTTLEW_CAPSULE.jpg?v=1764011188" -%}
{%- endif -%}
{%- if section.settings.hero_gallery_image_4 != blank -%}
  {%- assign gallery_img_4 = section.settings.hero_gallery_image_4 | image_url: width: 800 -%}
{%- else -%}
  {%- assign gallery_img_4 = "https://cdn.shopify.com/s/files/1/0619/6861/3445/files/PM_Capsule_Wide_1_2.png?v=1764266766" -%}
{%- endif -%}
{%- if section.settings.hero_gallery_image_5 != blank -%}
  {%- assign gallery_img_5 = section.settings.hero_gallery_image_5 | image_url: width: 800 -%}
{%- else -%}
  {%- assign gallery_img_5 = "https://cdn.shopify.com/s/files/1/0619/6861/3445/files/WELCOME_OPEN_LIGHT_BLUE.jpg?v=1759112312" -%}
{%- endif -%}

<div class="cc-productpage" data-product-id="{{ product.id }}">

  {%- comment -%} Hidden product form + JSON for ReCharge widget detection {%- endcomment -%}
  {%- form 'product', product, id: 'cc-product-form-hidden', style: 'display:none', data-productid: product.id -%}
    <input type="hidden" name="id" data-productid="{{ product.id }}" value="{{ product.selected_or_first_available_variant.id }}">
  {%- endform -%}
  <script type="application/json" id="ProductJSON-{{ product.id }}">
    {{ product | json }}
  </script>

  {%- comment -%} ============================================================
     SECTION 1: PRODUCT HERO (cc-product-02)
  ============================================================ {%- endcomment -%}
  <section id="cc-product-hero" class="section-editorial" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; background-color: var(--parchment);">
    <div style="max-width: 1200px; margin: 0 auto; padding: 0 24px;">

      <div class="cc-product-hero-grid">

        <!-- LEFT SIDE: Gallery (60%) -->
        <div
          x-data="ccProductGallery()"
          class="reveal"
          style="position: relative;"
        >
          <!-- Main Image -->
          <div style="background: #fff; border: 1px solid var(--light-gray); margin-bottom: 12px; overflow: hidden;">
            <img
              :src="images[activeImage]"
              alt="{{ hero_title | escape }}"
              width="800"
              height="800"
              style="width: 100%; height: auto; display: block; object-fit: contain; max-height: 600px;"
              class="img-editorial"
            >
          </div>

          <!-- Thumbnail Strip -->
          <div style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 8px;">
            <template x-for="(img, index) in images" :key="index">
              <div
                @click="activeImage = index"
                :style="activeImage === index ? 'border: 2px solid var(--forest); cursor: pointer; overflow: hidden;' : 'border: 2px solid var(--light-gray); cursor: pointer; overflow: hidden;'"
                style="background: #fff; transition: border-color 0.2s ease;"
              >
                <img
                  :src="img"
                  :alt="'Product image ' + (index + 1)"
                  width="200"
                  height="200"
                  loading="lazy"
                  style="width: 100%; height: auto; display: block; object-fit: contain; aspect-ratio: 1/1;"
                >
              </div>
            </template>
          </div>
        </div>

        <!-- RIGHT SIDE: Buy Panel (40%) -->
        <div
          x-data="ccProductBuy()"
          class="reveal"
          style="padding-top: 8px;"
        >
          <!-- Product Title -->
          <h1 style="font-size: clamp(18px, 2.8vw, 26px) !important; margin: 0 0 10px;">
            {{ hero_title }}
          </h1>

          <!-- Stars + Review Count -->
          <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 16px;">
            <span class="stars-minimal">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
            <span style="font-family: 'Inter', sans-serif; font-size: 13px; color: var(--warm-gray);">{{ hero_review_text }}</span>
          </div>

          <!-- Product Description -->
          <p style="font-family:'Inter',sans-serif;font-size:14px;color:#4A4A4A;line-height:1.6;margin:0 0 4px;">30-day supply of Morning Blend, Softgels, and Evening Capsules</p>
          <p style="font-family:'Inter',sans-serif;font-size:14px;color:#0A0A0A;font-weight:700;line-height:1.6;margin:0 0 16px;">+ Glass Shaker WELCOME GIFT</p>

          <!-- Trust Badges -->
          <p style="margin: 0 0 20px 0; font-family: 'Inter', system-ui, sans-serif; font-size: 9px !important; letter-spacing: 0.1em; text-transform: uppercase; color: var(--warm-gray); line-height: 1.4;">
            {%- assign badge_list = hero_trust_badges | split: ',' -%}
            {%- for badge in badge_list -%}{{ badge | strip }}{%- unless forloop.last %} &middot; {% endunless -%}{%- endfor -%}
          </p>

          <!-- Editorial Divider -->
          <div class="editorial-divider" style="margin-bottom: 28px;"></div>

          <!-- Flavor Selector -->
          <div style="margin-bottom: 28px;">
            <p style="font-family: 'Inter', sans-serif; font-size: 13px; font-weight: 500; color: var(--deep-ink); margin: 0 0 12px; text-transform: uppercase; letter-spacing: 0.1em;">Select your flavor</p>
            <div style="display: flex; gap: 10px;">
              <button @click="flavor = 'unflavored'" :class="flavor === 'unflavored' ? 'cc-flavor-unflavored-active' : 'cc-flavor-unflavored-idle'" class="cc-flavor-btn">Unflavored Blend</button>
              <button @click="flavor = 'lemonade'" :class="flavor === 'lemonade' ? 'cc-flavor-lemonade-active' : 'cc-flavor-lemonade-idle'" class="cc-flavor-btn">Coastal Lemonade</button>
            </div>
          </div>

          <!-- Subscription Selector -->
          <div style="margin-bottom: 28px;">
            <p style="font-family:'Inter',sans-serif;font-size:11px;letter-spacing:0.15em;text-transform:uppercase;color:#6B6B6B;font-weight:500;margin-bottom:14px;">Select your plan</p>

            <!-- Monthly -->
            <div @click="plan = 'monthly'" :class="plan === 'monthly' ? 'cc-plan-active' : 'cc-plan-idle'" class="cc-plan-card" style="margin-bottom:10px;position:relative;">
              <span style="position:absolute;top:-10px;left:20px;background:#0A0A0A;color:#E7FF56;font-family:'Space Grotesk',sans-serif;font-size:10px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;padding:5px 12px;">LIMITED TIME OFFER</span>
              <div style="display:flex;align-items:center;justify-content:space-between;padding:20px;">
                <div>
                  <span style="display:block;font-family:'Space Grotesk',sans-serif;font-weight:500;color:#0A0A0A;font-size:15px;line-height:1.3;">Monthly subscription</span>
                  <span style="display:block;font-family:'Inter',sans-serif;font-size:12px;color:#1A3A2F;font-weight:500;margin-top:3px;">Save 34% - just $3.30/day</span>
                </div>
                <div style="text-align:right;flex-shrink:0;margin-left:16px;">
                  <span style="display:block;font-family:'Space Grotesk',sans-serif;font-weight:600;color:#0A0A0A;font-size:24px;line-height:1;">$99</span>
                  <span style="display:block;font-family:'Inter',sans-serif;font-size:12px;color:#6B6B6B;margin-top:2px;">/month</span>
                </div>
              </div>
            </div>

            <!-- 2-Month -->
            <div @click="plan = 'bimonthly'" :class="plan === 'bimonthly' ? 'cc-plan-active' : 'cc-plan-idle'" class="cc-plan-card" style="margin-bottom:10px;">
              <div style="display:flex;align-items:center;justify-content:space-between;padding:20px;">
                <div>
                  <span style="display:block;font-family:'Space Grotesk',sans-serif;font-weight:500;color:#0A0A0A;font-size:15px;line-height:1.3;">Every 2 months</span>
                  <span style="display:block;font-family:'Inter',sans-serif;font-size:12px;color:#1A3A2F;font-weight:500;margin-top:3px;">Save 20%</span>
                </div>
                <div style="text-align:right;flex-shrink:0;margin-left:16px;">
                  <span style="display:block;font-family:'Space Grotesk',sans-serif;font-weight:600;color:#0A0A0A;font-size:24px;line-height:1;">$120</span>
                  <span style="display:block;font-family:'Inter',sans-serif;font-size:12px;color:#6B6B6B;margin-top:2px;">/month</span>
                </div>
              </div>
            </div>

            <!-- One-time -->
            <div @click="plan = 'onetime'" :class="plan === 'onetime' ? 'cc-plan-active' : 'cc-plan-idle'" class="cc-plan-card">
              <div style="display:flex;align-items:center;justify-content:space-between;padding:20px;">
                <div>
                  <span style="display:block;font-family:'Space Grotesk',sans-serif;font-weight:500;color:#0A0A0A;font-size:15px;line-height:1.3;">One-time purchase</span>
                  <span style="display:block;font-family:'Inter',sans-serif;font-size:12px;color:#6B6B6B;margin-top:3px;">No subscription</span>
                </div>
                <div style="text-align:right;flex-shrink:0;margin-left:16px;">
                  <span style="display:block;font-family:'Space Grotesk',sans-serif;font-weight:600;color:#0A0A0A;font-size:24px;line-height:1;">$150</span>
