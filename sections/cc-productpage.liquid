  <section class="section-editorial" style="padding-top: 80px; padding-bottom: 80px; background:var(--parchment);padding-left:1.5rem;padding-right:1.5rem;">
    <div style="max-width:1100px;margin:0 auto;">

      <div id="cc-reviews-anchor" style="position:relative;top:-100px;visibility:hidden;pointer-events:none;"></div>
      <p class="badge-minimal" style="text-align:center;margin-bottom:0.75rem;letter-spacing:0.15em;font-size:0.75rem;">
        {{ section.settings.reviews_label | default: "WHAT MEMBERS ARE SAYING" }}
      </p>

      <h2 class="reveal" style="text-align:center;color:var(--deep-ink);font-size:clamp(1.5rem,3.5vw,2.25rem);margin:0 0 2rem;">
        {{ section.settings.reviews_headline | default: "Real reviews from real members" }}
      </h2>

      <div x-data="{ reviewFilter: 'all', reviewsShown: 6 }">

        <!-- Filter tabs -->
        <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:0.5rem;margin-bottom:2rem;">
          <button class="cc-review-tab" :class="reviewFilter === 'all' ? 'cc-review-tab-active' : 'cc-review-tab-idle'" @click="reviewFilter = 'all'; reviewsShown = 6">All</button>
          <button class="cc-review-tab" :class="reviewFilter === 'energy' ? 'cc-review-tab-active' : 'cc-review-tab-idle'" @click="reviewFilter = 'energy'; reviewsShown = 6">Energy</button>
          <button class="cc-review-tab" :class="reviewFilter === 'focus' ? 'cc-review-tab-active' : 'cc-review-tab-idle'" @click="reviewFilter = 'focus'; reviewsShown = 6">Focus</button>
          <button class="cc-review-tab" :class="reviewFilter === 'trust' ? 'cc-review-tab-active' : 'cc-review-tab-idle'" @click="reviewFilter = 'trust'; reviewsShown = 6">Trust</button>
          <button class="cc-review-tab" :class="reviewFilter === 'convenience' ? 'cc-review-tab-active' : 'cc-review-tab-idle'" @click="reviewFilter = 'convenience'; reviewsShown = 6">Convenience</button>
        </div>

        <!-- Reviews grid -->
        {%- assign total_all = 0 -%}
        {%- assign total_energy = 0 -%}
        {%- assign total_focus = 0 -%}
        {%- assign total_trust = 0 -%}
        {%- assign total_convenience = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'testimonial' -%}
            {%- assign total_all = total_all | plus: 1 -%}
            {%- assign tcat = block.settings.category | default: 'energy' -%}
            {%- if tcat == 'energy' -%}{%- assign total_energy = total_energy | plus: 1 -%}
            {%- elsif tcat == 'focus' -%}{%- assign total_focus = total_focus | plus: 1 -%}
            {%- elsif tcat == 'trust' -%}{%- assign total_trust = total_trust | plus: 1 -%}
            {%- elsif tcat == 'convenience' -%}{%- assign total_convenience = total_convenience | plus: 1 -%}
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
        <div style="display:grid;gap:1.25rem;" class="cc-reviews-grid">

          {%- assign all_idx = 0 -%}
          {%- assign energy_idx = 0 -%}
          {%- assign focus_idx = 0 -%}
          {%- assign trust_idx = 0 -%}
          {%- assign convenience_idx = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'testimonial' -%}
              {%- assign all_idx = all_idx | plus: 1 -%}
              {%- assign cat = block.settings.category | default: 'energy' -%}
              {%- if cat == 'energy' -%}{%- assign energy_idx = energy_idx | plus: 1 -%}{%- assign cat_idx = energy_idx -%}
              {%- elsif cat == 'focus' -%}{%- assign focus_idx = focus_idx | plus: 1 -%}{%- assign cat_idx = focus_idx -%}
              {%- elsif cat == 'trust' -%}{%- assign trust_idx = trust_idx | plus: 1 -%}{%- assign cat_idx = trust_idx -%}
              {%- elsif cat == 'convenience' -%}{%- assign convenience_idx = convenience_idx | plus: 1 -%}{%- assign cat_idx = convenience_idx -%}
              {%- endif -%}

              <div
                {{ block.shopify_attributes }}
                x-show="(reviewFilter === 'all' && {{ all_idx }} <= reviewsShown) || (reviewFilter === '{{ cat }}' && {{ cat_idx }} <= reviewsShown)"
                x-cloak
                x-transition:enter="transition ease-out duration-300"
                x-transition:enter-start="opacity-0 transform translate-y-4"
                x-transition:enter-end="opacity-100 transform translate-y-0"
                style="padding:1.25rem 0 0;border-top:1px solid var(--light-gray);"
              >
                <p class="stars-minimal" style="color:var(--deep-ink);font-size:0.875rem;margin:0 0 0.5rem;letter-spacing:0.1em;">&#9733;&#9733;&#9733;&#9733;&#9733;</p>
                <p style="color:var(--deep-ink);font-size:0.9375rem;line-height:1.6;margin:0 0 0.75rem;">
                  "{{ block.settings.quote }}"
                </p>
                <p class="badge-minimal" style="color:var(--warm-gray);font-size:0.75rem;margin:0;letter-spacing:0.08em;">
                  {{ block.settings.name }}{% if block.settings.detail != blank %}, {{ block.settings.detail }}{% endif %}
                </p>
              </div>
            {%- endif -%}
          {%- endfor -%}

        </div>

        <!-- Show more / show less buttons -->
        <div style="text-align:center;margin-top:2rem;display:flex;justify-content:center;gap:0.75rem;flex-wrap:wrap;">
          <button
            class="cc-review-tab cc-review-tab-idle"
            x-show="(reviewFilter === 'all' && reviewsShown < {{ total_all }}) || (reviewFilter === 'energy' && reviewsShown < {{ total_energy }}) || (reviewFilter === 'focus' && reviewsShown < {{ total_focus }}) || (reviewFilter === 'trust' && reviewsShown < {{ total_trust }}) || (reviewFilter === 'convenience' && reviewsShown < {{ total_convenience }})"
            @click="reviewsShown = reviewsShown + 6"
            x-transition
            style="cursor:pointer;"
          >SHOW MORE REVIEWS</button>
          <button
            class="cc-review-tab cc-review-tab-idle"
            x-show="reviewsShown > 6"
            @click="reviewsShown = 6; $nextTick(() => { document.getElementById('cc-reviews-anchor').scrollIntoView({ behavior: 'smooth' }) })"
            x-transition
            style="cursor:pointer;"
          >SHOW LESS</button>
        </div>

      </div>
    </div>
  </section>


  <!-- Divider image between Reviews and Comparison -->
