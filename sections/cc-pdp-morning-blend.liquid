<script>
  /* Alpine: Morning Blend Buy Panel */
  function ccMBBuy() {
    return {
      flavor: 'unflavored',
      plan: 'monthly',
      loading: false,
      get variantId() {
        return this.flavor === 'lemonade' ? 43926823174213 : 43926823141445;
      },
      get sellingPlan() {
        if (this.plan === 'monthly') return 1840349253;
        if (this.plan === 'bimonthly') return 1840644165;
        return null;
      },
      get buttonPrice() {
        if (this.plan === 'monthly') return '$55.20/MO';
        if (this.plan === 'bimonthly') return '$62.10/MO';
        return '$69';
      },
      get sellingPlanId() {
        return this.sellingPlan;
      }
    };
  }

</script>


