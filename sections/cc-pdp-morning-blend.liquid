                x-show="{{ mb_review_idx }} <= reviewsShown"
                x-transition:enter="transition ease-out duration-300"
                x-transition:enter-start="opacity-0 transform translate-y-4"
                x-transition:enter-end="opacity-100 transform translate-y-0"
                style="padding:28px 32px;border:1px solid var(--light-gray);background:#fff;"
              >
                <p style="color:var(--deep-ink);font-size:14px;margin:0 0 8px;letter-spacing:0.1em;">&#9733;&#9733;&#9733;&#9733;&#9733;</p>
                <p style="color:var(--deep-ink);font-size:16px;line-height:1.65;margin:0 0 16px;font-family:'Inter',sans-serif;">"{{ block.settings.quote }}"</p>
