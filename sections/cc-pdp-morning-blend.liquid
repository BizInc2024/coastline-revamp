{% render 'cc-deps' %}
{% comment %}
  CC-PRODUCTPAGE-MORNING-BLEND: Individual product page for Morning Blend
  Layout: theme.liquid (deps loaded via cc-deps snippet)
{% endcomment %}

<script>
    tailwind.config = {
        theme: {
            extend: {
                colors: {
                    'parchment': '#FAF9F6',
                    'deep-ink': '#0A0A0A',
                    'warm-gray': '#6B6B6B',
                    'light-gray': '#E8E8E8',
                    'forest': '#1A3A2F',
                    'forest-light': '#2D5A47',
                    'ocean': '#062F3D',
                    'brand-navy': '#1E2D4D',
                },
                fontFamily: {
                    'grotesk': ['Space Grotesk', 'system-ui', 'sans-serif'],
                    'inter': ['Inter', 'system-ui', 'sans-serif'],
                }
            }
        }
    }
</script>

<style>
    :root {
      --parchment: #FAF9F6;
      --deep-ink: #0A0A0A;
      --warm-gray: #6B6B6B;
      --light-gray: #E8E8E8;
      --forest: #1A3A2F;
      --forest-light: #2D5A47;
    }

    .cc-productpage-mb p,
    .cc-product p {
      max-width: none !important;
    }

    .cc-productpage-mb h1, .cc-productpage-mb h2, .cc-productpage-mb h3,
    .cc-product h1, .cc-product h2, .cc-product h3 {
      font-family: 'Space Grotesk', system-ui, sans-serif !important;
      color: var(--deep-ink) !important;
      font-weight: 500 !important;
    }

    .cc-productpage-mb h1, .cc-product h1 {
      font-size: clamp(32px, 6vw, 64px) !important;
      letter-spacing: -0.03em !important;
      line-height: 1.1 !important;
    }

    .cc-productpage-mb h2, .cc-product h2 {
      font-size: clamp(28px, 5vw, 48px) !important;
      letter-spacing: -0.02em !important;
      line-height: 1.15 !important;
    }

    .cc-productpage-mb h3, .cc-product h3 {
      font-size: clamp(20px, 3vw, 24px) !important;
      letter-spacing: -0.01em !important;
      line-height: 1.3 !important;
    }

    .cc-productpage-mb p, .cc-productpage-mb li,
    .cc-product p, .cc-product li {
      font-family: 'Inter', system-ui, sans-serif !important;
      color: var(--warm-gray) !important;
      font-size: 17px !important;
      line-height: 1.7 !important;
    }

    .cc-productpage-mb .badge-minimal,
    .cc-product .badge-minimal {
      font-size: 11px !important;
      letter-spacing: 0.15em !important;
      text-transform: uppercase !important;
      color: var(--warm-gray) !important;
      font-family: 'Inter', system-ui, sans-serif !important;
      font-weight: 400 !important;
    }

    .cc-productpage-mb .editorial-divider,
    .cc-product .editorial-divider {
      width: 60px;
      height: 1px;
      background: var(--deep-ink);
    }

    .cc-productpage-mb .hairline,
    .cc-product .hairline {
      height: 1px;
      background-color: var(--light-gray);
    }

    .cc-productpage-mb .btn-primary,
    .cc-product .btn-primary {
      display: inline-block !important;
      background-color: var(--deep-ink) !important;
      color: var(--parchment) !important;
      font-family: 'Space Grotesk', sans-serif !important;
      font-weight: 500 !important;
      font-size: 12px !important;
      letter-spacing: 0.18em !important;
      text-transform: uppercase !important;
      padding: 20px 48px !important;
      border: none !important;
      border-radius: 0 !important;
      cursor: pointer !important;
      transition: opacity 0.3s ease !important;
      text-decoration: none !important;
      text-align: center !important;
      line-height: 1 !important;
    }

    .cc-productpage-mb .btn-primary:hover,
    .cc-product .btn-primary:hover {
      opacity: 0.8 !important;
    }

    .cc-productpage-mb .btn-secondary,
    .cc-product .btn-secondary {
      display: inline-block !important;
      background-color: transparent !important;
      color: var(--deep-ink) !important;
      border: 1px solid var(--deep-ink) !important;
      font-family: 'Space Grotesk', sans-serif !important;
      font-weight: 500 !important;
      font-size: 12px !important;
      letter-spacing: 0.18em !important;
      text-transform: uppercase !important;
      padding: 20px 48px !important;
      border-radius: 0 !important;
      cursor: pointer !important;
      transition: background-color 0.3s ease, color 0.3s ease !important;
      text-decoration: none !important;
      text-align: center !important;
      line-height: 1 !important;
    }

    .cc-productpage-mb .btn-secondary:hover,
    .cc-product .btn-secondary:hover {
      background-color: var(--deep-ink) !important;
      color: var(--parchment) !important;
    }

    .cc-productpage-mb .btn-primary-dark,
    .cc-product .btn-primary-dark {
      display: inline-block !important;
      background: var(--parchment) !important;
      color: var(--deep-ink) !important;
      font-family: 'Space Grotesk', sans-serif !important;
      font-weight: 500 !important;
      font-size: 12px !important;
      letter-spacing: 0.18em !important;
      text-transform: uppercase !important;
      padding: 20px 48px !important;
      border: none !important;
      border-radius: 0 !important;
      cursor: pointer !important;
      transition: opacity 0.3s ease !important;
      text-decoration: none !important;
      text-align: center !important;
      line-height: 1 !important;
    }

    .cc-productpage-mb .btn-primary-dark:hover,
    .cc-product .btn-primary-dark:hover {
      opacity: 0.8 !important;
    }

    .cc-productpage-mb .link-underline,
    .cc-product .link-underline {
      position: relative !important;
      font-size: 13px !important;
      letter-spacing: 0.1em !important;
      text-transform: uppercase !important;
      text-decoration: none !important;
      color: var(--deep-ink) !important;
      font-family: 'Space Grotesk', sans-serif !important;
    }

    .cc-productpage-mb .link-underline::after,
    .cc-product .link-underline::after {
      content: '' !important;
      position: absolute !important;
      bottom: -2px !important;
      left: 0 !important;
      width: 100% !important;
      height: 1px !important;
      background-color: currentColor !important;
      transition: transform 0.3s ease !important;
    }

    .cc-productpage-mb .link-underline:hover::after,
    .cc-product .link-underline:hover::after {
      transform: scaleX(0) !important;
    }

    .cc-productpage-mb .quote-editorial,
    .cc-product .quote-editorial {
      font-family: 'Space Grotesk', sans-serif !important;
      font-weight: 400 !important;
      line-height: 1.4 !important;
      letter-spacing: -0.01em !important;
      color: var(--deep-ink) !important;
    }

    .cc-productpage-mb .stars-minimal,
    .cc-product .stars-minimal {
      letter-spacing: 4px !important;
      color: var(--deep-ink) !important;
      font-size: 14px !important;
    }

    .cc-productpage-mb .img-editorial,
    .cc-product .img-editorial {
      filter: contrast(1.05) brightness(0.98) !important;
    }

    .cc-productpage-mb .section-editorial,
    .cc-product .section-editorial {
      padding: 80px 16px;
    }

    @media (min-width: 768px) {
      .cc-productpage-mb .section-editorial,
      .cc-product .section-editorial {
        padding: 120px 32px;
      }
    }

    @media (min-width: 1024px) {
      .cc-productpage-mb .section-editorial,
      .cc-product .section-editorial {
        padding: 160px 64px;
      }
    }

    .cc-productpage-mb .filter-tab,
    .cc-product .filter-tab {
      padding: 8px 16px;
      font-size: 12px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--warm-gray);
      border-bottom: 2px solid transparent;
      transition: color 0.2s ease, border-color 0.2s ease;
      cursor: pointer;
      background: none;
      border-top: none;
      border-left: none;
      border-right: none;
      font-family: 'Space Grotesk', sans-serif;
    }

    .cc-productpage-mb .filter-tab.active,
    .cc-product .filter-tab.active {
      color: var(--deep-ink);
      border-bottom-color: var(--deep-ink);
    }

    .cc-productpage-mb .accordion-content,
    .cc-product .accordion-content {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .cc-productpage-mb .accordion-content.open,
    .cc-product .accordion-content.open {
      max-height: 1000px;
    }

    .cc-productpage-mb .section-counter,
    .cc-product .section-counter {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--warm-gray);
    }
</style>

{%- comment -%} === ASSIGN HERO VARIABLES === {%- endcomment -%}
{%- assign mb_title = section.settings.hero_title | default: "Coastline AM Blend" -%}
{%- assign mb_review_text = section.settings.hero_review_text | default: "2,000+ reviews" -%}
{%- assign mb_trust_badges = section.settings.hero_trust_badges | default: "VEGAN, SUGAR-FREE, CAFFEINE-FREE" -%}
{%- if section.settings.hero_gallery_image_1 != blank -%}
  {%- assign mb_hero_img = section.settings.hero_gallery_image_1 | image_url: width: 800 -%}
{%- else -%}
  {%- assign mb_hero_img = "cc-mb-hero-hand-bag.png" | asset_url -%}
{%- endif -%}

<div class="cc-productpage-mb">

  {%- comment -%} ============================================================
     SECTION 1: PRODUCT HERO (60/40 grid)
  ============================================================ {%- endcomment -%}
  <section id="cc-mb-product-hero" class="section-editorial" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; background-color: var(--parchment);">
    <div style="max-width: 1200px; margin: 0 auto; padding: 0 24px;">

      <div class="cc-mb-hero-grid">

        <!-- LEFT SIDE: Product Image (60%) -->
        <div style="position: relative;">
          <div style="overflow: hidden;">
            <img
              src="{{ mb_hero_img }}"
              alt="{{ mb_title | escape }}"
              width="800"
              height="800"
              style="width: 100%; height: auto; display: block; object-fit: cover; max-height: 600px;"
              class="img-editorial"
            >
          </div>
        </div>

        <!-- RIGHT SIDE: Buy Panel (40%) -->
        <div
          x-data="ccMBBuy()"
          style="padding-top: 8px;"
        >
          <!-- Product Title -->
          <h1 style="font-size: clamp(28px, 4vw, 40px); margin: 0 0 16px;">
            {{ mb_title }}
          </h1>

          <!-- Stars + Review Count -->
          <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 20px;">
            <span class="stars-minimal">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
            <span style="font-family: 'Inter', sans-serif; font-size: 14px; color: var(--warm-gray);">{{ mb_review_text }}</span>
          </div>

          <!-- Trust Badges -->
          <p style="margin: 0 0 24px 0; font-family: 'Inter', system-ui, sans-serif; font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--warm-gray); line-height: 1.4;">
            {%- assign mb_badge_list = mb_trust_badges | split: ',' -%}
            {%- for badge in mb_badge_list -%}{{ badge | strip }}{%- unless forloop.last %} &middot; {% endunless -%}{%- endfor -%}
          </p>

          <!-- Editorial Divider -->
          <div class="editorial-divider" style="margin-bottom: 28px;"></div>

          <!-- Product Description -->
          <p style="font-family: 'Inter', sans-serif; font-size: 15px; color: var(--warm-gray); line-height: 1.6; margin: 0 0 24px;">
            {{ section.settings.hero_description | default: "7 science-backed ingredients in one easy-scoop powder. Mix with water and take with your first meal. Supports energy, focus, muscle, joints, and gut health." }}
          </p>

          <!-- Flavor Selector -->
          <div style="margin-bottom: 28px;">
            <p style="font-family: 'Inter', sans-serif; font-size: 13px; font-weight: 500; color: var(--deep-ink); margin: 0 0 12px; text-transform: uppercase; letter-spacing: 0.1em;">Select your flavor</p>
            <div style="display: flex; gap: 10px;">
              <button @click="flavor = 'unflavored'" :class="flavor === 'unflavored' ? 'cc-mb-flavor-unflavored-active' : 'cc-mb-flavor-unflavored-idle'" class="cc-mb-flavor-btn">Unflavored Blend</button>
              <button @click="flavor = 'lemonade'" :class="flavor === 'lemonade' ? 'cc-mb-flavor-lemonade-active' : 'cc-mb-flavor-lemonade-idle'" class="cc-mb-flavor-btn">Coastal Lemonade</button>
            </div>
          </div>

          <!-- Subscription Selector -->
          <div style="margin-bottom: 28px;">
            <p style="font-family:'Inter',sans-serif;font-size:11px;letter-spacing:0.15em;text-transform:uppercase;color:#6B6B6B;font-weight:500;margin-bottom:14px;">Select your plan</p>

            <!-- Monthly -->
            <div @click="plan = 'monthly'" :class="plan === 'monthly' ? 'cc-mb-plan-active' : 'cc-mb-plan-idle'" class="cc-mb-plan-card" style="margin-bottom:10px;">
              <div style="display:flex;align-items:center;justify-content:space-between;padding:20px;">
                <div>
                  <span style="display:block;font-family:'Space Grotesk',sans-serif;font-weight:500;color:#0A0A0A;font-size:15px;line-height:1.3;">Monthly subscription</span>
                  <span style="display:block;font-family:'Inter',sans-serif;font-size:12px;color:#1A3A2F;font-weight:500;margin-top:3px;">Save 20% -- $1.84/day</span>
                </div>
                <div style="text-align:right;flex-shrink:0;margin-left:16px;">
                  <span style="display:block;font-family:'Space Grotesk',sans-serif;font-weight:600;color:#0A0A0A;font-size:24px;line-height:1;">$55.20</span>
                  <span style="display:block;font-family:'Inter',sans-serif;font-size:12px;color:#6B6B6B;margin-top:2px;">/month</span>
                </div>
              </div>
            </div>

            <!-- 2-Month -->
            <div @click="plan = 'bimonthly'" :class="plan === 'bimonthly' ? 'cc-mb-plan-active' : 'cc-mb-plan-idle'" class="cc-mb-plan-card" style="margin-bottom:10px;">
              <div style="display:flex;align-items:center;justify-content:space-between;padding:20px;">
                <div>
                  <span style="display:block;font-family:'Space Grotesk',sans-serif;font-weight:500;color:#0A0A0A;font-size:15px;line-height:1.3;">Every 2 months</span>
                  <span style="display:block;font-family:'Inter',sans-serif;font-size:12px;color:#1A3A2F;font-weight:500;margin-top:3px;">Save 10%</span>
                </div>
                <div style="text-align:right;flex-shrink:0;margin-left:16px;">
                  <span style="display:block;font-family:'Space Grotesk',sans-serif;font-weight:600;color:#0A0A0A;font-size:24px;line-height:1;">$62.10</span>
                  <span style="display:block;font-family:'Inter',sans-serif;font-size:12px;color:#6B6B6B;margin-top:2px;">/month</span>
                </div>
              </div>
            </div>

            <!-- One-time -->
            <div @click="plan = 'onetime'" :class="plan === 'onetime' ? 'cc-mb-plan-active' : 'cc-mb-plan-idle'" class="cc-mb-plan-card">
              <div style="display:flex;align-items:center;justify-content:space-between;padding:20px;">
                <div>
                  <span style="display:block;font-family:'Space Grotesk',sans-serif;font-weight:500;color:#0A0A0A;font-size:15px;line-height:1.3;">One-time purchase</span>
                  <span style="display:block;font-family:'Inter',sans-serif;font-size:12px;color:#6B6B6B;margin-top:3px;">No subscription</span>
                </div>
                <div style="text-align:right;flex-shrink:0;margin-left:16px;">
                  <span style="display:block;font-family:'Space Grotesk',sans-serif;font-weight:600;color:#0A0A0A;font-size:24px;line-height:1;">$69</span>
                  <span style="display:block;font-family:'Inter',sans-serif;font-size:12px;color:#6B6B6B;margin-top:2px;">one-time</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Add to Cart Form -->
          <form id="cc-pdp-mb-cart-form" action="/cart/add" method="post" is="product-form" data-type="add-to-cart-form">
            <input type="hidden" name="id" :value="variantId" />
            <template x-if="sellingPlanId">
              <input type="hidden" name="selling_plan" :value="sellingPlanId" />
            </template>
            <button
              type="submit"
              :disabled="loading"
              style="width:100%;padding:22px 48px;font-size:14px;margin-bottom:20px;background:#0A0A0A !important;color:#FAF9F6 !important;border:none !important;font-family:'Space Grotesk',sans-serif;font-weight:500;letter-spacing:0.18em;text-transform:uppercase;cursor:pointer;transition:opacity 0.3s ease;"
            >
              <span class="btn-text"><span x-show="!loading">ADD TO CART - <span x-text="buttonPrice"></span></span>
              <span x-show="loading">ADDING...</span></span>
            </button>
          </form>

          <!-- Micro-copy -->
          <div style="display: flex; justify-content: center; gap: 24px; flex-wrap: wrap;">
            <span style="font-family: 'Inter', sans-serif; font-size: 12px; color: var(--warm-gray); display: flex; align-items: center; gap: 6px;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              Free shipping
            </span>
            <span style="font-family: 'Inter', sans-serif; font-size: 12px; color: var(--warm-gray); display: flex; align-items: center; gap: 6px;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M8 12l3 3 5-5"/></svg>
              Cancel anytime
            </span>
            <span style="font-family: 'Inter', sans-serif; font-size: 12px; color: var(--warm-gray); display: flex; align-items: center; gap: 6px;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              60-day guarantee
            </span>
          </div>

          <!-- Trust badge images -->
          <div style="display:flex;justify-content:center;align-items:center;gap:20px;margin-top:24px;">
            <img src="https://cdn.shopify.com/s/files/1/0619/6861/3445/files/istockphoto-1279030031-612x612_1.png?v=1767983702" alt="Third-party tested" style="height:48px;object-fit:contain;opacity:0.7;" loading="lazy">
            <img src="{{ 'cc-nsf-certified.png' | asset_url }}" alt="NSF Certified" style="height:48px;object-fit:contain;opacity:0.7;" loading="lazy">
            <img src="https://cdn.shopify.com/s/files/1/0619/6861/3445/files/download_1.png?v=1767983648" alt="GMP Certified" style="height:48px;object-fit:contain;opacity:0.7;" loading="lazy">
            <img src="https://cdn.shopify.com/s/files/1/0619/6861/3445/files/60-days-money-back-guarantee-icon-for-graphic-design-logo-website-social-media-mobile-app-ui-illustration-vector_1.png?v=1767983637" alt="60-Day Guarantee" style="height:48px;object-fit:contain;opacity:0.7;" loading="lazy">
          </div>

        </div>

      </div>

    </div>
  </section>


  {%- comment -%} === SECTION 2: PRESS LOGO BAR + DIVIDER IMAGE === {%- endcomment -%}

  <!-- Press Logo Bar -->
  <section style="padding:40px 1.5rem;background:var(--parchment);border-bottom:1px solid var(--light-gray);">
    <div style="max-width:64rem;margin:0 auto;text-align:center;">
      <p style="font-family:'Inter',system-ui,sans-serif;font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:var(--warm-gray);font-weight:500;margin:0 0 24px;">
        {{ section.settings.press_label | default: "AS FEATURED IN" }}
      </p>
      <div style="display:flex;flex-wrap:wrap;justify-content:center;align-items:center;gap:32px;opacity:0.4;filter:grayscale(100%);">
        <img src="https://cdn.shopify.com/s/files/1/0619/6861/3445/files/CL-PARTNERSHIP_LOGOS-1.png?v=1769181223" alt="Uncrate" class="cc-mb-press-logo" style="height:52px;width:auto;" loading="lazy">
        <img src="https://cdn.shopify.com/s/files/1/0619/6861/3445/files/CL-PARTNERSHIP_LOGOS-2.png?v=1769181172" alt="Vice" class="cc-mb-press-logo" style="height:52px;width:auto;" loading="lazy">
        <img src="https://cdn.shopify.com/s/files/1/0619/6861/3445/files/CL-PARTNERSHIP_LOGOS-3.png?v=1769181068" alt="Daily Beast" class="cc-mb-press-logo" style="height:52px;width:auto;" loading="lazy">
        <img src="https://cdn.shopify.com/s/files/1/0619/6861/3445/files/CL-PARTNERSHIP_LOGOS-4.png?v=1769181109" alt="Us Weekly" class="cc-mb-press-logo" style="height:52px;width:auto;" loading="lazy">
      </div>
    </div>
  </section>

  <div style="margin:0;padding:0;">
    {%- if section.settings.divider_image_1 != blank -%}
      <img src="{{ section.settings.divider_image_1 | image_url: width: 1600 }}" alt="Coastline" style="width:100%;max-height:50vh;object-fit:cover;display:block;" loading="lazy">
    {%- else -%}
      <img src="https://cdn.shopify.com/s/files/1/0619/6861/3445/files/canon-beach-haystack_1.png?v=1764011837" alt="Coastline" style="width:100%;max-height:50vh;object-fit:cover;display:block;" loading="lazy">
    {%- endif -%}
  </div>

  {%- comment -%} ============================================================
     SECTION 3: KEY BENEFITS
  ============================================================ {%- endcomment -%}
  <section class="section-editorial reveal" style="padding-top:80px;padding-bottom:80px;background:var(--parchment);">
    <div style="max-width:800px;margin:0 auto;padding:0 1.5rem;">

      <div style="text-align:center;margin-bottom:48px;">
        <p style="font-family:'Inter',sans-serif;font-size:11px;letter-spacing:0.15em;text-transform:uppercase;color:var(--warm-gray);font-weight:500;margin-bottom:20px;">WHY MORNING BLEND</p>
        <h2 style="font-family:'Space Grotesk',sans-serif;font-size:clamp(28px,5vw,42px);font-weight:500;color:var(--deep-ink);letter-spacing:-0.02em;line-height:1.2;margin:0;">7 ingredients working together for your morning</h2>
      </div>

      <div x-data="{ openBenefit: null }">

        <div style="border-bottom:1px solid var(--light-gray);padding:20px 0;cursor:pointer;" @click="openBenefit === 'energy' ? openBenefit = null : openBenefit = 'energy'">
          <div style="display:flex;justify-content:space-between;align-items:center;">
            <p style="font-family:'Space Grotesk',sans-serif;font-weight:500;font-size:18px;color:var(--deep-ink);margin:0;">Sustained energy</p>
            <span style="font-size:1.25rem;color:var(--warm-gray);transition:transform 0.3s ease;" :style="openBenefit === 'energy' ? 'transform:rotate(45deg)' : ''">+</span>
          </div>
