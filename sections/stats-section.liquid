{% comment %}
  Shopify Section: Stats Section with Count-Up Animation
  
  This section creates a full-width stats display with:
  - Customizable heading
  - Up to 5 stats with pill labels, numbers, descriptions, and sources
  - Separate desktop/mobile background images with overlay control
  - Full responsive layout
  - All content editable via Shopify theme customizer
{% endcomment %}

{% assign ai_gen_id = section.id | replace: '_', '' | downcase %}

{% style %}
  .ai-stats-section-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    padding-top: {{ section.settings.section_padding_top }}px;
    padding-bottom: {{ section.settings.section_padding_bottom }}px;
  }

  .ai-stats-content-{{ ai_gen_id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .ai-stats-bg-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .ai-stats-bg-desktop-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    {% if section.settings.desktop_image_height_type == 'adapt' %}
      height: auto;
    {% elsif section.settings.desktop_image_height_type == 'fullscreen' %}
      height: 100vh;
    {% else %}
      height: {{ section.settings.desktop_image_height }}px;
    {% endif %}
    object-fit: {{ section.settings.desktop_image_fit }};
    object-position: center;
  }

  .ai-stats-bg-mobile-{{ ai_gen_id }} {
    display: none;
    width: 100%;
    {% if section.settings.mobile_image_height_type == 'adapt' %}
      height: auto;
    {% elsif section.settings.mobile_image_height_type == 'fullscreen' %}
      height: 100vh;
    {% else %}
      height: {{ section.settings.mobile_image_height }}px;
    {% endif %}
    object-fit: {{ section.settings.mobile_image_fit }};
    object-position: center;
  }

  .ai-stats-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ section.settings.overlay_color }};
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 1;
  }

  .ai-stats-divider-top-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    width: 100%;
    height: 1px;
    background-color: {{ section.settings.divider_color }};
    margin-bottom: {{ section.settings.padding_top }}px;
  }

  .ai-stats-divider-bottom-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    width: 100%;
    height: 1px;
    background-color: {{ section.settings.divider_color }};
    margin-top: {{ section.settings.padding_bottom }}px;
  }

  .ai-stats-container-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    max-width: 100%;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-stats-heading-{{ ai_gen_id }} {
    text-align: center;
    font-size: {{ section.settings.heading_font_size }}px;
    color: {{ section.settings.heading_color }};
    margin: 0 0 {{ section.settings.heading_spacing }}px 0;
  }

  .ai-stats-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: {{ section.settings.column_gap_desktop }}px;
    align-items: center;
  }

  .ai-stats-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .ai-stats-pill-{{ ai_gen_id }} {
    display: inline-block;
    padding: 6px 16px;
    border-radius: 50px;
    font-size: {{ section.settings.pill_font_size }}px;
    margin-bottom: 12px;
  }

  .ai-stats-number-{{ ai_gen_id }} {
    font-size: {{ section.settings.stat_font_size }}px;
    font-weight: 900;
    color: {{ section.settings.stat_color }};
    margin: 0 0 8px 0;
    line-height: 0.9;
    letter-spacing: -0.02em;
  }

  .ai-stats-number-{{ ai_gen_id }}.counting {
    opacity: 1;
  }

  .ai-stats-subtext-{{ ai_gen_id }} {
    font-size: {{ section.settings.subtext_font_size }}px;
    color: {{ section.settings.subtext_color }};
    margin: 0 0 8px 0;
    line-height: 1.4;
  }

  .ai-stats-source-{{ ai_gen_id }} {
    font-size: {{ section.settings.source_font_size }}px;
    color: {{ section.settings.source_color }};
    margin: 0;
    opacity: 0.7;
  }

  @media screen and (max-width: 989px) {
    .ai-stats-grid-{{ ai_gen_id }} {
      gap: {{ section.settings.column_gap_tablet }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-stats-section-{{ ai_gen_id }} {
      padding-top: {{ section.settings.section_padding_top | times: 0.6 }}px;
      padding-bottom: {{ section.settings.section_padding_bottom | times: 0.6 }}px;
    }

    .ai-stats-content-{{ ai_gen_id }} {
      padding-top: {{ section.settings.padding_top | times: 0.7 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.7 }}px;
    }

    .ai-stats-bg-desktop-{{ ai_gen_id }} {
      display: none;
    }

    .ai-stats-bg-mobile-{{ ai_gen_id }} {
      display: block;
    }

    .ai-stats-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ section.settings.column_gap_mobile }}px;
    }

    .ai-stats-item-{{ ai_gen_id }} {
      align-items: flex-start;
      text-align: left;
    }

    .ai-stats-heading-{{ ai_gen_id }} {
      font-size: {{ section.settings.heading_font_size_mobile }}px;
      text-align: left;
    }

    .ai-stats-number-{{ ai_gen_id }} {
      font-size: {{ section.settings.stat_font_size }}px;
    }
  }
{% endstyle %}

<div class="ai-stats-section-{{ ai_gen_id }}" {{ section.shopify_attributes }}>
  <div class="ai-stats-bg-{{ ai_gen_id }}">
    {% if section.settings.desktop_bg_image %}
      <img
        src="{{ section.settings.desktop_bg_image | image_url: width: 2400 }}"
        alt="{{ section.settings.desktop_bg_image.alt | escape }}"
        loading="lazy"
        width="{{ section.settings.desktop_bg_image.width }}"
        height="{{ section.settings.desktop_bg_image.height }}"
        class="ai-stats-bg-desktop-{{ ai_gen_id }}"
      >
    {% endif %}

    {% if section.settings.mobile_bg_image %}
      <img
        src="{{ section.settings.mobile_bg_image | image_url: width: 1200 }}"
        alt="{{ section.settings.mobile_bg_image.alt | escape }}"
        loading="lazy"
        width="{{ section.settings.mobile_bg_image.width }}"
        height="{{ section.settings.mobile_bg_image.height }}"
        class="ai-stats-bg-mobile-{{ ai_gen_id }}"
      >
    {% elsif section.settings.desktop_bg_image %}
      <img
        src="{{ section.settings.desktop_bg_image | image_url: width: 1200 }}"
        alt="{{ section.settings.desktop_bg_image.alt | escape }}"
        loading="lazy"
        width="{{ section.settings.desktop_bg_image.width }}"
        height="{{ section.settings.desktop_bg_image.height }}"
        class="ai-stats-bg-mobile-{{ ai_gen_id }}"
      >
    {% endif %}

    <div class="ai-stats-overlay-{{ ai_gen_id }}"></div>
  </div>

  {% if section.settings.show_divider_top %}
    <div class="ai-stats-divider-top-{{ ai_gen_id }}"></div>
  {% endif %}

  <div class="ai-stats-content-{{ ai_gen_id }}">
    <div class="ai-stats-container-{{ ai_gen_id }}">
    {% if section.settings.heading != blank %}
      <div class="ai-stats-heading-{{ ai_gen_id }}">
        {{ section.settings.heading }}
      </div>
    {% endif %}

    <div class="ai-stats-grid-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign pill_text_key = 'stat_' | append: i | append: '_pill_text'
          assign pill_bg_key = 'stat_' | append: i | append: '_pill_bg'
          assign pill_text_color_key = 'stat_' | append: i | append: '_pill_text_color'
          assign number_key = 'stat_' | append: i | append: '_number'
          assign subtext_key = 'stat_' | append: i | append: '_subtext'
          assign source_key = 'stat_' | append: i | append: '_source'

          assign pill_text = section.settings[pill_text_key]
          assign pill_bg = section.settings[pill_bg_key]
          assign pill_text_color = section.settings[pill_text_color_key]
          assign number = section.settings[number_key]
          assign subtext = section.settings[subtext_key]
          assign source = section.settings[source_key]
        %}

        {% if pill_text != blank or number != blank or subtext != blank or source != blank %}
          <div class="ai-stats-item-{{ ai_gen_id }}">
            {% if pill_text != blank %}
              <span
                class="ai-stats-pill-{{ ai_gen_id }}"
                style="background-color: {{ pill_bg }}; color: {{ pill_text_color }};"
              >
                {{ pill_text }}
              </span>
            {% endif %}

            {% if number != blank %}
              <div class="ai-stats-number-{{ ai_gen_id }}" data-target="{{ number }}">0</div>
            {% endif %}

            {% if subtext != blank %}
              <div class="ai-stats-subtext-{{ ai_gen_id }}">{{ subtext }}</div>
            {% endif %}

            {% if source != blank %}
              <div class="ai-stats-source-{{ ai_gen_id }}">{{ source }}</div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
  </div>

  {% if section.settings.show_divider_bottom %}
    <div class="ai-stats-divider-bottom-{{ ai_gen_id }}"></div>
  {% endif %}
</div>

<script>
(function() {
  const section = document.querySelector('.ai-stats-section-{{ ai_gen_id }}');
  if (!section) return;

  const numbers = section.querySelectorAll('.ai-stats-number-{{ ai_gen_id }}[data-target]');
  let hasAnimated = false;

  function parseNumber(str) {
    // Extract numeric value, handling percentages, decimals, and suffixes
    const match = str.match(/[\d,.]+/);
    return match ? parseFloat(match[0].replace(/,/g, '')) : 0;
  }

  function formatNumber(num, original) {
    // Preserve original formatting
    const hasDecimal = original.includes('.');
    const hasComma = original.includes(',');
    
    let formatted = hasDecimal ? num.toFixed(1) : Math.round(num).toString();
    
    if (hasComma && num >= 1000) {
      formatted = formatted.replace(/\B(?=(\d{3})+(?!\d))/g, ',');
    }
    
    return formatted;
  }

  function animateNumber(element) {
    const target = element.dataset.target;
    const numericTarget = parseNumber(target);
    const duration = 2000; // 2 seconds
    const frameDuration = 1000 / 60; // 60fps
    const totalFrames = Math.round(duration / frameDuration);
    let frame = 0;

    // Get prefix and suffix (like % or +)
    const prefix = target.match(/^[^\d]*/)[0];
    const suffix = target.match(/[^\d]*$/)[0];

    const counter = setInterval(() => {
      frame++;
      const progress = frame / totalFrames;
      const easeOutQuart = 1 - Math.pow(1 - progress, 4);
      const current = numericTarget * easeOutQuart;

      element.textContent = prefix + formatNumber(current, target) + suffix;

      if (frame === totalFrames) {
        clearInterval(counter);
        element.textContent = target; // Ensure final value is exact
        element.classList.add('counting');
      }
    }, frameDuration);
  }

  function handleIntersection(entries, observer) {
    entries.forEach(entry => {
      if (entry.isIntersecting && !hasAnimated) {
        hasAnimated = true;
        numbers.forEach((number) => {
          animateNumber(number);
        });
        observer.unobserve(entry.target);
      }
    });
  }

  const observer = new IntersectionObserver(handleIntersection, {
    threshold: 0.3,
    rootMargin: '0px'
  });

  observer.observe(section);
})();
</script>

