{% render 'cc-deps' %}
{% comment %}
  CC-PRODUCTPAGE-EVENING-CAPSULES: Product page for Evening Capsules (standalone)
  No subscription plans, single variant, one-time purchase only.
  Layout: theme.liquid (deps loaded via cc-deps snippet)
{% endcomment %}

{%- comment -%} === NOSCRIPT FALLBACK === {%- endcomment -%}
<noscript>
  <style>
    .cc-productpage-ec .reveal,
    .cc-productpage-ec .reveal-stagger > * {
      opacity: 1 !important;
      transform: none !important;
    }
  </style>
</noscript>

{%- comment -%} === ASSIGN HERO VARIABLES === {%- endcomment -%}
{%- assign hero_title = section.settings.hero_title | default: "Coastline PM Capsules" -%}
{%- assign hero_review_text = section.settings.hero_review_text | default: "2,000+ reviews" -%}
{%- assign hero_trust_badges = section.settings.hero_trust_badges | default: "VEGAN, SUGAR-FREE, CAFFEINE-FREE" -%}
{%- if section.settings.hero_gallery_image_1 != blank -%}
  {%- assign ec_hero_img = section.settings.hero_gallery_image_1 | image_url: width: 800 -%}
{%- else -%}
  {%- assign ec_hero_img = "cc-bedside-evening.png" | asset_url -%}
{%- endif -%}

<div class="cc-productpage-ec">

  {%- comment -%} ============================================================
     SECTION 1: PRODUCT HERO (60/40 grid)
  ============================================================ {%- endcomment -%}
  <section id="cc-ec-product-hero" class="section-editorial" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; background-color: var(--parchment);">
    <div style="max-width: 1200px; margin: 0 auto; padding: 0 24px;">

      <div class="cc-ec-hero-grid">

        <!-- LEFT SIDE: Product Image (60%) -->
        <div class="reveal" style="position: relative;">
          <div style="overflow: hidden;">
            <img
              src="{{ ec_hero_img }}"
              alt="{{ hero_title | escape }}"
              width="800"
              height="800"
              style="width: 100%; height: auto; display: block; object-fit: cover; max-height: 600px; object-position: center 70%;"
              class="img-editorial"
            >
          </div>
        </div>

        <!-- RIGHT SIDE: Buy Panel (40%) -- SIMPLIFIED, no flavor/subscription -->
        <div
          x-data="ccECBuy()"
          class="reveal"
          style="padding-top: 8px;"
        >
          <!-- Product Title -->
          <h1 style="font-size: clamp(28px, 4vw, 40px); margin: 0 0 16px;">
            {{ hero_title }}
          </h1>

          <!-- Stars + Review Count -->
          <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 20px;">
            <span class="stars-minimal">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
            <span style="font-family: 'Inter', sans-serif; font-size: 14px; color: var(--warm-gray);">{{ hero_review_text }}</span>
          </div>

          <!-- Trust Badges -->
          <p style="margin: 0 0 24px 0; font-family: 'Inter', system-ui, sans-serif; font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--warm-gray); line-height: 1.4;">
            {%- assign badge_list = hero_trust_badges | split: ',' -%}
            {%- for badge in badge_list -%}{{ badge | strip }}{%- unless forloop.last %} &middot; {% endunless -%}{%- endfor -%}
          </p>

          <!-- Editorial Divider -->
          <div class="editorial-divider" style="margin-bottom: 28px;"></div>

          <!-- Product Description -->
          <p style="font-family: 'Inter', sans-serif; font-size: 15px; color: var(--warm-gray); line-height: 1.6; margin: 0 0 24px;">
            {{ section.settings.hero_description | default: "3 targeted compounds timed for your body's overnight repair cycle. Take 2 capsules before bed to support deep sleep, calm the nervous system, and maintain joint health." }}
          </p>

          <!-- Supply Info -->
          <p style="font-family: 'Inter', sans-serif; font-size: 14px; color: var(--warm-gray); margin: 0 0 24px; line-height: 1.6;">30-day supply. Fully dosed.</p>

          <!-- Subscription Selector -->
          <div style="margin-bottom: 28px;">
            <p style="font-family:'Inter',sans-serif;font-size:11px;letter-spacing:0.15em;text-transform:uppercase;color:#6B6B6B;font-weight:500;margin-bottom:14px;">Select your plan</p>

            <!-- Monthly -->
            <div @click="plan = 'monthly'" :class="plan === 'monthly' ? 'cc-plan-ec-active' : 'cc-plan-ec-idle'" class="cc-plan-ec-card" style="margin-bottom:10px;">
              <div style="display:flex;align-items:center;justify-content:space-between;padding:20px;">
                <div>
                  <span style="display:block;font-family:'Space Grotesk',sans-serif;font-weight:500;color:#0A0A0A;font-size:15px;line-height:1.3;">Monthly subscription</span>
                  <span style="display:block;font-family:'Inter',sans-serif;font-size:12px;color:#1A3A2F;font-weight:500;margin-top:3px;">Save 20%</span>
                </div>
                <div style="text-align:right;flex-shrink:0;margin-left:16px;">
                  <span style="display:block;font-family:'Space Grotesk',sans-serif;font-weight:600;color:#0A0A0A;font-size:24px;line-height:1;">$24</span>
                  <span style="display:block;font-family:'Inter',sans-serif;font-size:12px;color:#6B6B6B;margin-top:2px;">/month</span>
                </div>
              </div>
            </div>

            <!-- 2-Month -->
            <div @click="plan = 'bimonthly'" :class="plan === 'bimonthly' ? 'cc-plan-ec-active' : 'cc-plan-ec-idle'" class="cc-plan-ec-card" style="margin-bottom:10px;">
              <div style="display:flex;align-items:center;justify-content:space-between;padding:20px;">
                <div>
                  <span style="display:block;font-family:'Space Grotesk',sans-serif;font-weight:500;color:#0A0A0A;font-size:15px;line-height:1.3;">Every 2 months</span>
                  <span style="display:block;font-family:'Inter',sans-serif;font-size:12px;color:#1A3A2F;font-weight:500;margin-top:3px;">Save 10%</span>
                </div>
                <div style="text-align:right;flex-shrink:0;margin-left:16px;">
                  <span style="display:block;font-family:'Space Grotesk',sans-serif;font-weight:600;color:#0A0A0A;font-size:24px;line-height:1;">$27</span>
                  <span style="display:block;font-family:'Inter',sans-serif;font-size:12px;color:#6B6B6B;margin-top:2px;">/month</span>
                </div>
              </div>
            </div>

            <!-- One-time -->
            <div @click="plan = 'onetime'" :class="plan === 'onetime' ? 'cc-plan-ec-active' : 'cc-plan-ec-idle'" class="cc-plan-ec-card">
              <div style="display:flex;align-items:center;justify-content:space-between;padding:20px;">
                <div>
                  <span style="display:block;font-family:'Space Grotesk',sans-serif;font-weight:500;color:#0A0A0A;font-size:15px;line-height:1.3;">One-time purchase</span>
                  <span style="display:block;font-family:'Inter',sans-serif;font-size:12px;color:#6B6B6B;margin-top:3px;">No subscription</span>
                </div>
                <div style="text-align:right;flex-shrink:0;margin-left:16px;">
                  <span style="display:block;font-family:'Space Grotesk',sans-serif;font-weight:600;color:#0A0A0A;font-size:24px;line-height:1;">$30</span>
                  <span style="display:block;font-family:'Inter',sans-serif;font-size:12px;color:#6B6B6B;margin-top:2px;">one-time</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Add to Cart Form -->
          <form id="cc-pdp-ec-cart-form" action="/cart/add" method="post" is="product-form" data-type="add-to-cart-form">
            <input type="hidden" name="id" :value="variantId" />
            <template x-if="sellingPlanId">
              <input type="hidden" name="selling_plan" :value="sellingPlanId" />
            </template>
            <button
              type="submit"
              :disabled="loading"
              class="btn-primary"
              style="width:100%;padding:22px 48px;font-size:14px;margin-bottom:20px;background:#0A0A0A !important;color:#FAF9F6 !important;border:none !important;font-family:'Space Grotesk',sans-serif;font-weight:500;letter-spacing:0.18em;text-transform:uppercase;cursor:pointer;transition:opacity 0.3s ease;"
            >
              <span class="btn-text"><span x-show="!loading">ADD TO CART - <span x-text="buttonPrice"></span></span>
              <span x-show="loading">ADDING...</span></span>
            </button>
          </form>

          <!-- Micro-copy -->
          <div style="display: flex; justify-content: center; gap: 24px; flex-wrap: wrap;">
            <span style="font-family: 'Inter', sans-serif; font-size: 12px; color: var(--warm-gray); display: flex; align-items: center; gap: 6px;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              Free shipping
            </span>
            <span style="font-family: 'Inter', sans-serif; font-size: 12px; color: var(--warm-gray); display: flex; align-items: center; gap: 6px;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              60-day guarantee
            </span>
          </div>

          <!-- Trust badge images -->
          <div style="display:flex;justify-content:center;align-items:center;gap:20px;margin-top:24px;">
            <img src="https://cdn.shopify.com/s/files/1/0619/6861/3445/files/istockphoto-1279030031-612x612_1.png?v=1767983702" alt="Third-party tested" style="height:48px;object-fit:contain;opacity:0.7;" loading="lazy">
            <img src="{{ 'cc-nsf-certified.png' | asset_url }}" alt="NSF Certified" style="height:48px;object-fit:contain;opacity:0.7;" loading="lazy">
            <img src="https://cdn.shopify.com/s/files/1/0619/6861/3445/files/download_1.png?v=1767983648" alt="GMP Certified" style="height:48px;object-fit:contain;opacity:0.7;" loading="lazy">
            <img src="https://cdn.shopify.com/s/files/1/0619/6861/3445/files/60-days-money-back-guarantee-icon-for-graphic-design-logo-website-social-media-mobile-app-ui-illustration-vector_1.png?v=1767983637" alt="60-Day Guarantee" style="height:48px;object-fit:contain;opacity:0.7;" loading="lazy">
          </div>

        </div>

      </div>

    </div>
  </section>

  {%- comment -%} === SECTION 2: PRESS LOGO BAR + DIVIDER IMAGE === {%- endcomment -%}
  <section class="reveal" x-intersect.once="$el.classList.add('visible')" style="padding:40px 1.5rem;background:var(--parchment);border-bottom:1px solid var(--light-gray);">
    <div style="max-width:64rem;margin:0 auto;text-align:center;">
      <p style="font-family:'Inter',system-ui,sans-serif;font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:var(--warm-gray);font-weight:500;margin:0 0 24px;">
        {{ section.settings.press_label | default: "AS FEATURED IN" }}
      </p>
      <div class="cc-ec-press-logos" style="display:flex;flex-wrap:wrap;justify-content:center;align-items:center;gap:32px;opacity:0.4;filter:grayscale(100%);">
        {%- assign pp_logo_defaults = 'https://cdn.shopify.com/s/files/1/0619/6861/3445/files/CL-PARTNERSHIP_LOGOS-1.png?v=1769181223,https://cdn.shopify.com/s/files/1/0619/6861/3445/files/CL-PARTNERSHIP_LOGOS-2.png?v=1769181172,https://cdn.shopify.com/s/files/1/0619/6861/3445/files/CL-PARTNERSHIP_LOGOS-3.png?v=1769181068,https://cdn.shopify.com/s/files/1/0619/6861/3445/files/CL-PARTNERSHIP_LOGOS-4.png?v=1769181109' | split: ',' -%}
        {%- assign pp_logo_alts = 'Uncrate,Vice,Daily Beast,Us Weekly' | split: ',' -%}
        {%- for i in (0..3) -%}
          {%- assign logo_src = pp_logo_defaults[i] -%}
          {%- if logo_src != blank -%}
            <img src="{{ logo_src }}" alt="{{ pp_logo_alts[i] }}" class="cc-ec-press-logo" style="height:52px;width:auto;" loading="lazy">
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>

  <div class="reveal" x-intersect.once="$el.classList.add('visible')" style="margin:0;padding:0;position:relative;overflow:hidden;">
    {%- if section.settings.divider_image_1 != blank -%}
      <img src="{{ section.settings.divider_image_1 | image_url: width: 1600 }}" alt="Coastline" style="width:100%;max-height:50vh;object-fit:cover;display:block;" loading="lazy">
    {%- else -%}
      <img src="{{ 'cc-night-beach-bioluminescent.jpg' | asset_url }}" alt="Coastline" style="width:100%;max-height:50vh;object-fit:cover;display:block;" loading="lazy">
    {%- endif -%}
  </div>

  {%- comment -%} ============================================================
     SECTION 3: KEY BENEFITS
  ============================================================ {%- endcomment -%}
  <section class="section-editorial reveal" style="padding-top:80px;padding-bottom:80px;background:var(--parchment);">
    <div style="max-width:800px;margin:0 auto;padding:0 1.5rem;">

      <div style="text-align:center;margin-bottom:48px;">
        <p style="font-family:'Inter',sans-serif;font-size:11px;letter-spacing:0.15em;text-transform:uppercase;color:var(--warm-gray);font-weight:500;margin-bottom:20px;">WHY PM CAPSULES</p>
        <h2 style="font-family:'Space Grotesk',sans-serif;font-size:clamp(28px,5vw,42px);font-weight:500;color:var(--deep-ink);letter-spacing:-0.02em;line-height:1.2;margin:0;">3 ingredients that support better sleep and overnight recovery</h2>
      </div>

      <div x-data="{ openBenefit: null }">

        <div style="border-bottom:1px solid var(--light-gray);padding:20px 0;cursor:pointer;" @click="openBenefit === 'sleep' ? openBenefit = null : openBenefit = 'sleep'">
          <div style="display:flex;justify-content:space-between;align-items:center;">
            <p style="font-family:'Space Grotesk',sans-serif;font-weight:500;font-size:18px;color:var(--deep-ink);margin:0;">Deeper sleep</p>
            <span style="font-size:1.25rem;color:var(--warm-gray);transition:transform 0.3s ease;" :style="openBenefit === 'sleep' ? 'transform:rotate(45deg)' : ''">+</span>
          </div>
          <p style="font-family:'Inter',sans-serif;font-size:15px;color:var(--warm-gray);line-height:1.6;margin:8px 0 0;">L-Theanine promotes relaxation and natural sleep onset without drowsiness or grogginess.</p>
          <div x-show="openBenefit === 'sleep'" x-collapse x-cloak>
            <p style="font-family:'Inter',sans-serif;font-size:14px;color:var(--warm-gray);line-height:1.7;margin:12px 0 0;opacity:0.85;">200mg L-Theanine increases alpha brain wave activity, promoting a calm-but-alert state that transitions naturally into restful sleep. Unlike sedatives, it supports your natural sleep architecture without morning grogginess.</p>
          </div>
        </div>

        <div style="border-bottom:1px solid var(--light-gray);padding:20px 0;cursor:pointer;" @click="openBenefit === 'calm' ? openBenefit = null : openBenefit = 'calm'">
          <div style="display:flex;justify-content:space-between;align-items:center;">
            <p style="font-family:'Space Grotesk',sans-serif;font-weight:500;font-size:18px;color:var(--deep-ink);margin:0;">Calmer evenings</p>
            <span style="font-size:1.25rem;color:var(--warm-gray);transition:transform 0.3s ease;" :style="openBenefit === 'calm' ? 'transform:rotate(45deg)' : ''">+</span>
          </div>
          <p style="font-family:'Inter',sans-serif;font-size:15px;color:var(--warm-gray);line-height:1.6;margin:8px 0 0;">Trace-dose lithium orotate supports mood stability and reduces racing thoughts before bed.</p>
          <div x-show="openBenefit === 'calm'" x-collapse x-cloak>
            <p style="font-family:'Inter',sans-serif;font-size:14px;color:var(--warm-gray);line-height:1.7;margin:12px 0 0;opacity:0.85;">At 400mcg, lithium orotate is a trace dose -- roughly 1/100th of prescription levels. Population studies show regions with naturally higher lithium in tap water have lower rates of mood disorders and neurodegenerative disease.</p>
          </div>
        </div>

        <div style="border-bottom:1px solid var(--light-gray);padding:20px 0;cursor:pointer;" @click="openBenefit === 'joints' ? openBenefit = null : openBenefit = 'joints'">
          <div style="display:flex;justify-content:space-between;align-items:center;">
            <p style="font-family:'Space Grotesk',sans-serif;font-weight:500;font-size:18px;color:var(--deep-ink);margin:0;">Joint recovery</p>
            <span style="font-size:1.25rem;color:var(--warm-gray);transition:transform 0.3s ease;" :style="openBenefit === 'joints' ? 'transform:rotate(45deg)' : ''">+</span>
          </div>
          <p style="font-family:'Inter',sans-serif;font-size:15px;color:var(--warm-gray);line-height:1.6;margin:8px 0 0;">The PM dose of glucosamine sulfate supports overnight joint repair and reduces morning stiffness.</p>
          <div x-show="openBenefit === 'joints'" x-collapse x-cloak>
            <p style="font-family:'Inter',sans-serif;font-size:14px;color:var(--warm-gray);line-height:1.7;margin:12px 0 0;opacity:0.85;">750mg glucosamine sulfate completes the 1,500mg daily clinical dose (split AM/PM for steady levels). Overnight, the body prioritizes repair -- glucosamine supports cartilage regeneration and reduces inflammatory markers in joint tissue.</p>
          </div>
        </div>

        <div style="border-bottom:1px solid var(--light-gray);padding:20px 0;cursor:pointer;" @click="openBenefit === 'neuro' ? openBenefit = null : openBenefit = 'neuro'">
          <div style="display:flex;justify-content:space-between;align-items:center;">
            <p style="font-family:'Space Grotesk',sans-serif;font-weight:500;font-size:18px;color:var(--deep-ink);margin:0;">Neuroprotection</p>
            <span style="font-size:1.25rem;color:var(--warm-gray);transition:transform 0.3s ease;" :style="openBenefit === 'neuro' ? 'transform:rotate(45deg)' : ''">+</span>
          </div>
          <p style="font-family:'Inter',sans-serif;font-size:15px;color:var(--warm-gray);line-height:1.6;margin:8px 0 0;">Lithium orotate increases BDNF and supports brain autophagy at safe, trace-level doses.</p>
          <div x-show="openBenefit === 'neuro'" x-collapse x-cloak>
            <p style="font-family:'Inter',sans-serif;font-size:14px;color:var(--warm-gray);line-height:1.7;margin:12px 0 0;opacity:0.85;">Trace lithium upregulates BDNF (brain-derived neurotrophic factor), promotes neuronal autophagy, and inhibits GSK-3 beta -- a key enzyme linked to neurodegeneration. These neuroprotective effects occur at doses far below therapeutic psychiatric use.</p>
          </div>
        </div>

      </div>

    </div>
  </section>

  {%- comment -%} ============================================================
     HOW TO TAKE
  ============================================================ {%- endcomment -%}
  <section class="section-editorial" style="padding-top:80px;padding-bottom:80px;background:var(--parchment);">
    <div style="max-width:1100px;margin:0 auto;padding:0 1.5rem;">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;" class="cc-ec-how-grid">
        <div style="overflow:hidden;">
          <img src="https://cdn.shopify.com/s/files/1/0619/6861/3445/files/CL-Landing_Page_Images-15_1.png" alt="Restful sleep" style="width:100%;height:auto;display:block;object-fit:cover;max-height:500px;" loading="lazy">
        </div>
        <div>
          <p style="font-family:'Inter',sans-serif;font-size:11px;letter-spacing:0.15em;text-transform:uppercase;color:var(--warm-gray);font-weight:500;margin-bottom:20px;">HOW TO TAKE</p>
          <h2 style="font-family:'Space Grotesk',sans-serif;font-size:clamp(28px,4vw,38px);font-weight:500;color:var(--deep-ink);letter-spacing:-0.02em;line-height:1.2;margin:0 0 24px;">Two capsules. Before bed. That simple.</h2>
          <div style="display:flex;flex-direction:column;gap:16px;">
            <div style="display:flex;align-items:flex-start;gap:12px;">
              <span style="font-family:'Space Grotesk',sans-serif;font-weight:500;font-size:14px;color:var(--forest);min-width:24px;">01</span>
              <p style="font-family:'Inter',sans-serif;font-size:16px;color:var(--deep-ink);line-height:1.6;margin:0;">Take 2 capsules 30-60 minutes before bed</p>
            </div>
            <div style="display:flex;align-items:flex-start;gap:12px;">
              <span style="font-family:'Space Grotesk',sans-serif;font-weight:500;font-size:14px;color:var(--forest);min-width:24px;">02</span>
              <p style="font-family:'Inter',sans-serif;font-size:16px;color:var(--deep-ink);line-height:1.6;margin:0;">Take with a glass of water</p>
            </div>
            <div style="display:flex;align-items:flex-start;gap:12px;">
              <span style="font-family:'Space Grotesk',sans-serif;font-weight:500;font-size:14px;color:var(--forest);min-width:24px;">03</span>
              <p style="font-family:'Inter',sans-serif;font-size:16px;color:var(--deep-ink);line-height:1.6;margin:0;">Completes the PM half of the Coastline system</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} ============================================================
     SECTION 5: INGREDIENT DEEP DIVE (3 evening capsule ingredients only)
  ============================================================ {%- endcomment -%}
  {%- assign ingredients_label = section.settings.ingredients_label | default: "THE INGREDIENTS" -%}
  {%- assign ingredients_headline = section.settings.ingredients_headline | default: "Every ingredient, every dose, every reason" -%}
  {%- assign ingredients_subheadline = section.settings.ingredients_subheadline | default: "3 clinically validated ingredients. Transparently dosed. Chosen for a reason." -%}

  <section class="section-editorial" style="padding-top: 80px; padding-bottom: 80px; background-color: var(--parchment); padding-left: 1.5rem; padding-right: 1.5rem;">
    <div style="max-width: 800px; margin: 0 auto;">

      <div class="reveal" style="margin-bottom: 48px;">
        <img src="https://cdn.shopify.com/s/files/1/0619/6861/3445/files/PM_Capsule_Wide_1_2.png?v=1764266766" alt="Evening Capsules" style="width:100%;max-height:500px;object-fit:cover;object-position:center 23%;display:block;" loading="lazy">
      </div>

      <div class="reveal" style="margin-bottom: 64px;">
        <p class="badge-minimal" style="margin-bottom: 20px;">{{ ingredients_label }}</p>
        <div class="editorial-divider" style="margin-bottom: 32px;"></div>
        <h2 style="margin-bottom: 24px; font-size: clamp(32px, 5vw, 48px); letter-spacing: -0.02em; line-height: 1.15;">{{ ingredients_headline }}</h2>
        <p style="color: var(--warm-gray); font-family: 'Inter', system-ui, sans-serif; font-size: 17px; line-height: 1.7; max-width: 600px;">
          {{ ingredients_subheadline }}
        </p>
      </div>

      <div x-data="{ open: null }" class="reveal" style="margin-bottom: 64px;">

        <p class="badge-minimal" style="margin-bottom: 24px; color: var(--forest);">EVENING CAPSULES</p>

        <!-- Lithium Orotate -->
        <div class="hairline"></div>
        <div style="padding:20px 0;cursor:pointer;" @click="open === 'lithium' ? open = null : open = 'lithium'">
          <div style="display:flex;justify-content:space-between;align-items:center;">
            <div style="display:flex;align-items:center;gap:12px;">
