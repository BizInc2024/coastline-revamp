{% render 'cc-deps' %}
{% comment %}
  CC-PRODUCTPAGE-SOFTGELS: Product page for Coastline Daily Softgels
  Variant ID: 42607325446213
  Selling Plans: Monthly 1580007493 ($28/mo), 2-Month 1927282757 ($31.50/mo), One-time $35
  Layout: theme.liquid (deps loaded via cc-deps snippet)
{% endcomment %}

<style>
    :root {
      --parchment: #FAF9F6;
      --deep-ink: #0A0A0A;
      --warm-gray: #6B6B6B;
      --light-gray: #E8E8E8;
      --forest: #1A3A2F;
      --forest-light: #2D5A47;
    }

    .cc-productpage-sg p,
    .cc-product p {
      max-width: none !important;
    }

    .cc-productpage-sg h1, .cc-productpage-sg h2, .cc-productpage-sg h3,
    .cc-product h1, .cc-product h2, .cc-product h3 {
      font-family: 'Space Grotesk', system-ui, sans-serif !important;
      color: var(--deep-ink) !important;
      font-weight: 500 !important;
    }

    .cc-productpage-sg h1, .cc-product h1 {
      font-size: clamp(32px, 6vw, 64px) !important;
      letter-spacing: -0.03em !important;
      line-height: 1.1 !important;
    }

    .cc-productpage-sg h2, .cc-product h2 {
      font-size: clamp(28px, 5vw, 48px) !important;
      letter-spacing: -0.02em !important;
      line-height: 1.15 !important;
    }

    .cc-productpage-sg h3, .cc-product h3 {
      font-size: clamp(20px, 3vw, 24px) !important;
      letter-spacing: -0.01em !important;
      line-height: 1.3 !important;
    }

    .cc-productpage-sg p, .cc-productpage-sg li,
    .cc-product p, .cc-product li {
      font-family: 'Inter', system-ui, sans-serif !important;
      color: var(--warm-gray) !important;
      font-size: 17px !important;
      line-height: 1.7 !important;
    }

    .cc-productpage-sg .badge-minimal,
    .cc-product .badge-minimal {
      font-size: 11px !important;
      letter-spacing: 0.15em !important;
      text-transform: uppercase !important;
      color: var(--warm-gray) !important;
      font-family: 'Inter', system-ui, sans-serif !important;
      font-weight: 400 !important;
    }

    .cc-productpage-sg .editorial-divider,
    .cc-product .editorial-divider {
      width: 60px;
      height: 1px;
      background: var(--deep-ink);
    }

    .cc-productpage-sg .hairline,
    .cc-product .hairline {
      height: 1px;
      background-color: var(--light-gray);
    }

    .cc-productpage-sg .btn-primary,
    .cc-product .btn-primary {
      display: inline-block !important;
      background-color: var(--deep-ink) !important;
      color: var(--parchment) !important;
      font-family: 'Space Grotesk', sans-serif !important;
      font-weight: 500 !important;
      font-size: 12px !important;
      letter-spacing: 0.18em !important;
      text-transform: uppercase !important;
      padding: 20px 48px !important;
      border: none !important;
      border-radius: 0 !important;
      cursor: pointer !important;
      transition: opacity 0.3s ease !important;
      text-decoration: none !important;
      text-align: center !important;
      line-height: 1 !important;
    }

    .cc-productpage-sg .btn-primary:hover,
    .cc-product .btn-primary:hover {
      opacity: 0.8 !important;
    }

    .cc-productpage-sg .btn-secondary,
    .cc-product .btn-secondary {
      display: inline-block !important;
      background-color: transparent !important;
      color: var(--deep-ink) !important;
      border: 1px solid var(--deep-ink) !important;
      font-family: 'Space Grotesk', sans-serif !important;
      font-weight: 500 !important;
      font-size: 12px !important;
      letter-spacing: 0.18em !important;
      text-transform: uppercase !important;
      padding: 20px 48px !important;
      border-radius: 0 !important;
      cursor: pointer !important;
      transition: background-color 0.3s ease, color 0.3s ease !important;
      text-decoration: none !important;
      text-align: center !important;
      line-height: 1 !important;
    }

    .cc-productpage-sg .btn-secondary:hover,
    .cc-product .btn-secondary:hover {
      background-color: var(--deep-ink) !important;
      color: var(--parchment) !important;
    }

    .cc-productpage-sg .btn-primary-dark,
    .cc-product .btn-primary-dark {
      display: inline-block !important;
      background: var(--parchment) !important;
      color: var(--deep-ink) !important;
      font-family: 'Space Grotesk', sans-serif !important;
      font-weight: 500 !important;
      font-size: 12px !important;
      letter-spacing: 0.18em !important;
      text-transform: uppercase !important;
      padding: 20px 48px !important;
      border: none !important;
      border-radius: 0 !important;
      cursor: pointer !important;
      transition: opacity 0.3s ease !important;
      text-decoration: none !important;
      text-align: center !important;
      line-height: 1 !important;
    }

    .cc-productpage-sg .btn-primary-dark:hover,
    .cc-product .btn-primary-dark:hover {
      opacity: 0.8 !important;
    }

    .cc-productpage-sg .link-underline,
    .cc-product .link-underline {
      position: relative !important;
      font-size: 13px !important;
      letter-spacing: 0.1em !important;
      text-transform: uppercase !important;
      text-decoration: none !important;
      color: var(--deep-ink) !important;
      font-family: 'Space Grotesk', sans-serif !important;
    }

    .cc-productpage-sg .link-underline::after,
    .cc-product .link-underline::after {
      content: '' !important;
      position: absolute !important;
      bottom: -2px !important;
      left: 0 !important;
      width: 100% !important;
      height: 1px !important;
      background-color: currentColor !important;
      transition: transform 0.3s ease !important;
    }

    .cc-productpage-sg .link-underline:hover::after,
    .cc-product .link-underline:hover::after {
      transform: scaleX(0) !important;
    }

    .cc-productpage-sg .quote-editorial,
    .cc-product .quote-editorial {
      font-family: 'Space Grotesk', sans-serif !important;
      font-weight: 400 !important;
      line-height: 1.4 !important;
      letter-spacing: -0.01em !important;
      color: var(--deep-ink) !important;
    }

    .cc-productpage-sg .stars-minimal,
    .cc-product .stars-minimal {
      letter-spacing: 4px !important;
      color: var(--deep-ink) !important;
      font-size: 14px !important;
    }

    .cc-productpage-sg .img-editorial,
    .cc-product .img-editorial {
      filter: contrast(1.05) brightness(0.98) !important;
    }

    .cc-productpage-sg .section-editorial,
    .cc-product .section-editorial {
      padding: 80px 16px;
    }

    @media (min-width: 768px) {
      .cc-productpage-sg .section-editorial,
      .cc-product .section-editorial {
        padding: 120px 32px;
      }
    }

    @media (min-width: 1024px) {
      .cc-productpage-sg .section-editorial,
      .cc-product .section-editorial {
        padding: 160px 64px;
      }
    }

    .cc-productpage-sg .reveal,
    .cc-product .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.8s ease, transform 0.8s ease;
    }

    .cc-productpage-sg .reveal.visible,
    .cc-product .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .cc-productpage-sg .reveal-stagger > *,
    .cc-product .reveal-stagger > * {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }

    .cc-productpage-sg .reveal-stagger.visible > *:nth-child(1),
    .cc-product .reveal-stagger.visible > *:nth-child(1) { transition-delay: 0s; opacity: 1; transform: translateY(0); }
    .cc-productpage-sg .reveal-stagger.visible > *:nth-child(2),
    .cc-product .reveal-stagger.visible > *:nth-child(2) { transition-delay: 0.1s; opacity: 1; transform: translateY(0); }
    .cc-productpage-sg .reveal-stagger.visible > *:nth-child(3),
    .cc-product .reveal-stagger.visible > *:nth-child(3) { transition-delay: 0.15s; opacity: 1; transform: translateY(0); }
    .cc-productpage-sg .reveal-stagger.visible > *:nth-child(4),
    .cc-product .reveal-stagger.visible > *:nth-child(4) { transition-delay: 0.2s; opacity: 1; transform: translateY(0); }
    .cc-productpage-sg .reveal-stagger.visible > *:nth-child(5),
    .cc-product .reveal-stagger.visible > *:nth-child(5) { transition-delay: 0.25s; opacity: 1; transform: translateY(0); }
    .cc-productpage-sg .reveal-stagger.visible > *:nth-child(6),
    .cc-product .reveal-stagger.visible > *:nth-child(6) { transition-delay: 0.3s; opacity: 1; transform: translateY(0); }

    @media (prefers-reduced-motion: reduce) {
      .cc-productpage-sg .reveal,
      .cc-product .reveal {
        opacity: 1;
        transform: none;
      }
      .cc-productpage-sg .reveal-stagger > *,
      .cc-product .reveal-stagger > * {
        opacity: 1;
        transform: none;
      }
    }

    .cc-productpage-sg .filter-tab,
    .cc-product .filter-tab {
      padding: 8px 16px;
      font-size: 12px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--warm-gray);
      border-bottom: 2px solid transparent;
      transition: color 0.2s ease, border-color 0.2s ease;
      cursor: pointer;
      background: none;
      border-top: none;
      border-left: none;
      border-right: none;
      font-family: 'Space Grotesk', sans-serif;
    }

    .cc-productpage-sg .filter-tab.active,
    .cc-product .filter-tab.active {
      color: var(--deep-ink);
      border-bottom-color: var(--deep-ink);
    }

    .cc-productpage-sg .accordion-content,
    .cc-product .accordion-content {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .cc-productpage-sg .accordion-content.open,
    .cc-product .accordion-content.open {
      max-height: 1000px;
    }

    .cc-productpage-sg .section-counter,
    .cc-product .section-counter {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--warm-gray);
    }
</style>

{%- comment -%} === NOSCRIPT FALLBACK === {%- endcomment -%}
<noscript>
  <style>
    .cc-productpage-sg .reveal,
    .cc-productpage-sg .reveal-stagger > * {
      opacity: 1 !important;
      transform: none !important;
    }
  </style>
</noscript>

{%- comment -%} === ASSIGN HERO VARIABLES === {%- endcomment -%}
{%- assign hero_title = section.settings.hero_title | default: "Coastline AM SoftGels" -%}
{%- assign hero_review_text = section.settings.hero_review_text | default: "2,000+ reviews" -%}
{%- assign hero_trust_badges = section.settings.hero_trust_badges | default: "VEGAN, SUGAR-FREE, CAFFEINE-FREE" -%}
{%- if section.settings.hero_gallery_image_1 != blank -%}
  {%- assign sg_hero_img = section.settings.hero_gallery_image_1 | image_url: width: 800 -%}
{%- else -%}
  {%- assign sg_hero_img = "https://cdn.shopify.com/s/files/1/0619/6861/3445/files/SOFTGELBOTTLEW_CAPSULE.jpg?v=1764011188" -%}
{%- endif -%}

<div class="cc-productpage-sg">

  {%- comment -%} ============================================================
     SECTION 1: PRODUCT HERO (60/40 grid)
  ============================================================ {%- endcomment -%}
  <section id="cc-sg-product-hero" class="section-editorial" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; background-color: var(--parchment);">
    <div style="max-width: 1200px; margin: 0 auto; padding: 0 24px;">

      <div class="cc-sg-hero-grid">

        <!-- LEFT SIDE: Product Image (60%) -->
        <div class="reveal" style="position: relative;">
          <div style="background: #fff; border: 1px solid var(--light-gray); overflow: hidden;">
            <img
              src="{{ sg_hero_img }}"
              alt="{{ hero_title | escape }}"
              width="800"
              height="800"
              style="width: 100%; height: auto; display: block; object-fit: contain; max-height: 600px;"
              class="img-editorial"
            >
          </div>
        </div>

        <!-- RIGHT SIDE: Buy Panel (40%) -->
        <div
          x-data="ccSGBuy()"
          class="reveal"
          style="padding-top: 8px;"
        >
          <!-- Product Title -->
          <h1 style="font-size: clamp(28px, 4vw, 40px); margin: 0 0 16px;">
            {{ hero_title }}
          </h1>

          <!-- Stars + Review Count -->
          <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 20px;">
            <span class="stars-minimal">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
            <span style="font-family: 'Inter', sans-serif; font-size: 14px; color: var(--warm-gray);">{{ hero_review_text }}</span>
          </div>

          <!-- Trust Badges -->
          <p style="margin: 0 0 24px 0; font-family: 'Inter', system-ui, sans-serif; font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--warm-gray); line-height: 1.4;">
            {%- assign badge_list = hero_trust_badges | split: ',' -%}
            {%- for badge in badge_list -%}{{ badge | strip }}{%- unless forloop.last %} &middot; {% endunless -%}{%- endfor -%}
          </p>

          <!-- Editorial Divider -->
          <div class="editorial-divider" style="margin-bottom: 28px;"></div>

          <!-- Product Description -->
          <div style="margin-bottom: 28px;">
            <p style="font-family: 'Inter', sans-serif; font-size: 15px; line-height: 1.7; color: var(--warm-gray); margin: 0 0 12px;">
              {{ section.settings.hero_description | default: "4 fat-soluble ingredients for cellular protection, eye health, and mitochondrial energy. Take 1 softgel with your first meal." }}
            </p>
            <p style="font-family: 'Inter', sans-serif; font-size: 13px; color: var(--forest); font-weight: 500; margin: 0;">
              Astaxanthin 6 mg &middot; Lutein 10 mg &middot; Zeaxanthin 2 mg &middot; CoQ10 200 mg
            </p>
          </div>

          <!-- Subscription Selector -->
          <div style="margin-bottom: 28px;">
            <p style="font-family:'Inter',sans-serif;font-size:13px;letter-spacing:0.08em;text-transform:uppercase;color:#1A3A2F;font-weight:600;margin:0 0 16px;">
              Subscribe and save
            </p>
            <p style="font-family:'Inter',sans-serif;font-size:11px;letter-spacing:0.15em;text-transform:uppercase;color:#6B6B6B;font-weight:500;margin-bottom:14px;">Select your plan</p>

            <!-- Monthly -->
            <div @click="plan = 'monthly'" :class="plan === 'monthly' ? 'cc-plan-sg-active' : 'cc-plan-sg-idle'" class="cc-plan-sg-card" style="margin-bottom:10px;">
              <div style="display:flex;align-items:center;justify-content:space-between;padding:20px;">
                <div>
                  <span style="display:block;font-family:'Space Grotesk',sans-serif;font-weight:500;color:#0A0A0A;font-size:15px;line-height:1.3;">Monthly subscription</span>
                  <span style="display:block;font-family:'Inter',sans-serif;font-size:12px;color:#1A3A2F;font-weight:500;margin-top:3px;">Save 20%</span>
                </div>
                <div style="text-align:right;flex-shrink:0;margin-left:16px;">
                  <span style="display:block;font-family:'Space Grotesk',sans-serif;font-weight:600;color:#0A0A0A;font-size:24px;line-height:1;">$28</span>
                  <span style="display:block;font-family:'Inter',sans-serif;font-size:12px;color:#6B6B6B;margin-top:2px;">/month</span>
                </div>
              </div>
            </div>

            <!-- 2-Month -->
            <div @click="plan = 'bimonthly'" :class="plan === 'bimonthly' ? 'cc-plan-sg-active' : 'cc-plan-sg-idle'" class="cc-plan-sg-card" style="margin-bottom:10px;">
              <div style="display:flex;align-items:center;justify-content:space-between;padding:20px;">
                <div>
                  <span style="display:block;font-family:'Space Grotesk',sans-serif;font-weight:500;color:#0A0A0A;font-size:15px;line-height:1.3;">Every 2 months</span>
                  <span style="display:block;font-family:'Inter',sans-serif;font-size:12px;color:#1A3A2F;font-weight:500;margin-top:3px;">Save 10%</span>
                </div>
                <div style="text-align:right;flex-shrink:0;margin-left:16px;">
                  <span style="display:block;font-family:'Space Grotesk',sans-serif;font-weight:600;color:#0A0A0A;font-size:24px;line-height:1;">$31.50</span>
                  <span style="display:block;font-family:'Inter',sans-serif;font-size:12px;color:#6B6B6B;margin-top:2px;">/month</span>
                </div>
              </div>
            </div>

            <!-- One-time -->
            <div @click="plan = 'onetime'" :class="plan === 'onetime' ? 'cc-plan-sg-active' : 'cc-plan-sg-idle'" class="cc-plan-sg-card">
              <div style="display:flex;align-items:center;justify-content:space-between;padding:20px;">
                <div>
                  <span style="display:block;font-family:'Space Grotesk',sans-serif;font-weight:500;color:#0A0A0A;font-size:15px;line-height:1.3;">One-time purchase</span>
                  <span style="display:block;font-family:'Inter',sans-serif;font-size:12px;color:#6B6B6B;margin-top:3px;">No subscription</span>
                </div>
                <div style="text-align:right;flex-shrink:0;margin-left:16px;">
                  <span style="display:block;font-family:'Space Grotesk',sans-serif;font-weight:600;color:#0A0A0A;font-size:24px;line-height:1;">$35</span>
                  <span style="display:block;font-family:'Inter',sans-serif;font-size:12px;color:#6B6B6B;margin-top:2px;">one-time</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Add to Cart Form -->
          <form id="cc-pdp-sg-cart-form" action="/cart/add" method="post" is="product-form" data-type="add-to-cart-form">
            <input type="hidden" name="id" :value="variantId" />
            <template x-if="sellingPlanId">
              <input type="hidden" name="selling_plan" :value="sellingPlanId" />
            </template>
            <button
              type="submit"
              :disabled="loading"
              class="btn-primary"
              style="width:100%;padding:22px 48px;font-size:14px;margin-bottom:20px;background:#0A0A0A !important;color:#FAF9F6 !important;border:none !important;font-family:'Space Grotesk',sans-serif;font-weight:500;letter-spacing:0.18em;text-transform:uppercase;cursor:pointer;transition:opacity 0.3s ease;"
            >
              <span class="btn-text"><span x-show="!loading">ADD TO CART - <span x-text="buttonPrice"></span></span>
              <span x-show="loading">ADDING...</span></span>
            </button>
          </form>

          <!-- Micro-copy -->
          <div style="display: flex; justify-content: center; gap: 24px; flex-wrap: wrap;">
            <span style="font-family: 'Inter', sans-serif; font-size: 12px; color: var(--warm-gray); display: flex; align-items: center; gap: 6px;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              Free shipping
            </span>
            <span style="font-family: 'Inter', sans-serif; font-size: 12px; color: var(--warm-gray); display: flex; align-items: center; gap: 6px;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              60-day guarantee
            </span>
          </div>

          <!-- Trust badge images -->
          <div style="display:flex;justify-content:center;align-items:center;gap:20px;margin-top:24px;">
            <img src="https://cdn.shopify.com/s/files/1/0619/6861/3445/files/istockphoto-1279030031-612x612_1.png?v=1767983702" alt="Third-party tested" style="height:48px;object-fit:contain;opacity:0.7;" loading="lazy">
            <img src="{{ 'cc-nsf-certified.png' | asset_url }}" alt="NSF Certified" style="height:48px;object-fit:contain;opacity:0.7;" loading="lazy">
            <img src="https://cdn.shopify.com/s/files/1/0619/6861/3445/files/download_1.png?v=1767983648" alt="GMP Certified" style="height:48px;object-fit:contain;opacity:0.7;" loading="lazy">
            <img src="https://cdn.shopify.com/s/files/1/0619/6861/3445/files/60-days-money-back-guarantee-icon-for-graphic-design-logo-website-social-media-mobile-app-ui-illustration-vector_1.png?v=1767983637" alt="60-Day Guarantee" style="height:48px;object-fit:contain;opacity:0.7;" loading="lazy">
          </div>

        </div>

      </div>

    </div>
  </section>

  {%- comment -%} === PRESS LOGO BAR + DIVIDER IMAGE === {%- endcomment -%}
  <section class="reveal" x-intersect.once="$el.classList.add('visible')" style="padding:40px 1.5rem;background:var(--parchment);border-bottom:1px solid var(--light-gray);">
    <div style="max-width:64rem;margin:0 auto;text-align:center;">
      <p style="font-family:'Inter',system-ui,sans-serif;font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:var(--warm-gray);font-weight:500;margin:0 0 24px;">
        {{ section.settings.press_label | default: "AS FEATURED IN" }}
      </p>
      <div class="cc-sg-press-logos" style="display:flex;flex-wrap:wrap;justify-content:center;align-items:center;gap:32px;opacity:0.4;filter:grayscale(100%);">
        {%- assign sg_logo_defaults = 'https://cdn.shopify.com/s/files/1/0619/6861/3445/files/CL-PARTNERSHIP_LOGOS-1.png?v=1769181223,https://cdn.shopify.com/s/files/1/0619/6861/3445/files/CL-PARTNERSHIP_LOGOS-2.png?v=1769181172,https://cdn.shopify.com/s/files/1/0619/6861/3445/files/CL-PARTNERSHIP_LOGOS-3.png?v=1769181068,https://cdn.shopify.com/s/files/1/0619/6861/3445/files/CL-PARTNERSHIP_LOGOS-4.png?v=1769181109' | split: ',' -%}
        {%- assign sg_logo_alts = 'Uncrate,Vice,Daily Beast,Us Weekly' | split: ',' -%}
        {%- for i in (0..3) -%}
          {%- assign logo_src = sg_logo_defaults[i] -%}
          {%- if logo_src != blank -%}
            <img src="{{ logo_src }}" alt="{{ sg_logo_alts[i] }}" class="cc-sg-press-logo" style="height:52px;width:auto;" loading="lazy">
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>

  <div class="reveal" x-intersect.once="$el.classList.add('visible')" style="margin:0;padding:0;position:relative;overflow:hidden;">
    {%- if section.settings.divider_image_1 != blank -%}
