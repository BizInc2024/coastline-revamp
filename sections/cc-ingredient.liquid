{%- comment -%} === STUDY REFERENCES ACCORDION JS === {%- endcomment -%}
<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Scroll reveals
    var reveals = document.querySelectorAll('.cci .reveal');
    if (reveals.length) {
      var obs = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) {
          if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
        });
      }, { threshold: 0.15 });
      reveals.forEach(function(el) { obs.observe(el); });
    }

    // Study references: parse page.content h2s into accordions
    var source = document.getElementById('cci-body-source');
    var container = document.getElementById('cci-study-accordions');
    if (!source || !container) return;

    var tempDiv = document.createElement('div');
    tempDiv.innerHTML = source.innerHTML;

    var sections = [];
    var currentSection = null;

    Array.from(tempDiv.childNodes).forEach(function(node) {
      if (node.nodeType === 1 && node.tagName === 'H2') {
        if (currentSection) sections.push(currentSection);
        currentSection = { title: node.textContent.trim(), content: '' };
      } else if (node.nodeType === 1 && node.tagName === 'H1') {
        // Skip page title
      } else if (currentSection && node.nodeType === 1) {
        currentSection.content += node.outerHTML;
      } else if (currentSection && node.nodeType === 3 && node.textContent.trim()) {
        currentSection.content += node.textContent;
      }
    });
    if (currentSection) sections.push(currentSection);
    if (!sections.length) return;

    sections.forEach(function(sec, idx) {
      var wrapper = document.createElement('div');
      wrapper.style.borderTop = '1px solid #E8E8E8';
      if (idx === sections.length - 1) wrapper.style.borderBottom = '1px solid #E8E8E8';

      var btn = document.createElement('button');
      btn.className = 'cci-study-btn';
      btn.innerHTML = '<span>' + sec.title + '</span>' +
        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>';

      var contentDiv = document.createElement('div');
      contentDiv.className = 'cci-study-content';
      contentDiv.innerHTML = '<div class="cci-study-inner">' + sec.content + '</div>';

      btn.addEventListener('click', function() {
        var isOpen = contentDiv.classList.contains('open');
        container.querySelectorAll('.cci-study-content.open').forEach(function(el) {
          el.classList.remove('open');
          el.previousElementSibling.querySelector('svg').style.transform = '';
        });
        if (!isOpen) {
          contentDiv.classList.add('open');
          btn.querySelector('svg').style.transform = 'rotate(45deg)';
        }
      });

      wrapper.appendChild(btn);
      wrapper.appendChild(contentDiv);
      container.appendChild(wrapper);
    });

    // Open links in new tab
    container.querySelectorAll('a').forEach(function(a) {
      a.setAttribute('target', '_blank');
    });
  });
</script>

