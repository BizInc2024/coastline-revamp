{% comment %}
  Multi-Column Icons for Mobile
  
  To use this section:
  1. In your Shopify admin, go to Online Store > Themes
  2. Click "Actions" > "Edit code"
  3. Under "Sections", click "Add a new section"
  4. Name it "multicolumn-icons-for-mobile" and paste this code
  5. Save and add to your page using the theme editor
{% endcomment %}

<style>
  .features-section-{{ section.id }} {
    width: 100%;
    padding: 1.5rem 0;
    background-color: {{ section.settings.background_color }};
  }
  
  .features-container-{{ section.id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 0.5rem;
  }
  
  @media (min-width: 768px) {
    .features-section-{{ section.id }} {
      padding: 3rem 0;
    }
    .features-container-{{ section.id }} {
      padding: 0 1rem;
    }
  }
  
  .features-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }
  
  @media (min-width: 768px) {
    .features-grid-{{ section.id }} {
      gap: 1.5rem;
    }
  }
  
  .feature-item-{{ section.id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0.75rem;
    background-color: {{ section.settings.card_background }};
    border-radius: 0.5rem;
    transition: all 0.3s ease;
  }
  
  @media (min-width: 768px) {
    .feature-item-{{ section.id }} {
      padding: 1.5rem;
    }
  }
  
  .feature-icon-{{ section.id }} {
    margin-bottom: 0.5rem;
    color: {{ section.settings.icon_color }};
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
  }
  
  @media (min-width: 768px) {
    .feature-icon-{{ section.id }} {
      margin-bottom: 1rem;
    }
  }
  
  .feature-icon-{{ section.id }} svg {
    width: 100%;
    height: 100%;
    stroke-width: 1.5;
  }
  
  .feature-title-{{ section.id }} {
    font-weight: 600;
    color: {{ section.settings.title_color }};
    font-size: {{ section.settings.title_size }}px;
    margin: 0;
    line-height: 1.3;
  }
  
  .feature-description-{{ section.id }} {
    color: {{ section.settings.description_color }};
    font-size: {{ section.settings.description_size }}px;
    margin-top: 0.5rem;
    line-height: 1.4;
  }
</style>

<section class="features-section-{{ section.id }}">
  <div class="features-container-{{ section.id }}">
    <div class="features-grid-{{ section.id }}">
      {% for block in section.blocks %}
        <div class="feature-item-{{ section.id }}" {{ block.shopify_attributes }}>
          <div class="feature-icon-{{ section.id }}">
            {% case block.settings.icon %}
              {% when 'star' %}
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
                </svg>
              {% when 'sparkles' %}
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
                </svg>
              {% when 'shield' %}
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
                </svg>
              {% when 'trophy' %}
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M7.73 9.728a6.726 6.726 0 002.748 1.35m8.272-6.842V4.5c0 2.108-.966 3.99-2.48 5.228m2.48-5.492a46.32 46.32 0 012.916.52 6.003 6.003 0 01-5.395 4.972m0 0a6.726 6.726 0 01-2.749 1.35m0 0a6.772 6.772 0 01-3.044 0" />
                </svg>
              {% when 'eye' %}
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              {% when 'award' %}
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M7.73 9.728a6.726 6.726 0 002.748 1.35m8.272-6.842V4.5c0 2.108-.966 3.99-2.48 5.228m2.48-5.492a46.32 46.32 0 012.916.52 6.003 6.003 0 01-5.395 4.972m0 0a6.726 6.726 0 01-2.749 1.35m0 0a6.772 6.772 0 01-3.044 0" />
                </svg>
            {% endcase %}
          </div>
          
          <h3 class="feature-title-{{ section.id }}">{{ block.settings.title }}</h3>
          
          {% if block.settings.description != blank %}
            <p class="feature-description-{{ section.id }}">{{ block.settings.description }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "multi-icon-mobile",
  "tag": "section",
  "class": "section-multicolumn-icons",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#f8fafb"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card Background",
      "default": "#ffffff80"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Color",
      "default": "#003d4d"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#003d4d"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description Color",
      "default": "#006580"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon Size",
      "min": 16,
      "max": 64,
      "step": 2,
      "default": 28,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title Font Size",
      "min": 10,
      "max": 24,
      "step": 1,
      "default": 14,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "Description Font Size",
      "min": 10,
      "max": 20,
      "step": 1,
      "default": 12,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "star", "label": "Star" },
            { "value": "sparkles", "label": "Sparkles" },
            { "value": "shield", "label": "Shield Check" },
            { "value": "trophy", "label": "Trophy" },
            { "value": "eye", "label": "Eye" },
            { "value": "award", "label": "Award" }
          ],
          "default": "star"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature Title"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description (optional)",
          "default": "Feature description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "multi-icon-mobile",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "star",
            "title": "Clinically proven"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "sparkles",
            "title": "Optimal Doses"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "shield",
            "title": "GMP Certified"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "trophy",
            "title": "Third-Party Tested"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "eye",
            "title": "Transparent Labeling"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "award",
            "title": "Rigorously Curated"
          }
        }
      ]
    }
  ]
}
{% endschema %}