      <img src="https://cdn.shopify.com/s/files/1/0619/6861/3445/files/The_Washington_Post_White.png?v=1738115154" alt="The Washington Post">
      <img src="https://cdn.shopify.com/s/files/1/0619/6861/3445/files/kindpng_2532766.png?v=1738115288" alt="TIME">
      <img src="https://cdn.shopify.com/s/files/1/0619/6861/3445/files/reuters-6-logo-black-and-white.png?v=1738115081" alt="Reuters">
    </div>
  </div>

