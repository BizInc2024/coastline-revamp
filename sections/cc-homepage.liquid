{% render 'cc-deps' %}
{% comment %}
  CC-HOMEPAGE: Monolithic homepage section
  Contains all 13 homepage sections inline, following the v4/v5 landing page pattern.
  Layout: theme.liquid (deps loaded via cc-deps snippet)
{% endcomment %}

<script>
    tailwind.config = {
        theme: {
            extend: {
                colors: {
                    'parchment': '#FAF9F6',
                    'deep-ink': '#0A0A0A',
                    'warm-gray': '#6B6B6B',
                    'light-gray': '#E8E8E8',
                    'forest': '#1A3A2F',
                    'forest-light': '#2D5A47',
                    'ocean': '#062F3D',
                    'brand-navy': '#1E2D4D',
                },
                fontFamily: {
                    'grotesk': ['Space Grotesk', 'system-ui', 'sans-serif'],
                    'inter': ['Inter', 'system-ui', 'sans-serif'],
                }
            }
        }
    }
</script>

<style>
    /* ================================================
       COASTLINE DESIGN SYSTEM OVERRIDES
       Scoped to .cc-home and .cc-product to avoid
       breaking theme header/footer styles
       ================================================ */

    :root {
      --parchment: #FAF9F6;
      --deep-ink: #0A0A0A;
      --warm-gray: #6B6B6B;
      --light-gray: #E8E8E8;
      --forest: #1A3A2F;
      --forest-light: #2D5A47;
    }

    /* Override theme.css p max-width inside our sections */
    .cc-home p,
    .cc-product p {
      max-width: none !important;
    }

    /* Typography overrides */
    .cc-home h1, .cc-home h2, .cc-home h3,
    .cc-product h1, .cc-product h2, .cc-product h3 {
      font-family: 'Space Grotesk', system-ui, sans-serif !important;
      color: var(--deep-ink) !important;
      font-weight: 500 !important;
    }

    .cc-home h1, .cc-product h1 {
      font-size: clamp(32px, 6vw, 64px) !important;
      letter-spacing: -0.03em !important;
      line-height: 1.1 !important;
    }

    .cc-home h2, .cc-product h2 {
      font-size: clamp(28px, 5vw, 48px) !important;
      letter-spacing: -0.02em !important;
      line-height: 1.15 !important;
    }

    .cc-home h3, .cc-product h3 {
      font-size: clamp(20px, 3vw, 24px) !important;
      letter-spacing: -0.01em !important;
      line-height: 1.3 !important;
    }

    .cc-home p, .cc-home li,
    .cc-product p, .cc-product li {
      font-family: 'Inter', system-ui, sans-serif !important;
      color: var(--warm-gray) !important;
      font-size: 17px !important;
      line-height: 1.7 !important;
    }

    /* Badge / label */
    .cc-home .badge-minimal,
    .cc-product .badge-minimal {
      font-size: 11px !important;
      letter-spacing: 0.15em !important;
      text-transform: uppercase !important;
      color: var(--warm-gray) !important;
      font-family: 'Inter', system-ui, sans-serif !important;
      font-weight: 400 !important;
    }

    /* Editorial divider */
    .cc-home .editorial-divider,
    .cc-product .editorial-divider {
      width: 60px;
      height: 1px;
      background: var(--deep-ink);
    }

    /* Hairline */
    .cc-home .hairline,
    .cc-product .hairline {
      height: 1px;
      background-color: var(--light-gray);
    }

    /* Primary button */
    .cc-home .btn-primary,
    .cc-product .btn-primary {
      display: inline-block !important;
      background-color: var(--deep-ink) !important;
      color: var(--parchment) !important;
      font-family: 'Space Grotesk', sans-serif !important;
      font-weight: 500 !important;
      font-size: 12px !important;
      letter-spacing: 0.18em !important;
      text-transform: uppercase !important;
      padding: 20px 48px !important;
      border: none !important;
      border-radius: 0 !important;
      cursor: pointer !important;
      transition: opacity 0.3s ease !important;
      text-decoration: none !important;
      text-align: center !important;
      line-height: 1 !important;
    }

    .cc-home .btn-primary:hover,
    .cc-product .btn-primary:hover {
      opacity: 0.8 !important;
    }

    /* Secondary button */
    .cc-home .btn-secondary,
    .cc-product .btn-secondary {
      display: inline-block !important;
      background-color: transparent !important;
      color: var(--deep-ink) !important;
      border: 1px solid var(--deep-ink) !important;
      font-family: 'Space Grotesk', sans-serif !important;
      font-weight: 500 !important;
      font-size: 12px !important;
      letter-spacing: 0.18em !important;
      text-transform: uppercase !important;
      padding: 20px 48px !important;
      border-radius: 0 !important;
      cursor: pointer !important;
      transition: background-color 0.3s ease, color 0.3s ease !important;
      text-decoration: none !important;
      text-align: center !important;
      line-height: 1 !important;
    }

    .cc-home .btn-secondary:hover,
    .cc-product .btn-secondary:hover {
      background-color: var(--deep-ink) !important;
      color: var(--parchment) !important;
    }

    /* Primary button on dark */
    .cc-home .btn-primary-dark,
    .cc-product .btn-primary-dark {
      display: inline-block !important;
      background: var(--parchment) !important;
      color: var(--deep-ink) !important;
      font-family: 'Space Grotesk', sans-serif !important;
      font-weight: 500 !important;
      font-size: 12px !important;
      letter-spacing: 0.18em !important;
      text-transform: uppercase !important;
      padding: 20px 48px !important;
      border: none !important;
      border-radius: 0 !important;
      cursor: pointer !important;
      transition: opacity 0.3s ease !important;
      text-decoration: none !important;
      text-align: center !important;
      line-height: 1 !important;
    }

    .cc-home .btn-primary-dark:hover,
    .cc-product .btn-primary-dark:hover {
      opacity: 0.8 !important;
    }

    /* Link underline */
    .cc-home .link-underline,
    .cc-product .link-underline {
      position: relative !important;
      font-size: 13px !important;
      letter-spacing: 0.1em !important;
      text-transform: uppercase !important;
      text-decoration: none !important;
      color: var(--deep-ink) !important;
      font-family: 'Space Grotesk', sans-serif !important;
    }

    .cc-home .link-underline::after,
    .cc-product .link-underline::after {
      content: '' !important;
      position: absolute !important;
      bottom: -2px !important;
      left: 0 !important;
      width: 100% !important;
      height: 1px !important;
      background-color: currentColor !important;
      transition: transform 0.3s ease !important;
    }

    .cc-home .link-underline:hover::after,
    .cc-product .link-underline:hover::after {
      transform: scaleX(0) !important;
    }

    /* Quote editorial */
    .cc-home .quote-editorial,
    .cc-product .quote-editorial {
      font-family: 'Space Grotesk', sans-serif !important;
      font-weight: 400 !important;
      line-height: 1.4 !important;
      letter-spacing: -0.01em !important;
      color: var(--deep-ink) !important;
    }

    /* Stars */
    .cc-home .stars-minimal,
    .cc-product .stars-minimal {
      letter-spacing: 4px !important;
      color: var(--deep-ink) !important;
      font-size: 14px !important;
    }

    /* Editorial image filter */
    .cc-home .img-editorial,
    .cc-product .img-editorial {
      filter: contrast(1.05) brightness(0.98) !important;
    }

    /* Section editorial spacing */
    .cc-home .section-editorial,
    .cc-product .section-editorial {
      padding: 80px 16px;
    }

    @media (min-width: 768px) {
      .cc-home .section-editorial,
      .cc-product .section-editorial {
        padding: 120px 32px;
      }
    }

    @media (min-width: 1024px) {
      .cc-home .section-editorial,
      .cc-product .section-editorial {
        padding: 160px 64px;
      }
    }

    /* Scroll reveal */
    .cc-home .reveal,
    .cc-product .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.8s ease, transform 0.8s ease;
    }

    .cc-home .reveal.visible,
    .cc-product .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* Stagger children */
    .cc-home .reveal-stagger > *,
    .cc-product .reveal-stagger > * {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }

    .cc-home .reveal-stagger.visible > *:nth-child(1),
    .cc-product .reveal-stagger.visible > *:nth-child(1) { transition-delay: 0s; opacity: 1; transform: translateY(0); }
    .cc-home .reveal-stagger.visible > *:nth-child(2),
    .cc-product .reveal-stagger.visible > *:nth-child(2) { transition-delay: 0.1s; opacity: 1; transform: translateY(0); }
    .cc-home .reveal-stagger.visible > *:nth-child(3),
    .cc-product .reveal-stagger.visible > *:nth-child(3) { transition-delay: 0.15s; opacity: 1; transform: translateY(0); }
    .cc-home .reveal-stagger.visible > *:nth-child(4),
    .cc-product .reveal-stagger.visible > *:nth-child(4) { transition-delay: 0.2s; opacity: 1; transform: translateY(0); }
    .cc-home .reveal-stagger.visible > *:nth-child(5),
    .cc-product .reveal-stagger.visible > *:nth-child(5) { transition-delay: 0.25s; opacity: 1; transform: translateY(0); }
    .cc-home .reveal-stagger.visible > *:nth-child(6),
    .cc-product .reveal-stagger.visible > *:nth-child(6) { transition-delay: 0.3s; opacity: 1; transform: translateY(0); }

    /* Reduced motion */
    @media (prefers-reduced-motion: reduce) {
      .cc-home .reveal,
      .cc-product .reveal {
        opacity: 1;
        transform: none;
      }
      .cc-home .reveal-stagger > *,
      .cc-product .reveal-stagger > * {
        opacity: 1;
        transform: none;
      }
    }

    /* Filter tab */
    .cc-home .filter-tab,
    .cc-product .filter-tab {
      padding: 8px 16px;
      font-size: 12px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--warm-gray);
      border-bottom: 2px solid transparent;
      transition: color 0.2s ease, border-color 0.2s ease;
      cursor: pointer;
      background: none;
      border-top: none;
      border-left: none;
      border-right: none;
      font-family: 'Space Grotesk', sans-serif;
    }

    .cc-home .filter-tab.active,
    .cc-product .filter-tab.active {
      color: var(--deep-ink);
      border-bottom-color: var(--deep-ink);
    }

    /* Accordion */
    .cc-home .accordion-content,
    .cc-product .accordion-content {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .cc-home .accordion-content.open,
    .cc-product .accordion-content.open {
      max-height: 1000px;
    }

    /* Section counter */
    .cc-home .section-counter,
    .cc-product .section-counter {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--warm-gray);
    }
</style>

{%- comment -%} === NOSCRIPT FALLBACK === {%- endcomment -%}
<noscript>
  <style>
    .cc-homepage .reveal,
    .cc-homepage .reveal-stagger > * {
      opacity: 1 !important;
      transform: none !important;
    }
  </style>
</noscript>

{%- comment -%} === SVG ICON CAPTURES (Benefits section) === {%- endcomment -%}
{%- capture icon_energy -%}
<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
{%- endcapture -%}
{%- capture icon_focus -%}
<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/><line x1="12" y1="2" x2="12" y2="4"/><line x1="12" y1="20" x2="12" y2="22"/><line x1="2" y1="12" x2="4" y2="12"/><line x1="20" y1="12" x2="22" y2="12"/></svg>
{%- endcapture -%}
{%- capture icon_recovery -%}
<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6"/><path d="M2.5 22v-6h6"/><path d="M2.5 16a10 10 0 0 1 16.6-5.7L21.5 8"/><path d="M21.5 8a10 10 0 0 1-16.6 5.7L2.5 16"/></svg>
{%- endcapture -%}
{%- capture icon_sleep -%}
<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
{%- endcapture -%}

<div class="cc-homepage">

  {%- comment -%} ============================================================
     SECTION 1: HERO (cc-home-02)
  ============================================================ {%- endcomment -%}
  <section id="cc-home-hero" class="relative min-h-screen flex items-end md:items-center bg-deep-ink overflow-hidden">

    {%- comment -%} Desktop hero image {%- endcomment -%}
    {%- if section.settings.hero_image != blank -%}
      <img src="{{ section.settings.hero_image | image_url: width: 1920 }}" alt="Coastline hero" class="hidden md:block absolute inset-0 w-full h-full object-cover" loading="eager">
    {%- else -%}
      <img src="https://cdn.shopify.com/s/files/1/0619/6861/3445/files/CL-newhero-jan23.png?v=1769187732" alt="Coastline hero" class="hidden md:block absolute inset-0 w-full h-full object-cover" loading="eager">
    {%- endif -%}
    {%- comment -%} Mobile hero image {%- endcomment -%}
    {%- if section.settings.hero_image_mobile != blank -%}
      <img src="{{ section.settings.hero_image_mobile | image_url: width: 800 }}" alt="Coastline hero" class="block md:hidden absolute inset-0 w-full h-full object-cover cc-hero-mobile-img" loading="eager">
    {%- else -%}
      <img src="https://cdn.shopify.com/s/files/1/0619/6861/3445/files/cl-newhero-jan23-vert_07def72b-63dc-4597-8162-d117dcc483a7.png?v=1769187984" alt="Coastline hero" class="block md:hidden absolute inset-0 w-full h-full object-cover cc-hero-mobile-img" loading="eager">
    {%- endif -%}

    <div class="cc-hero-gradient absolute inset-0"></div>

    <div class="relative z-10 w-full px-6 lg:px-16 pb-12 md:pb-0">
      <div class="max-w-7xl mx-auto flex justify-center md:justify-start">
        <div class="cc-hero-content text-center md:text-left max-w-lg">
          <p class="font-inter text-[10px] md:text-xs tracking-[0.2em] uppercase font-medium mb-3 md:mb-5" style="color:#062F3D;">{{ section.settings.hero_label | default: "THE ULTIMATE LONGEVITY SYSTEM" }}</p>
          <div class="w-10 h-px bg-white/40 mb-5 md:mb-8 mx-auto md:mx-0"></div>
          <h1 class="cc-hero-headline text-white mb-3 md:mb-4">
            {{ section.settings.hero_headline | default: "Stay sharp, strong, and energized at every age" }}
          </h1>
          <p class="cc-hero-subheadline leading-relaxed mb-5 md:mb-6" style="color:#1E2D4D;">
            {{ section.settings.hero_subheadline | default: "13 science-backed ingredients. One simple system. From $3.30/day." }}
          </p>
          <a href="#cc-reviews-anchor" class="flex items-center gap-2 mb-5 md:mb-8 justify-center md:justify-start" style="cursor:pointer;text-decoration:none;">
            <span class="text-white text-sm tracking-widest">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
            <span class="font-inter text-[11px] text-white/60" style="text-decoration:underline;text-underline-offset:3px;">{{ section.settings.hero_reviews | default: "2,000+ five-star reviews" }}</span>
          </a>
          <div class="flex flex-col gap-3 items-center md:items-start">
            <a href="{{ section.settings.hero_cta_link | default: '#cc-home-pricing' }}" style="display:inline-block;background:#0A0A0A;color:#FAF9F6;font-family:'Space Grotesk',sans-serif;font-weight:500;font-size:12px;letter-spacing:0.18em;text-transform:uppercase;padding:20px 48px;border:none;text-decoration:none;text-align:center;min-width:200px;transition:opacity 0.3s ease;">
              {{ section.settings.hero_cta_text | default: "START MY LONGEVITY SYSTEM" }}
            </a>
            <a href="{{ section.settings.hero_secondary_link | default: '#cc-home-pricing' }}" style="font-size:13px;letter-spacing:0.1em;text-transform:uppercase;text-decoration:underline;text-underline-offset:4px;color:#062F3D;font-family:'Space Grotesk',sans-serif;padding:4px 0;transition:opacity 0.3s ease;">
              {{ section.settings.hero_secondary_text | default: "SKIP TO PRICING" }}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>


  {%- comment -%} ============================================================
     SECTION 2: PRESS LOGOS (cc-home-03)
  ============================================================ {%- endcomment -%}
  <section class="bg-parchment border-b border-light-gray reveal" style="padding-top:{{ section.settings.section2_padding_top | default: 48 }}px;padding-bottom:{{ section.settings.section2_padding_bottom | default: 48 }}px;" x-intersect.once="$el.classList.add('visible')">
    <div class="max-w-5xl mx-auto px-6 text-center">
      <p class="font-inter text-[10px] tracking-[0.2em] uppercase text-warm-gray font-medium mb-8">{{ section.settings.press_label | default: "AS FEATURED IN" }}</p>
      <div style="display:grid;grid-template-columns:repeat(2, 1fr);gap:24px;align-items:center;justify-items:center;opacity:0.4;filter:grayscale(100%);" class="md:!flex md:!flex-nowrap md:!justify-center md:!items-center md:!gap-16">
        {%- assign logo_defaults = 'https://cdn.shopify.com/s/files/1/0619/6861/3445/files/CL-PARTNERSHIP_LOGOS-1.png?v=1769181223,https://cdn.shopify.com/s/files/1/0619/6861/3445/files/CL-PARTNERSHIP_LOGOS-2.png?v=1769181172,https://cdn.shopify.com/s/files/1/0619/6861/3445/files/CL-PARTNERSHIP_LOGOS-3.png?v=1769181068,https://cdn.shopify.com/s/files/1/0619/6861/3445/files/CL-PARTNERSHIP_LOGOS-4.png?v=1769181109,,' | split: ',' -%}
        {%- assign logo_alts = 'Uncrate,Vice,Daily Beast,Us Weekly,Press logo 5,Press logo 6' | split: ',' -%}
        {%- for i in (1..6) -%}
          {%- assign logo_key = 'logo_' | append: i -%}
          {%- assign url_key = 'logo_' | append: i | append: '_url' -%}
          {%- assign height_key = 'logo_' | append: i | append: '_height' -%}
          {%- assign logo_img = section.settings[logo_key] -%}
          {%- assign logo_url = section.settings[url_key] | default: '#' -%}
          {%- assign logo_height = section.settings[height_key] | default: 40 -%}
          {%- assign default_index = i | minus: 1 -%}
          {%- assign fallback = logo_defaults[default_index] -%}
          {%- if logo_img != blank or fallback != blank -%}
            <a href="{{ logo_url }}" style="text-decoration:none;{% if logo_url == '#' %}pointer-events:none;{% endif %}">
              {%- if logo_img != blank -%}
                <img src="{{ logo_img | image_url: width: 320 }}" alt="{{ logo_alts[default_index] }}" style="height:{{ logo_height }}px;width:auto;" loading="lazy">
              {%- elsif fallback != blank -%}
                <img src="{{ fallback }}" alt="{{ logo_alts[default_index] }}" style="height:{{ logo_height }}px;width:auto;" loading="lazy">
              {%- endif -%}
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>


  {%- comment -%} SECTION 3: PROBLEM — REMOVED (content preserved in schema settings) {%- endcomment -%}

  {%- comment -%} ============================================================
     SECTION 4: SYSTEM / 3 STEPS (cc-home-05)
  ============================================================ {%- endcomment -%}
  <section class="bg-parchment reveal" style="padding-top:{{ section.settings.section4_padding_top | default: 80 }}px;padding-bottom:{{ section.settings.section4_padding_bottom | default: 80 }}px;" x-intersect.once="$el.classList.add('visible')">
    <div class="max-w-6xl mx-auto px-8 lg:px-16 text-center">
      {%- if section.settings.system_label != blank -%}
        <span class="badge-minimal font-inter text-xs font-semibold tracking-widest uppercase text-warm-gray inline-block mb-5">
          {{ section.settings.system_label }}
        </span>
      {%- endif -%}
      {%- if section.settings.system_headline != blank -%}
        <h2 class="font-grotesk font-medium text-deep-ink leading-tight mb-4" style="font-size: clamp(1.75rem, 4vw, 2.75rem);">
          {{ section.settings.system_headline }}
        </h2>
      {%- endif -%}
      <div class="editorial-divider hairline w-12 h-px bg-light-gray mx-auto mt-8 mb-12"></div>

      {%- assign step_blocks = section.blocks | where: "type", "step" -%}
      {%- if step_blocks.size > 0 -%}
        <div x-data="{ openStep: null }" class="grid md:grid-cols-3 gap-10 text-center">
          {%- assign step_counter = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'step' -%}
              {%- assign step_counter = step_counter | plus: 1 -%}
              <div {{ block.shopify_attributes }} class="flex flex-col items-center">
                <div class="border-t border-light-gray w-full pt-6 mb-5">
                  {%- if block.settings.image != blank -%}
                    <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.title | escape }}" loading="lazy" width="600" height="600" class="max-w-[280px] w-full h-auto mx-auto block">
                  {%- else -%}
                    <img src="{{ block.settings.fallback_image_url | default: 'https://cdn.shopify.com/s/files/1/0619/6861/3445/files/Creatine_Front2.png?v=1769024194' }}" alt="{{ block.settings.title | escape }}" loading="lazy" width="600" height="600" class="max-w-[280px] w-full h-auto mx-auto block">
                  {%- endif -%}
                </div>
                <span class="badge-minimal font-inter text-[0.65rem] font-semibold tracking-widest uppercase text-warm-gray inline-block mb-2">
                  STEP {{ step_counter }}
                </span>
                {%- if block.settings.title != blank -%}
                  <h3 class="font-grotesk text-xl font-medium text-deep-ink mb-2">
                    {{ block.settings.title }}
                  </h3>
                {%- endif -%}
                {%- if block.settings.description != blank -%}
                  <p class="font-inter text-[0.95rem] leading-relaxed text-warm-gray max-w-xs mx-auto">
                    {{ block.settings.description }}
                  </p>
                {%- endif -%}

                <!-- Expandable details toggle -->
                <button type="button" @click="openStep === {{ step_counter }} ? openStep = null : openStep = {{ step_counter }}" style="display:inline-flex !important;align-items:center !important;gap:6px !important;margin-top:28px !important;background:none !important;border:none !important;border-bottom:1px solid transparent !important;cursor:pointer !important;font-family:'Inter',sans-serif !important;font-size:13px !important;font-weight:400 !important;letter-spacing:0.02em !important;text-transform:none !important;color:var(--warm-gray) !important;transition:all 0.2s ease !important;padding:0 0 2px !important;line-height:1 !important;white-space:nowrap !important;" :style="openStep === {{ step_counter }} ? 'color:var(--deep-ink) !important;border-bottom-color:var(--deep-ink) !important' : ''">
                  <span style="font-size:13px !important;font-weight:400 !important;text-transform:none !important;letter-spacing:0.02em !important;" x-text="openStep === {{ step_counter }} ? 'Hide details' : 'View details'"></span>
                  <span :style="openStep === {{ step_counter }} ? 'transform:rotate(180deg)' : ''" style="font-size:10px !important;line-height:1 !important;display:inline-block !important;transition:transform 0.3s ease !important;vertical-align:middle !important;">&#9662;</span>
                </button>
                <div x-show="openStep === {{ step_counter }}" x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100" x-transition:leave="transition ease-in duration-150" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0" x-cloak style="text-align:left;width:100%;margin-top:12px;">
                  <div style="border-top:1px solid var(--light-gray);padding:20px 16px 16px;background:#FAFAF8;margin:0 -8px;">
                    {%- if block.settings.ingredients_text != blank -%}
                      <p style="font-family:'Inter',sans-serif;font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:var(--warm-gray);margin-bottom:10px;font-weight:600;">Ingredients</p>
                      <ul style="list-style:none;padding:0;margin:0 0 16px;">
                        {%- assign ing_lines = block.settings.ingredients_text | newline_to_br | split: "<br />" -%}
                        {%- for line in ing_lines -%}
                          {%- assign trimmed_line = line | strip -%}
                          {%- if trimmed_line != blank -%}
                            {%- assign parts = trimmed_line | split: "|" -%}
                            <li style="font-size:14px;color:var(--deep-ink);padding:4px 0;{%- unless forloop.last -%}border-bottom:1px solid #f0f0f0;{%- endunless -%}">{{ parts[0] | strip }} <span style="color:var(--warm-gray);float:right;">{{ parts[1] | strip }}</span></li>
                          {%- endif -%}
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}
                    {%- if block.settings.directions != blank -%}
                      <p style="font-family:'Inter',sans-serif;font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:var(--warm-gray);margin-bottom:6px;font-weight:600;">Directions</p>
                      <p style="font-size:14px;color:var(--deep-ink);line-height:1.6;margin-bottom:16px;">{{ block.settings.directions }}</p>
                    {%- endif -%}
                    {%- if block.settings.benefits_text != blank -%}
                      <p style="font-family:'Inter',sans-serif;font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:var(--warm-gray);margin-bottom:6px;font-weight:600;">Key benefits</p>
                      <ul style="list-style:none;padding:0;margin:0;">
                        {%- assign ben_lines = block.settings.benefits_text | newline_to_br | split: "<br />" -%}
                        {%- for line in ben_lines -%}
                          {%- assign trimmed_line = line | strip -%}
                          {%- if trimmed_line != blank -%}
                            <li style="font-size:14px;color:var(--deep-ink);padding:3px 0;">{{ trimmed_line }}</li>
                          {%- endif -%}
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}
                  </div>
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      <div class="mt-12" style="text-align:center;">
        <a href="{{ section.settings.system_cta_url | default: '#cc-home-pricing' }}" style="display:inline-block;background:var(--deep-ink);color:var(--parchment);font-family:'Space Grotesk',sans-serif;font-weight:500;font-size:12px;letter-spacing:0.18em;text-transform:uppercase;padding:20px 48px;text-decoration:none;transition:opacity 0.3s ease;">
          {{ section.settings.system_cta_text | default: "GET 34% OFF YOUR FIRST ORDER" }}
        </a>
      </div>
    </div>
  </section>


  <!-- Divider image between System and Benefits -->
  <div class="reveal" x-intersect.once="$el.classList.add('visible')" style="margin:0;padding:0;">
    {%- if section.settings.divider_problem_system != blank -%}
      <img src="{{ section.settings.divider_problem_system | image_url: width: 1600 }}" alt="Coastline" style="width:100%;max-height:50vh;object-fit:cover;display:block;" loading="lazy">
    {%- else -%}
      <img src="https://cdn.shopify.com/s/files/1/0619/6861/3445/files/canon-beach-haystack_1.png?v=1764011837" alt="Coastline" style="width:100%;max-height:50vh;object-fit:cover;display:block;" loading="lazy">
    {%- endif -%}
  </div>

  {%- comment -%} ============================================================
     SECTION 5: BENEFITS / 5 PILLARS (cc-home-07)
  ============================================================ {%- endcomment -%}
  <section class="bg-parchment" style="padding-top:{{ section.settings.section5_padding_top | default: 80 }}px;padding-bottom:{{ section.settings.section5_padding_bottom | default: 80 }}px;">
    <div class="max-w-7xl mx-auto px-8 lg:px-16">
      <div class="reveal text-center mb-14" x-intersect.once="$el.classList.add('visible')">
        <span class="badge-minimal font-inter text-xs font-semibold tracking-wider uppercase text-warm-gray inline-block mb-5">
          {{ section.settings.benefits_label | default: "THE BENEFITS" }}
        </span>
        <h2 class="font-grotesk font-medium text-deep-ink leading-tight" style="font-size: clamp(28px, 4vw, 44px);">
          {{ section.settings.benefits_headline | default: "What Coastline does for you" }}
        </h2>
      </div>
      <div class="reveal-stagger cc-benefits-grid" style="display:grid;grid-template-columns:1fr;gap:24px;" x-intersect.once="$el.classList.add('visible')">
        {%- for block in section.blocks -%}
          {%- if block.type == 'pillar' -%}
            <div {{ block.shopify_attributes }} class="cc-pillar-card" style="border-top:1px solid var(--light-gray);padding-top:24px;">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.title | escape }}" loading="lazy" class="cc-pillar-img" style="width:100%;object-fit:cover;margin-bottom:16px;">
              {%- elsif block.settings.fallback_image_url != blank -%}
                <img src="{{ block.settings.fallback_image_url }}" alt="{{ block.settings.title | escape }}" loading="lazy" class="cc-pillar-img" style="width:100%;object-fit:cover;margin-bottom:16px;">
              {%- else -%}
                <div class="text-forest mb-4">
                  {%- case block.settings.icon -%}
                    {%- when 'energy' -%}{{ icon_energy }}
                    {%- when 'focus' -%}{{ icon_focus }}
                    {%- when 'recovery' -%}{{ icon_recovery }}
                    {%- when 'sleep' -%}{{ icon_sleep }}
                    {%- when 'gut' -%}<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 12c0-2 1-3 2-3s2 1 2 3-1 3-2 3-2-1-2-3"/><path d="M14 10c1 0 2 1 2 2s-1 2-2 2"/></svg>
                    {%- when 'body' -%}<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 1 0 0 6 3 3 0 0 0 0-6z"/><path d="M12 8v4m-4 2l4-2 4 2m-8 0v4m8-4v4"/></svg>
                  {%- endcase -%}
                </div>
              {%- endif -%}
              <h3 style="font-family:'Space Grotesk',sans-serif;font-size:22px;font-weight:500;color:var(--deep-ink);margin-bottom:8px;line-height:1.3;">
                {{ block.settings.title }}
              </h3>
              <p style="font-family:'Inter',sans-serif;font-size:15px;color:var(--warm-gray);line-height:1.65;">
                {{ block.settings.description }}
              </p>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <!-- Benefits page CTA -->
      <div class="reveal" style="text-align:center;margin-top:48px;" x-intersect.once="$el.classList.add('visible')">
        <a href="{{ section.settings.benefits_link_url | default: '/pages/benefits' }}" style="display:inline-block;padding:16px 40px;font-family:'Space Grotesk',sans-serif;font-weight:500;font-size:12px;letter-spacing:0.18em;text-transform:uppercase;color:var(--deep-ink);border:1px solid var(--deep-ink);text-decoration:none;transition:all 0.3s ease;background:transparent;">
          {{ section.settings.benefits_link_text | default: "EXPLORE ALL THE BENEFITS" }}
        </a>
      </div>
    </div>
  </section>


  {%- comment -%} ============================================================
     SECTION 6: REVIEWS (cc-home-09)
  ============================================================ {%- endcomment -%}
  <section id="cc-reviews-anchor" class="bg-parchment" style="padding-top:{{ section.settings.section6_padding_top | default: 80 }}px;padding-bottom:{{ section.settings.section6_padding_bottom | default: 80 }}px;">
    <div class="max-w-7xl mx-auto px-8 lg:px-16">
      <p class="badge-minimal text-center mb-3 tracking-widest text-xs reveal" x-intersect.once="$el.classList.add('visible')">
        {{ section.settings.reviews_label | default: "WHAT MEMBERS ARE SAYING" }}
      </p>
      <h2 class="reveal text-center text-deep-ink mb-10 font-grotesk font-medium leading-tight" style="font-size:clamp(1.75rem,4vw,2.75rem);" x-intersect.once="$el.classList.add('visible')">
        {{ section.settings.reviews_headline | default: "2,000+ five-star reviews" }}
      </h2>

      {%- comment -%} Count reviews per category for Alpine {%- endcomment -%}
      {%- assign count_all = 0 -%}
      {%- assign count_energy = 0 -%}
      {%- assign count_focus = 0 -%}
      {%- assign count_trust = 0 -%}
      {%- assign count_convenience = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'testimonial' -%}
          {%- assign count_all = count_all | plus: 1 -%}
          {%- case block.settings.category -%}
            {%- when 'energy' -%}{%- assign count_energy = count_energy | plus: 1 -%}
            {%- when 'focus' -%}{%- assign count_focus = count_focus | plus: 1 -%}
            {%- when 'trust' -%}{%- assign count_trust = count_trust | plus: 1 -%}
            {%- when 'convenience' -%}{%- assign count_convenience = count_convenience | plus: 1 -%}
          {%- endcase -%}
        {%- endif -%}
      {%- endfor -%}

      <div x-data="{
        reviewFilter: 'all',
        shown: { all: 6, energy: 6, focus: 6, trust: 6, convenience: 6 },
        totals: { all: {{ count_all }}, energy: {{ count_energy }}, focus: {{ count_focus }}, trust: {{ count_trust }}, convenience: {{ count_convenience }} },
        counters: { all: 0, energy: 0, focus: 0, trust: 0, convenience: 0 },
        resetCounters() { this.counters = { all: 0, energy: 0, focus: 0, trust: 0, convenience: 0 }; }
      }">
        <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:8px;margin-bottom:40px;">
          {%- assign tab_cats = 'all,energy,focus,trust,convenience' | split: ',' -%}
          {%- assign tab_labels = 'ALL,ENERGY,FOCUS,TRUST,CONVENIENCE' | split: ',' -%}
          {%- for tab_cat in tab_cats -%}
            <button @click="reviewFilter = '{{ tab_cat }}'; resetCounters()" class="cc-review-tab" :class="reviewFilter === '{{ tab_cat }}' ? 'cc-review-tab-active' : 'cc-review-tab-idle'">{{ tab_labels[forloop.index0] }}</button>
          {%- endfor -%}
        </div>

        <div style="display:grid;gap:24px;" class="md:!grid-cols-2 lg:!grid-cols-3" x-ref="reviewGrid" x-effect="resetCounters()">
          {%- assign energy_idx = 0 -%}
          {%- assign focus_idx = 0 -%}
          {%- assign trust_idx = 0 -%}
          {%- assign convenience_idx = 0 -%}
          {%- assign all_idx = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'testimonial' -%}
              {%- assign cat = block.settings.category | default: 'energy' -%}
              {%- assign all_idx = all_idx | plus: 1 -%}
              {%- case cat -%}
                {%- when 'energy' -%}{%- assign energy_idx = energy_idx | plus: 1 -%}{%- assign cat_idx = energy_idx -%}
                {%- when 'focus' -%}{%- assign focus_idx = focus_idx | plus: 1 -%}{%- assign cat_idx = focus_idx -%}
                {%- when 'trust' -%}{%- assign trust_idx = trust_idx | plus: 1 -%}{%- assign cat_idx = trust_idx -%}
                {%- when 'convenience' -%}{%- assign convenience_idx = convenience_idx | plus: 1 -%}{%- assign cat_idx = convenience_idx -%}
              {%- endcase -%}
              <div {{ block.shopify_attributes }}
                x-show="(reviewFilter === 'all' && {{ all_idx }} <= shown.all) || (reviewFilter === '{{ cat }}' && {{ cat_idx }} <= shown['{{ cat }}'])"
                x-transition:enter="transition ease-out duration-300"
                x-transition:enter-start="opacity-0 transform translate-y-4"
                x-transition:enter-end="opacity-100 transform translate-y-0"
                style="border-top:1px solid var(--light-gray);padding-top:24px;"
              >
                <p style="letter-spacing:4px;color:var(--deep-ink);font-size:14px;margin-bottom:12px;">&#9733;&#9733;&#9733;&#9733;&#9733;</p>
                <p style="font-family:'Inter',sans-serif;font-size:16px;color:var(--deep-ink);line-height:1.65;margin-bottom:16px;">
                  "{{ block.settings.quote }}"
                </p>
                <p style="font-family:'Inter',sans-serif;font-size:12px;letter-spacing:0.12em;text-transform:uppercase;color:var(--warm-gray);">
                  {{ block.settings.name }}{% if block.settings.detail != blank %}, {{ block.settings.detail }}{% endif %}
                </p>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        <div style="text-align:center;margin-top:40px;display:flex;justify-content:center;gap:0.75rem;flex-wrap:wrap;">
          <button
            x-show="shown[reviewFilter] < totals[reviewFilter]"
            @click="shown[reviewFilter] += 6"
            style="padding:12px 32px;font-family:'Space Grotesk',sans-serif;font-size:12px;letter-spacing:0.12em;text-transform:uppercase;border-radius:100px;cursor:pointer;border:1px solid var(--light-gray);background:transparent;color:var(--warm-gray);transition:all 0.2s ease;"
            x-transition
          >SHOW MORE REVIEWS</button>
          <button
            x-show="shown[reviewFilter] > 6"
            @click="shown[reviewFilter] = 6; $nextTick(() => { document.getElementById('cc-reviews-anchor').scrollIntoView({ behavior: 'smooth' }) })"
            style="padding:12px 32px;font-family:'Space Grotesk',sans-serif;font-size:12px;letter-spacing:0.12em;text-transform:uppercase;border-radius:100px;cursor:pointer;border:1px solid var(--light-gray);background:transparent;color:var(--warm-gray);transition:all 0.2s ease;"
            x-transition
          >SHOW LESS</button>
        </div>
      </div>
    </div>
  </section>


  {%- comment -%} === DIVIDER IMAGE 1: Between Reviews & Ingredients === {%- endcomment -%}
  <div class="reveal" x-intersect.once="$el.classList.add('visible')">
    {%- if section.settings.divider_image_1 != blank -%}
      <img src="{{ section.settings.divider_image_1 | image_url: width: 1920 }}" alt="Coastline" style="width:100%;max-height:50vh;object-fit:cover;display:block;" loading="lazy">
    {%- else -%}
      <img src="https://cdn.shopify.com/s/files/1/0619/6861/3445/files/Hero_Coastline_Bottle_On_Coast_2_3.jpg?v=1769557785" alt="Coastline bottle on the coast" style="width:100%;max-height:50vh;object-fit:cover;display:block;" loading="lazy">
    {%- endif -%}
  </div>

  {%- comment -%} ============================================================
     SECTION 7: INGREDIENTS ACCORDION (cc-home-10)
  ============================================================ {%- endcomment -%}
  <section class="bg-parchment" style="padding-top:{{ section.settings.section7_padding_top | default: 80 }}px;padding-bottom:{{ section.settings.section7_padding_bottom | default: 80 }}px;">
    <div class="max-w-3xl mx-auto px-8 lg:px-16">

      <div class="reveal mb-16" x-intersect.once="$el.classList.add('visible')">
        <p class="badge-minimal mb-5">{{ section.settings.ingredients_label | default: "THE INGREDIENTS" }}</p>
        <div class="editorial-divider mb-8"></div>
        <h2 style="font-family:'Space Grotesk',sans-serif !important;font-weight:500 !important;color:var(--deep-ink) !important;line-height:1.15 !important;letter-spacing:-0.02em !important;font-size:clamp(1.75rem,4vw,2.75rem) !important;margin-bottom:24px;">{{ section.settings.ingredients_headline | default: "13 science-backed ingredients, zero filler" }}</h2>
        <p class="text-warm-gray font-inter text-[17px] leading-relaxed max-w-xl">
          {{ section.settings.ingredients_subheadline | default: "Every ingredient is clinically validated, transparently dosed, and chosen for a reason." }}
        </p>
      </div>

      <div x-data="{ open: null }" class="reveal mb-16" x-intersect.once="$el.classList.add('visible')">

        <!-- UNIFIED INGREDIENT LIST -->
        {%- capture badge_morning -%}<span style="display:inline-block;font-size:9px;letter-spacing:0.1em;text-transform:uppercase;color:var(--warm-gray);background:#F0EFEC;padding:2px 8px;margin-top:4px;">MORNING BLEND</span>{%- endcapture -%}
        {%- capture badge_softgel -%}<span style="display:inline-block;font-size:9px;letter-spacing:0.1em;text-transform:uppercase;color:var(--warm-gray);background:#F0EFEC;padding:2px 8px;margin-top:4px;">MORNING SOFTGELS</span>{%- endcapture -%}
        {%- capture badge_evening -%}<span style="display:inline-block;font-size:9px;letter-spacing:0.1em;text-transform:uppercase;color:var(--warm-gray);background:#F0EFEC;padding:2px 8px;margin-top:4px;">EVENING CAPSULES</span>{%- endcapture -%}
        {%- capture badge_split -%}<span style="display:inline-block;font-size:9px;letter-spacing:0.1em;text-transform:uppercase;color:var(--warm-gray);background:#F0EFEC;padding:2px 8px;margin-top:4px;">MORNING + EVENING</span>{%- endcapture -%}

        {%- capture chevron_svg -%}<svg width="16" height="16" class="flex-shrink-0 transition-transform duration-300" style="width:16px;height:16px;" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="8" y1="2" x2="8" y2="14"></line><line x1="2" y1="8" x2="14" y2="8"></line></svg>{%- endcapture -%}

        <!-- 1. Creatine Monohydrate -->
        <div class="hairline"></div>
        <div class="py-5 cursor-pointer" @click="open === 'creatine' ? open = null : open = 'creatine'">
          <div class="flex justify-between items-center">
            <div style="display:flex;align-items:center;gap:14px;">
              <img src="https://cdn.shopify.com/s/files/1/0619/6861/3445/files/CL-13IngredientImages-v1_2_a9a90961-637d-402f-856b-17493e2fe0d7.png?v=1767985945" alt="Creatine Monohydrate" style="width:48px;height:48px;object-fit:cover;border-radius:0;flex-shrink:0;" loading="lazy">
              <div>
                <div class="flex items-baseline gap-2">
                  <span class="font-grotesk font-medium text-deep-ink text-base">Creatine Monohydrate</span>
                  <span class="font-inter text-sm text-warm-gray">5.25 g</span>
                </div>
                {{ badge_morning }}
              </div>
            </div>
            <svg :style="open === 'creatine' ? 'transform: rotate(45deg)' : ''" width="16" height="16" class="flex-shrink-0 transition-transform duration-300" style="width:16px;height:16px;" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="8" y1="2" x2="8" y2="14"></line><line x1="2" y1="8" x2="14" y2="8"></line></svg>
          </div>
          <div x-show="open === 'creatine'" x-collapse x-cloak>
            <p class="text-warm-gray font-inter text-[15px] leading-relaxed mt-3 pr-8">
              Supports muscle strength, bone density, and cognitive function under stress. One of the most studied supplements with an excellent safety profile.
            </p>
          </div>
        </div>

        <!-- 2. Taurine -->
        <div class="hairline"></div>
        <div class="py-5 cursor-pointer" @click="open === 'taurine' ? open = null : open = 'taurine'">
          <div class="flex justify-between items-center">
            <div style="display:flex;align-items:center;gap:14px;">
              <img src="https://cdn.shopify.com/s/files/1/0619/6861/3445/files/CL-13IngredientImages-v1_16_2.png?v=1767986425" alt="Taurine" style="width:48px;height:48px;object-fit:cover;border-radius:0;flex-shrink:0;" loading="lazy">
              <div>
                <span class="font-grotesk font-medium text-deep-ink text-base">Taurine</span>
                <span class="font-inter text-sm text-warm-gray">3.05 g</span>
                 <br>{{ badge_morning }}
              </div>
            </div>
            <svg :style="open === 'taurine' ? 'transform: rotate(45deg)' : ''" width="16" height="16" class="flex-shrink-0 transition-transform duration-300" style="width:16px;height:16px;" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="8" y1="2" x2="8" y2="14"></line><line x1="2" y1="8" x2="14" y2="8"></line></svg>
          </div>
          <div x-show="open === 'taurine'" x-collapse x-cloak>
            <p class="text-warm-gray font-inter text-[15px] leading-relaxed mt-3 pr-8">
              Supports cardiovascular health, reduces blood pressure and inflammation, and improves metabolic markers including blood sugar and cholesterol.
            </p>
          </div>
        </div>

        <!-- 3. Glycine -->
        <div class="hairline"></div>
        <div class="py-5 cursor-pointer" @click="open === 'glycine' ? open = null : open = 'glycine'">
          <div class="flex justify-between items-center">
            <div style="display:flex;align-items:center;gap:14px;">
              <img src="https://cdn.shopify.com/s/files/1/0619/6861/3445/files/CL-13IngredientImages-v1_2_2.png?v=1767987227" alt="Glycine" style="width:48px;height:48px;object-fit:cover;border-radius:0;flex-shrink:0;" loading="lazy">
              <div>
                <div class="flex items-baseline gap-2">
                  <span class="font-grotesk font-medium text-deep-ink text-base">Glycine</span>
                  <span class="font-inter text-sm text-warm-gray">5 g</span>
                </div>
                {{ badge_morning }}
              </div>
            </div>
            <svg :style="open === 'glycine' ? 'transform: rotate(45deg)' : ''" width="16" height="16" class="flex-shrink-0 transition-transform duration-300" style="width:16px;height:16px;" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="8" y1="2" x2="8" y2="14"></line><line x1="2" y1="8" x2="14" y2="8"></line></svg>
          </div>
