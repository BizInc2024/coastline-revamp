      <div class="reveal-stagger cc-benefits-grid" style="display:grid;grid-template-columns:1fr;gap:24px;" x-intersect.once="$el.classList.add('visible')">
        {%- for block in section.blocks -%}
          {%- if block.type == 'pillar' -%}
