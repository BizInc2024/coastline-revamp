    {%- else -%}
      <img src="https://cdn.shopify.com/s/files/1/0619/6861/3445/files/WELCOME_OPEN_LIGHT_BLUE.jpg?v=1759112312" alt="Coastline Welcome Pack" class="cc-divider2-desktop" style="width:100%;max-height:60vh;object-fit:cover;display:none;" loading="lazy">
    {%- endif -%}
  </div>

  {%- comment -%} ============================================================
     SECTION 9: COMPARISON TABLE (cc-home-12)
  ============================================================ {%- endcomment -%}
  <section class="bg-parchment reveal" style="padding-top:{{ section.settings.section9_padding_top | default: 80 }}px;padding-bottom:{{ section.settings.section9_padding_bottom | default: 80 }}px;" x-intersect.once="$el.classList.add('visible')">
    <div class="max-w-6xl mx-auto px-8 lg:px-16 text-center">

      {%- if section.settings.comparison_label != blank -%}
        <span class="badge-minimal">{{ section.settings.comparison_label }}</span>
      {%- endif -%}
      {%- if section.settings.comparison_headline != blank -%}
        <h2 class="text-deep-ink max-w-2xl mx-auto mt-4 mb-12 leading-snug" style="font-size:clamp(1.6rem,3.2vw,2.4rem);">
          {{ section.settings.comparison_headline }}
        </h2>
      {%- endif -%}

      {%- comment -%} SVG icon captures for comparison table {%- endcomment -%}
      {%- capture svg_check -%}<svg width="22" height="22" viewBox="0 0 24 24" fill="none" style="display:inline-block;"><circle cx="12" cy="12" r="12" fill="#1A3A2F"/><path d="M7 12.5L10.5 16L17 9" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>{%- endcapture -%}
      {%- capture svg_empty -%}<svg width="22" height="22" viewBox="0 0 24 24" fill="none" style="display:inline-block;"><circle cx="12" cy="12" r="11" stroke="#E8E8E8" stroke-width="2" fill="none"/></svg>{%- endcapture -%}

      <p class="text-center mb-4 md:hidden" style="font-size:11px;color:var(--warm-gray);letter-spacing:0.1em;">SCROLL RIGHT TO COMPARE &rarr;</p>
      <div class="overflow-x-auto" style="-webkit-overflow-scrolling:touch;">
        <table style="min-width:520px;width:100%;border-collapse:collapse;">
          <thead>
            <tr>
              <th style="padding:20px 12px;text-align:left;min-width:140px;font-weight:400;color:var(--warm-gray);font-size:12px;letter-spacing:0.03em;"></th>
              <th style="padding:20px 12px;background:var(--deep-ink);color:var(--parchment);font-family:'Space Grotesk',sans-serif;font-weight:500;font-size:13px;letter-spacing:0.05em;min-width:90px;text-align:center;">COASTLINE</th>
              <th style="padding:20px 12px;font-weight:400;color:var(--warm-gray);font-size:12px;letter-spacing:0.03em;min-width:80px;text-align:center;">NOVOS</th>
              <th style="padding:20px 12px;font-weight:400;color:var(--warm-gray);font-size:12px;letter-spacing:0.03em;min-width:80px;text-align:center;">BLUEPRINT</th>
              <th style="padding:20px 12px;font-weight:400;color:var(--warm-gray);font-size:12px;letter-spacing:0.03em;min-width:80px;text-align:center;">AG1</th>
              <th style="padding:20px 12px;font-weight:400;color:var(--warm-gray);font-size:12px;letter-spacing:0.03em;min-width:80px;text-align:center;">TIMELINE</th>
            </tr>
          </thead>
          <tbody>
            <tr style="border-top:1px solid var(--light-gray);">
              <td style="padding:16px 12px;font-size:14px;font-weight:500;color:var(--deep-ink);">Active ingredients</td>
              <td style="padding:16px 12px;background:#F5F5F2;text-align:center;font-family:'Space Grotesk',sans-serif;font-weight:600;">13</td>
              <td style="padding:16px 12px;text-align:center;color:var(--warm-gray);">12</td>
              <td style="padding:16px 12px;text-align:center;color:var(--warm-gray);">40+</td>
              <td style="padding:16px 12px;text-align:center;color:var(--warm-gray);">75</td>
              <td style="padding:16px 12px;text-align:center;color:var(--warm-gray);">1</td>
            </tr>
            <tr style="border-top:1px solid var(--light-gray);">
              <td style="padding:16px 12px;font-size:14px;font-weight:500;color:var(--deep-ink);">Clinical dosing</td>
              <td style="padding:16px 12px;background:#F5F5F2;text-align:center;">{{ svg_check }}</td>
              <td style="padding:16px 12px;text-align:center;">{{ svg_check }}</td>
              <td style="padding:16px 12px;text-align:center;">{{ svg_check }}</td>
              <td style="padding:16px 12px;text-align:center;">{{ svg_empty }}</td>
              <td style="padding:16px 12px;text-align:center;">{{ svg_check }}</td>
