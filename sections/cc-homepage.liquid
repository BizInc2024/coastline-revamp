      {%- endif -%}
      {%- if section.settings.pricing_headline != blank -%}
        <h2 class="reveal text-deep-ink mt-4 mb-6 leading-snug" style="font-size:clamp(1.6rem,3.2vw,2.4rem);" x-intersect.once="$el.classList.add('visible')">
          {{ section.settings.pricing_headline }}
        </h2>
      {%- endif -%}

      <!-- Limited time offer callout -->
