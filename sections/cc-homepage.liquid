<script>
document.addEventListener('DOMContentLoaded', function() {
  document.querySelectorAll('.cc-homepage a[href^="#"]').forEach(function(link) {
    link.addEventListener('click', function(e) {
      var targetId = this.getAttribute('href');
      if (targetId && targetId.length > 1) {
        var target = document.querySelector(targetId);
        if (target) {
          e.preventDefault();
          // Force ALL lazy images to eager so page height settles
          document.querySelectorAll('img[loading="lazy"]').forEach(function(img) {
            img.loading = 'eager';
          });

          function doScroll() {
            var headerEl = document.querySelector('header, .header, .shopify-section-header-sticky');
            var offset = (headerEl ? headerEl.getBoundingClientRect().height : 0) + 40;
            var top = target.getBoundingClientRect().top + window.pageYOffset - offset;
            window.scrollTo({ top: top, behavior: 'smooth' });
          }

          // Scroll immediately, then correct after images load
          setTimeout(doScroll, 100);
          setTimeout(doScroll, 800);
          setTimeout(doScroll, 1500);
        }
      }
    });
  });
});
</script>

<script>
    // Scroll reveal for cc-home and cc-product sections
    document.addEventListener('DOMContentLoaded', function() {
      var reveals = document.querySelectorAll('.cc-home .reveal, .cc-home .reveal-stagger, .cc-product .reveal, .cc-product .reveal-stagger');
      if (!reveals.length) return;

      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

      reveals.forEach(function(el) {
        observer.observe(el);
      });
    });
</script>

{% schema %}
{
  "name": "CC Homepage",
  "tag": "section",
  "class": "cc-homepage-section",
  "max_blocks": 50,
  "settings": [
    {
      "type": "header",
      "content": "1. Hero"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero background image (desktop)"
    },
    {
      "type": "image_picker",
      "id": "hero_image_mobile",
      "label": "Hero background image (mobile)"
    },
    {
      "type": "text",
      "id": "hero_label",
      "label": "Hero top label",
      "default": "THE ULTIMATE LONGEVITY SYSTEM"
    },
    {
      "type": "textarea",
      "id": "hero_headline",
      "label": "Hero headline",
      "default": "Stay sharp, strong, and energized at every age"
    },
    {
      "type": "textarea",
