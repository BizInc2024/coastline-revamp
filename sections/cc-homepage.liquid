<script>
document.addEventListener('DOMContentLoaded', function() {
  document.querySelectorAll('.cc-homepage a[href^="#"]').forEach(function(link) {
    link.addEventListener('click', function(e) {
      var targetId = this.getAttribute('href');
      if (targetId && targetId.length > 1) {
        var target = document.querySelector(targetId);
        if (target) {
          e.preventDefault();
          // Force ALL lazy images to eager so page height settles
          document.querySelectorAll('img[loading="lazy"]').forEach(function(img) {
            img.loading = 'eager';
          });

          function doScroll() {
            var headerEl = document.querySelector('header, .header, .shopify-section-header-sticky');
            var offset = (headerEl ? headerEl.getBoundingClientRect().height : 0) + 40;
            var top = target.getBoundingClientRect().top + window.pageYOffset - offset;
            window.scrollTo({ top: top, behavior: 'smooth' });
          }

          // Scroll immediately, then correct after images load
          setTimeout(doScroll, 100);
          setTimeout(doScroll, 800);
          setTimeout(doScroll, 1500);
        }
      }
    });
  });
});
</script>

