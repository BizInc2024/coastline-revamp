          <button type="button" @click="flavor = 'lemonade'" :class="flavor === 'lemonade' ? 'cc-flavor-lemonade-active' : 'cc-flavor-lemonade-idle'" class="cc-flavor-btn">Coastal Lemonade</button>
        </div>
      </div>

      <!-- Plan selector -->
      <div class="reveal" style="margin-bottom:32px;text-align:left;" x-intersect.once="$el.classList.add('visible')">
        <p style="font-family:'Inter',sans-serif;font-size:11px;letter-spacing:0.15em;text-transform:uppercase;color:#6B6B6B;font-weight:500;margin-bottom:14px;text-align:center;">Select your plan</p>

        <!-- Monthly -->
        <div @click="plan = 'monthly'" :class="plan === 'monthly' ? 'cc-plan-active' : 'cc-plan-idle'" class="cc-plan-card" style="margin-bottom:10px;">
          <div style="display:flex;align-items:center;justify-content:space-between;padding:20px;">
            <div>
              <span style="display:block;font-family:'Space Grotesk',sans-serif;font-weight:500;color:#0A0A0A;font-size:15px;line-height:1.3;">Monthly subscription</span>
              <span style="display:block;font-family:'Inter',sans-serif;font-size:12px;color:#1A3A2F;font-weight:500;margin-top:3px;">Save 34% - just $3.30/day</span>
            </div>
            <div style="text-align:right;flex-shrink:0;margin-left:16px;">
              <span style="display:block;font-family:'Space Grotesk',sans-serif;font-weight:600;color:#0A0A0A;font-size:24px;line-height:1;">$99</span>
              <span style="display:block;font-family:'Inter',sans-serif;font-size:12px;color:#6B6B6B;margin-top:2px;">/month</span>
            </div>
          </div>
        </div>

        <!-- 2-Month -->
        <div @click="plan = 'bimonthly'" :class="plan === 'bimonthly' ? 'cc-plan-active' : 'cc-plan-idle'" class="cc-plan-card" style="margin-bottom:10px;">
          <div style="display:flex;align-items:center;justify-content:space-between;padding:20px;">
            <div>
              <span style="display:block;font-family:'Space Grotesk',sans-serif;font-weight:500;color:#0A0A0A;font-size:15px;line-height:1.3;">Every 2 months</span>
              <span style="display:block;font-family:'Inter',sans-serif;font-size:12px;color:#1A3A2F;font-weight:500;margin-top:3px;">Save 20%</span>
            </div>
            <div style="text-align:right;flex-shrink:0;margin-left:16px;">
              <span style="display:block;font-family:'Space Grotesk',sans-serif;font-weight:600;color:#0A0A0A;font-size:24px;line-height:1;">$120</span>
              <span style="display:block;font-family:'Inter',sans-serif;font-size:12px;color:#6B6B6B;margin-top:2px;">/month</span>
            </div>
          </div>
        </div>

        <!-- One-time -->
        <div @click="plan = 'onetime'" :class="plan === 'onetime' ? 'cc-plan-active' : 'cc-plan-idle'" class="cc-plan-card">
          <div style="display:flex;align-items:center;justify-content:space-between;padding:20px;">
            <div>
              <span style="display:block;font-family:'Space Grotesk',sans-serif;font-weight:500;color:#0A0A0A;font-size:15px;line-height:1.3;">One-time purchase</span>
              <span style="display:block;font-family:'Inter',sans-serif;font-size:12px;color:#6B6B6B;margin-top:3px;">No subscription</span>
            </div>
            <div style="text-align:right;flex-shrink:0;margin-left:16px;">
              <span style="display:block;font-family:'Space Grotesk',sans-serif;font-weight:600;color:#0A0A0A;font-size:24px;line-height:1;">$150</span>
              <span style="display:block;font-family:'Inter',sans-serif;font-size:12px;color:#6B6B6B;margin-top:2px;">one-time</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Add to cart — native product-form (theme.js handles cart drawer + updates) -->
      <div class="reveal" style="margin-bottom:20px;" x-intersect.once="$el.classList.add('visible')">
        <form id="cc-home-cart-form" action="/cart/add" method="post" is="product-form" data-type="add-to-cart-form">
          <input type="hidden" name="id" :value="variantId" />
          <template x-if="sellingPlanId">
            <input type="hidden" name="selling_plan" :value="sellingPlanId" />
          </template>
          <button type="submit" style="display:block;width:100%;background:var(--deep-ink);color:var(--parchment);font-family:'Space Grotesk',sans-serif;font-weight:500;font-size:13px;letter-spacing:0.18em;text-transform:uppercase;padding:20px 48px;border:none;cursor:pointer;transition:opacity 0.3s ease;">
            <span class="btn-text"><span x-text="buttonText"></span></span>
          </button>
        </form>
      </div>

      <!-- Trust signals -->
      <div class="reveal" style="margin-bottom:28px;text-align:center;" x-intersect.once="$el.classList.add('visible')">
        <p style="font-family:'Inter',sans-serif;font-size:13px;color:var(--warm-gray);margin:0 0 4px;">{{ section.settings.pricing_trust_1 | default: "Free shipping. Cancel anytime." }}</p>
        <p style="font-family:'Inter',sans-serif;font-size:13px;color:var(--warm-gray);margin:0;">{{ section.settings.pricing_trust_2 | default: "60-day money-back guarantee." }}</p>
      </div>

      <div class="reveal" style="text-align:center;" x-intersect.once="$el.classList.add('visible')">
        <p style="font-family:'Inter',sans-serif;font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:var(--warm-gray);margin:0;opacity:0.7;">VEGAN, SUGAR-FREE, CAFFEINE-FREE, GMP CERTIFIED, NSF CERTIFIED</p>
      </div>

      <!-- Trust badge images -->
      <div class="reveal" style="display:flex;justify-content:center;align-items:center;gap:24px;margin-top:32px;" x-intersect.once="$el.classList.add('visible')">
        <div style="background:white;border-radius:50%;padding:8px;display:flex;align-items:center;justify-content:center;"><img src="https://cdn.shopify.com/s/files/1/0619/6861/3445/files/istockphoto-1279030031-612x612_1.png?v=1767983702" alt="Third-party tested" style="height:52px;object-fit:contain;" loading="lazy"></div>
        <div style="background:white;border-radius:50%;padding:8px;display:flex;align-items:center;justify-content:center;"><img src="{{ 'cc-nsf-certified.png' | asset_url }}" alt="NSF Certified" style="height:52px;object-fit:contain;" loading="lazy"></div>
        <div style="background:white;border-radius:50%;padding:8px;display:flex;align-items:center;justify-content:center;"><img src="https://cdn.shopify.com/s/files/1/0619/6861/3445/files/download_1.png?v=1767983648" alt="GMP Certified" style="height:52px;object-fit:contain;" loading="lazy"></div>
        <div style="background:white;border-radius:50%;padding:8px;display:flex;align-items:center;justify-content:center;"><img src="https://cdn.shopify.com/s/files/1/0619/6861/3445/files/60-days-money-back-guarantee-icon-for-graphic-design-logo-website-social-media-mobile-app-ui-illustration-vector_1.png?v=1767983637" alt="60-Day Money-Back Guarantee" style="height:52px;object-fit:contain;" loading="lazy"></div>
      </div>
    </div>
  </section>


  {%- comment -%} === WELCOME PACK IMAGE: Between Pricing & Founder (mobile/desktop) === {%- endcomment -%}
  <div class="reveal" x-intersect.once="$el.classList.add('visible')" style="margin:0;padding:0;">
