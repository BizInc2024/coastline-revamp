  {%- comment -%} ============================================================
     SECTION 6: REVIEWS (cc-home-09)
  ============================================================ {%- endcomment -%}
  <section id="cc-reviews-anchor" class="bg-parchment" style="padding-top:{{ section.settings.section6_padding_top | default: 80 }}px;padding-bottom:{{ section.settings.section6_padding_bottom | default: 80 }}px;">
    <div class="max-w-7xl mx-auto px-8 lg:px-16">
      <p class="badge-minimal text-center mb-3 tracking-widest text-xs reveal" x-intersect.once="$el.classList.add('visible')">
        {{ section.settings.reviews_label | default: "WHAT MEMBERS ARE SAYING" }}
      </p>
      <h2 class="reveal text-center text-deep-ink mb-10 font-grotesk font-medium leading-tight" style="font-size:clamp(1.75rem,4vw,2.75rem);" x-intersect.once="$el.classList.add('visible')">
        {{ section.settings.reviews_headline | default: "2,000+ five-star reviews" }}
      </h2>

      {%- comment -%} Count reviews per category for Alpine {%- endcomment -%}
      {%- assign count_all = 0 -%}
      {%- assign count_energy = 0 -%}
      {%- assign count_focus = 0 -%}
      {%- assign count_trust = 0 -%}
      {%- assign count_convenience = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'testimonial' -%}
          {%- assign count_all = count_all | plus: 1 -%}
          {%- case block.settings.category -%}
            {%- when 'energy' -%}{%- assign count_energy = count_energy | plus: 1 -%}
            {%- when 'focus' -%}{%- assign count_focus = count_focus | plus: 1 -%}
            {%- when 'trust' -%}{%- assign count_trust = count_trust | plus: 1 -%}
            {%- when 'convenience' -%}{%- assign count_convenience = count_convenience | plus: 1 -%}
          {%- endcase -%}
        {%- endif -%}
      {%- endfor -%}

      <div x-data="{
        reviewFilter: 'all',
        shown: { all: 6, energy: 6, focus: 6, trust: 6, convenience: 6 },
        totals: { all: {{ count_all }}, energy: {{ count_energy }}, focus: {{ count_focus }}, trust: {{ count_trust }}, convenience: {{ count_convenience }} },
        counters: { all: 0, energy: 0, focus: 0, trust: 0, convenience: 0 },
        resetCounters() { this.counters = { all: 0, energy: 0, focus: 0, trust: 0, convenience: 0 }; }
      }">
        <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:8px;margin-bottom:40px;">
          {%- assign tab_cats = 'all,energy,focus,trust,convenience' | split: ',' -%}
          {%- assign tab_labels = 'ALL,ENERGY,FOCUS,TRUST,CONVENIENCE' | split: ',' -%}
          {%- for tab_cat in tab_cats -%}
            <button @click="reviewFilter = '{{ tab_cat }}'; resetCounters()" class="cc-review-tab" :class="reviewFilter === '{{ tab_cat }}' ? 'cc-review-tab-active' : 'cc-review-tab-idle'">{{ tab_labels[forloop.index0] }}</button>
          {%- endfor -%}
        </div>

        <div style="display:grid;gap:24px;" class="md:!grid-cols-2 lg:!grid-cols-3" x-ref="reviewGrid" x-effect="resetCounters()">
          {%- assign energy_idx = 0 -%}
          {%- assign focus_idx = 0 -%}
          {%- assign trust_idx = 0 -%}
          {%- assign convenience_idx = 0 -%}
          {%- assign all_idx = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'testimonial' -%}
              {%- assign cat = block.settings.category | default: 'energy' -%}
              {%- assign all_idx = all_idx | plus: 1 -%}
              {%- case cat -%}
                {%- when 'energy' -%}{%- assign energy_idx = energy_idx | plus: 1 -%}{%- assign cat_idx = energy_idx -%}
                {%- when 'focus' -%}{%- assign focus_idx = focus_idx | plus: 1 -%}{%- assign cat_idx = focus_idx -%}
                {%- when 'trust' -%}{%- assign trust_idx = trust_idx | plus: 1 -%}{%- assign cat_idx = trust_idx -%}
                {%- when 'convenience' -%}{%- assign convenience_idx = convenience_idx | plus: 1 -%}{%- assign cat_idx = convenience_idx -%}
              {%- endcase -%}
              <div {{ block.shopify_attributes }}
                x-show="(reviewFilter === 'all' && {{ all_idx }} <= shown.all) || (reviewFilter === '{{ cat }}' && {{ cat_idx }} <= shown['{{ cat }}'])"
                x-transition:enter="transition ease-out duration-300"
                x-transition:enter-start="opacity-0 transform translate-y-4"
                x-transition:enter-end="opacity-100 transform translate-y-0"
                style="border-top:1px solid var(--light-gray);padding-top:24px;"
              >
                <p style="letter-spacing:4px;color:var(--deep-ink);font-size:14px;margin-bottom:12px;">&#9733;&#9733;&#9733;&#9733;&#9733;</p>
                <p style="font-family:'Inter',sans-serif;font-size:16px;color:var(--deep-ink);line-height:1.65;margin-bottom:16px;">
                  "{{ block.settings.quote }}"
                </p>
                <p style="font-family:'Inter',sans-serif;font-size:12px;letter-spacing:0.12em;text-transform:uppercase;color:var(--warm-gray);">
                  {{ block.settings.name }}{% if block.settings.detail != blank %}, {{ block.settings.detail }}{% endif %}
                </p>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        <div style="text-align:center;margin-top:40px;display:flex;justify-content:center;gap:0.75rem;flex-wrap:wrap;">
          <button
            x-show="shown[reviewFilter] < totals[reviewFilter]"
            @click="shown[reviewFilter] += 6"
            style="padding:12px 32px;font-family:'Space Grotesk',sans-serif;font-size:12px;letter-spacing:0.12em;text-transform:uppercase;border-radius:100px;cursor:pointer;border:1px solid var(--light-gray);background:transparent;color:var(--warm-gray);transition:all 0.2s ease;"
            x-transition
          >SHOW MORE REVIEWS</button>
          <button
            x-show="shown[reviewFilter] > 6"
            @click="shown[reviewFilter] = 6; $nextTick(() => { document.getElementById('cc-reviews-anchor').scrollIntoView({ behavior: 'smooth' }) })"
            style="padding:12px 32px;font-family:'Space Grotesk',sans-serif;font-size:12px;letter-spacing:0.12em;text-transform:uppercase;border-radius:100px;cursor:pointer;border:1px solid var(--light-gray);background:transparent;color:var(--warm-gray);transition:all 0.2s ease;"
            x-transition
          >SHOW LESS</button>
        </div>
      </div>
    </div>
  </section>



  {%- comment -%} ============================================================
     SECTION 8: VIDEO (cc-home-11)
  ============================================================ {%- endcomment -%}
  {%- assign video_url = section.settings.video_url -%}
  {%- if section.settings.section8_visible -%}
  <section class="bg-parchment" style="padding-top:{{ section.settings.section8_padding_top | default: 80 }}px;padding-bottom:{{ section.settings.section8_padding_bottom | default: 80 }}px;">
    <div class="max-w-6xl mx-auto px-8 lg:px-16">
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">

        <div class="lg:col-span-7 reveal" x-intersect.once="$el.classList.add('visible')" x-data="{ playing: false, embedUrl: '' }" x-init="
          {% if video_url != blank %}
            var raw = '{{ video_url }}';
            if (raw.indexOf('youtube.com') > -1 || raw.indexOf('youtu.be') > -1) {
              var id = '';
              if (raw.indexOf('youtu.be/') > -1) { id = raw.split('youtu.be/')[1].split(/[?&#]/)[0]; }
              else { var match = raw.match(/[?&]v=([^&#]+)/); if (match) id = match[1]; }
              if (id) embedUrl = 'https://www.youtube-nocookie.com/embed/' + id + '?autoplay=1&rel=0';
            } else if (raw.indexOf('vimeo.com') > -1) {
              var vid = raw.split('vimeo.com/')[1].split(/[?&#]/)[0];
              if (vid) embedUrl = 'https://player.vimeo.com/video/' + vid + '?autoplay=1';
            }
          {% endif %}
        ">
          <div class="cc-video-wrap">
            <template x-if="!playing">
              <div @click="if(embedUrl) playing = true" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; cursor: pointer;">
                {% if section.settings.video_thumbnail != blank %}
                  <img src="{{ section.settings.video_thumbnail | image_url: width: 1200 }}" alt="{{ section.settings.video_headline | default: 'Watch how Coastline works' }}" loading="lazy" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover;">
                {% else %}
                  <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: var(--deep-ink); display: flex; align-items: center; justify-content: center;">
                    <p class="text-warm-gray font-inter text-sm tracking-widest uppercase">Video</p>
                  </div>
                {% endif %}
                <svg style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 72px; height: 72px; cursor: pointer; z-index: 2; transition: opacity 0.3s ease;" viewBox="0 0 72 72" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="36" cy="36" r="35" fill="rgba(10,10,10,0.6)" stroke="#FAF9F6" stroke-width="1.5"/>
                  <polygon points="29,22 29,50 52,36" fill="#FAF9F6"/>
                </svg>
              </div>
            </template>
            <template x-if="playing">
              <iframe :src="embedUrl" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: 0;"></iframe>
            </template>
          </div>
        </div>

        <div class="lg:col-span-5 reveal" x-intersect.once="$el.classList.add('visible')">
          <p style="font-family:'Inter',sans-serif;font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:var(--warm-gray);font-weight:500;margin-bottom:12px;">{{ section.settings.video_label | default: "SEE THE SCIENCE" }}</p>
          <div style="width:40px;height:1px;background:var(--light-gray);margin-bottom:24px;"></div>
          <h2 style="font-family:'Space Grotesk',sans-serif;font-weight:500;font-size:clamp(24px,3vw,36px);color:var(--deep-ink);letter-spacing:-0.02em;line-height:1.2;margin-bottom:16px;">{{ section.settings.video_headline | default: "Watch how Coastline works" }}</h2>
          <p style="font-family:'Inter',sans-serif;font-size:17px;color:var(--warm-gray);line-height:1.7;margin-bottom:32px;">
            {{ section.settings.video_body | default: "Our team of researchers breaks down the science behind each ingredient and why timing matters for longevity." }}
          </p>
          <a href="{{ section.settings.video_link_url | default: '#' }}" style="font-family:'Space Grotesk',sans-serif;font-size:13px;letter-spacing:0.1em;text-transform:uppercase;color:var(--deep-ink);text-decoration:none;border-bottom:1px solid var(--deep-ink);padding-bottom:2px;">{{ section.settings.video_link_text | default: "WATCH NOW" }}</a>
        </div>

      </div>
    </div>
  </section>
  {%- endif -%}


  {%- comment -%} === DIVIDER IMAGE 2: Between Comparison & Pricing (separate mobile/desktop) === {%- endcomment -%}
  <div class="reveal" x-intersect.once="$el.classList.add('visible')">
    {%- comment -%} Mobile image (shown below 768px) {%- endcomment -%}
