    <p style="font-family:'Inter',sans-serif !important;font-size:11px !important;letter-spacing:0.12em !important;text-transform:uppercase !important;font-weight:600 !important;color:#1A3A2F !important;margin:0 0 4px !important;">{{ section.settings.free_gift_label | default: "Free gift with your first order of the complete system" }}</p>
    <p style="font-family:'Inter',sans-serif !important;font-size:15px !important;color:#0A0A0A !important;margin:0 !important;font-weight:400 !important;">{{ section.settings.free_gift_description | default: "Premium Glass Shaker Bottle ($15 value)" }}</p>
  </div>

  {%- comment -%} ============================================================
     SECTION 10: PRICING CTA (cc-home-13)
  ============================================================ {%- endcomment -%}
