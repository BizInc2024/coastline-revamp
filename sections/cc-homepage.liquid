    {%- else -%}
      <img src="https://cdn.shopify.com/s/files/1/0619/6861/3445/files/Family_Vert_-_CL_2_20aeec91-5477-425f-84e0-5ea21f9239ad.png?v=1769186113" alt="Coastline product family" class="cc-divider2-mobile" style="width:100%;height:320px;object-fit:cover;display:block;" loading="lazy">
    {%- endif -%}
    {%- comment -%} Desktop image (shown at 768px+) {%- endcomment -%}
    {%- if section.settings.divider_image_2_desktop != blank -%}
      <img src="{{ section.settings.divider_image_2_desktop | image_url: width: 1920 }}" alt="Coastline" class="cc-divider2-desktop" style="width:100%;height:auto;display:none;" loading="lazy">
    {%- elsif section.settings.divider_image_2 != blank -%}
      <img src="{{ section.settings.divider_image_2 | image_url: width: 1920 }}" alt="Coastline" class="cc-divider2-desktop" style="width:100%;height:auto;display:none;" loading="lazy">
    {%- else -%}
      <img src="https://cdn.shopify.com/s/files/1/0619/6861/3445/files/Family_Vert_-_CL_2_20aeec91-5477-425f-84e0-5ea21f9239ad.png?v=1769186113" alt="Coastline product family" class="cc-divider2-desktop" style="width:100%;height:320px;object-fit:cover;display:none;" loading="lazy">
    {%- endif -%}
