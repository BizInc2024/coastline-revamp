      <img src="{{ section.settings.welcome_pack_image_mobile | image_url: width: 800 }}" alt="Coastline Welcome Pack" class="cc-divider2-mobile" style="width:100%;max-height:60vh;object-fit:cover;display:block;" loading="lazy">
    {%- else -%}
      <img src="https://cdn.shopify.com/s/files/1/0619/6861/3445/files/WELCOME_OPEN_LIGHT_BLUE.jpg?v=1759112312" alt="Coastline Welcome Pack" class="cc-divider2-mobile" style="width:100%;max-height:60vh;object-fit:cover;display:block;" loading="lazy">
    {%- endif -%}
