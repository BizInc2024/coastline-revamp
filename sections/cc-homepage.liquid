      <img src="{{ section.settings.divider_image_2_mobile | image_url: width: 800 }}" alt="Coastline" class="cc-divider2-mobile" style="width:100%;height:auto;display:block;" loading="lazy">
    {%- elsif section.settings.divider_image_2 != blank -%}
