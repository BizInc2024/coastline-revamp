        <span style="display:inline-block;font-family:'Space Grotesk',sans-serif;font-size:12px;letter-spacing:0.15em;text-transform:uppercase;color:#0A0A0A;font-weight:500;padding:14px 32px;border:2px solid #0A0A0A;">
          {{ section.settings.pricing_urgency | default: "Introductory pricing -- limited time offer" }}
