    <div
      x-data="{
        flavor: 'unflavored',
        plan: 'monthly',
        variants: { unflavored: 42179764453445, lemonade: 42179764486213 },
        plans: {
          monthly:   { id: 1862631493, price: '$99/mo',  label: 'Monthly',  save: 'Save 34%' },
          bimonthly: { id: 1892712517, price: '$120/mo', label: '2-Month',  save: 'Save 20%' },
          onetime:   { id: null,       price: '$150',    label: 'One-time', save: '' }
        },
        loading: false,
        get variantId() { return this.variants[this.flavor]; },
        get sellingPlanId() { return this.plans[this.plan].id; },
        get buttonText() { return 'ADD TO CART - ' + this.plans[this.plan].price; }
