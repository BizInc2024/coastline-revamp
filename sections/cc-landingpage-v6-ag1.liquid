<!-- Anchor scrolling -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.cc-landing-v6 a[href^="#"]').forEach(function(link) {
      link.addEventListener('click', function(e) {
        var targetId = this.getAttribute('href');
        if (!targetId || targetId === '#') return;
        var target = document.querySelector(targetId);
        if (target) {
          e.preventDefault();
          var wrapper = document.querySelector('.cc-landing-v6');
          if (wrapper) { wrapper.querySelectorAll('img[loading="lazy"]').forEach(function(img) { if (img.getBoundingClientRect().top < target.getBoundingClientRect().top) { img.loading = 'eager'; } }); }
          var reveals = []; var el = target;
          while (el && !el.classList.contains('cc-landing-v6')) { if (el.classList.contains('reveal')) reveals.push(el); el = el.parentElement; }
          if (target.classList.contains('reveal')) reveals.push(target);
          reveals.forEach(function(r) { r.style.transition = 'none'; r.classList.add('visible'); r.style.opacity = '1'; r.style.transform = 'none'; });
          void target.offsetHeight;
          var rect = target.getBoundingClientRect();
          var scrollTop = window.pageYOffset || document.documentElement.scrollTop;
          var dest = scrollTop + rect.top; var start = scrollTop; var distance = dest - start; var duration = 600; var startTime = null;
          function smoothStep(time) {
            if (!startTime) startTime = time;
            var progress = Math.min((time - startTime) / duration, 1);
            var ease = progress < 0.5 ? 2 * progress * progress : -1 + (4 - 2 * progress) * progress;
            window.scrollTo(0, start + distance * ease);
            if (progress < 1) { requestAnimationFrame(smoothStep); }
            else { reveals.forEach(function(r) { r.style.transition = ''; }); setTimeout(function() { var finalRect = target.getBoundingClientRect(); if (Math.abs(finalRect.top) > 5) { window.scrollTo(0, window.pageYOffset + finalRect.top); } }, 100); }
          }
          requestAnimationFrame(smoothStep);
        }
      });
    });
  });
</script>

