                <div class="editorial-divider mx-auto mb-10"></div>
                <h2 class="text-3xl lg:text-4xl font-grotesk font-medium mb-4">{{ section.settings.price_headline | default: "What you're actually paying for" }}</h2>
            </div>

            <div class="grid md:grid-cols-2 gap-8 mb-20 reveal" x-init="setTimeout(() => $el.classList.add('visible'), 100)" x-intersect="$el.classList.add('visible')">
                <!-- AG1 Card -->
                <div class="border border-light-gray p-8">
                    <img src="{% if section.settings.ag1_product_image != blank %}{{ section.settings.ag1_product_image | image_url: width: 400 }}{% else %}{{ 'cc-v6-ag1-product.webp' | asset_url }}{% endif %}" alt="AG1" class="mx-auto mb-6" style="max-height: 120px; object-fit: contain;" loading="lazy">
                    <p class="text-xs tracking-widest uppercase text-warm-gray mb-2">AG1</p>
                    <p class="text-4xl font-grotesk font-medium text-deep-ink mb-4">$79<span class="text-lg text-warm-gray">/month</span></p>
                    <div class="border-t border-light-gray pt-4 space-y-3 text-sm text-warm-gray">
                        <p>75 ingredients at trace amounts</p>
                        <p>~$1.05 per ingredient per month</p>
                        <p>$2.63/day</p>
                        <p>$948/year</p>
                        <p class="text-xs pt-2" style="color: #C0392B;">Proprietary blends -- doses undisclosed</p>
                    </div>
                </div>
                <!-- Coastline Card -->
                <div class="border-2 border-deep-ink p-8 relative">
                    <span style="position: absolute; top: -12px; left: 16px; background: var(--forest-light); color: white; font-size: 10px; font-weight: 500; letter-spacing: 0.08em; padding: 4px 10px;">BETTER VALUE</span>
                    <img src="{% if section.settings.coastline_product_image != blank %}{{ section.settings.coastline_product_image | image_url: width: 400 }}{% else %}https://cdn.shopify.com/s/files/1/0619/6861/3445/files/Family_Vert_-_CL_2_20aeec91-5477-425f-84e0-5ea21f9239ad.png?v=1769186113{% endif %}" alt="Coastline" class="mx-auto mb-6" style="max-height: 120px; object-fit: contain;" loading="lazy">
                    <p class="text-xs tracking-widest uppercase text-warm-gray mb-2">Coastline</p>
                    <p class="text-4xl font-grotesk font-medium text-deep-ink mb-4">$99<span class="text-lg text-warm-gray">/month</span></p>
                    <div class="border-t border-light-gray pt-4 space-y-3 text-sm text-warm-gray">
                        <p>13 ingredients at clinical doses</p>
                        <p>~$7.62 per ingredient per month</p>
                        <p>$3.30/day</p>
