<style>
    html { scroll-behavior: smooth; }
    .cc-landing-v6 p { max-width: none !important; }
    .cc-landing-v6 h1, .cc-landing-v6 h2 { text-wrap: balance; }

    .editorial-divider { width: 60px; height: 1px; background: #0A0A0A; }
    .section-counter { font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 400; letter-spacing: 0.15em; text-transform: uppercase; color: #6B6B6B; }

    .accordion-content { max-height: 0; overflow: hidden; transition: max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1); }
    .accordion-content.open { max-height: 2000px; }

    .cc-landing-v6 footer .cc-v6-footer-cta {
        display: inline-block !important; width: auto !important; min-width: 0 !important; min-height: 0 !important;
        padding: 20px 48px !important; margin: 0 !important; box-shadow: none !important; border-radius: 0 !important; border: none !important; box-sizing: border-box !important;
    }

    .v6-blockquote { font-family: 'Space Grotesk', sans-serif; font-size: clamp(28px, 5vw, 48px); font-weight: 500; line-height: 1.2; letter-spacing: -0.02em; color: #FAF9F6; }
    .v6-study-card { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); padding: 32px; margin-top: 40px; }
    .v6-study-card li { display: flex; align-items: flex-start; gap: 12px; padding: 10px 0; font-size: 15px; color: #9A9A9A; }

    .v6-comparison-table { width: 100%; border-collapse: collapse; }
    .v6-comparison-table th, .v6-comparison-table td { padding: 16px 12px; text-align: left; border-bottom: 1px solid #E8E8E8; font-size: 14px; }
    .v6-comparison-table th { font-weight: 500; color: #0A0A0A; font-family: 'Space Grotesk', sans-serif; font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; }
    .v6-comparison-table td:first-child { color: #6B6B6B; min-width: 140px; }
    .v6-comparison-table .v6-check { color: #2D5A47; font-weight: 600; }
    .v6-comparison-table .v6-x { color: #C0392B; font-weight: 600; }

    .v6-star-table { width: 100%; border-collapse: collapse; }
    .v6-star-table th, .v6-star-table td { padding: 16px 12px; text-align: center; border-bottom: 1px solid #E8E8E8; }
    .v6-star-table th { font-weight: 500; font-family: 'Space Grotesk', sans-serif; font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; color: #0A0A0A; }
    .v6-star-table td:first-child { text-align: left; color: #6B6B6B; font-size: 14px; }
    .v6-star-table .v6-stars { letter-spacing: 2px; font-size: 16px; color: #0A0A0A; }
    .v6-star-table-dark th, .v6-star-table-dark td { border-bottom-color: rgba(250,249,246,0.1); }
    .v6-star-table-dark th { color: rgba(250,249,246,0.5); }
    .v6-star-table-dark td:first-child { color: rgba(250,249,246,0.6); }
    .v6-star-table-dark .v6-stars { color: #FAF9F6; }

    .v6-ingredient-card { border: 1px solid #E8E8E8; padding: 20px; text-align: center; }
    .v6-ingredient-card p:first-of-type { font-family: 'Space Grotesk', sans-serif; font-weight: 500; font-size: 15px; color: #0A0A0A; margin-bottom: 4px; }
    .v6-ingredient-card p:last-of-type { font-size: 12px; color: #6B6B6B; }

    @media (prefers-reduced-motion: reduce) { .reveal { opacity: 1; transform: none; } }
</style>

<div class="cc-landing-v6" x-data="{ visibleReviews: 3 }">

    <!-- SECTION 1: EDITORIAL HERO -->
    <section id="hero" class="pt-20 pb-12 lg:pt-32 lg:pb-16 bg-parchment">
        <div class="max-w-3xl mx-auto px-6 sm:px-8 text-center">
            <div class="reveal" x-init="setTimeout(() => $el.classList.add('visible'), 100)" x-intersect="$el.classList.add('visible')">
                <p class="section-counter mb-6">{{ section.settings.hero_eyebrow | default: 'SUPPLEMENT COMPARISON - UPDATED JANUARY 2026' }}</p>
                <div class="editorial-divider mx-auto mb-10"></div>
                <h1 class="text-3xl md:text-4xl lg:text-5xl xl:text-6xl font-grotesk font-medium mb-8 leading-tight text-deep-ink">
                    {{ section.settings.hero_headline | default: 'Coastline vs AG1: Which Longevity Supplement Is Actually Worth It?' }}
                </h1>
                <p class="text-lg lg:text-xl text-warm-gray mb-8 max-w-2xl mx-auto leading-relaxed">
                    {{ section.settings.hero_subheadline | default: 'Both brands promise better health. But which one actually delivers? We compared ingredients, clinical evidence, pricing, and real user feedback.' }}
                </p>
                <div class="inline-flex items-center gap-3 mb-10">
                    <div class="w-10 h-10 rounded-full bg-deep-ink flex items-center justify-center">
                        <span class="text-parchment text-sm font-grotesk font-medium">JC</span>
                    </div>
                    <div class="text-left">
                        <p class="text-sm text-deep-ink font-medium leading-tight">{{ section.settings.hero_author | default: 'Dr. James Chen' }}</p>
                        <p class="text-xs text-warm-gray leading-tight">{{ section.settings.hero_author_title | default: 'Clinical Nutrition Researcher' }}</p>
                    </div>
                </div>
                <div class="flex flex-col items-center gap-4">
                    <a href="#v6-comparison" class="btn-primary">{{ section.settings.hero_cta_text | default: 'See the Full Comparison' }}</a>
                    <a href="#v6-takeaways" class="link-underline" style="font-size:12px; color:var(--warm-gray);">SKIP TO THE KEY TAKEAWAYS</a>
                </div>

                <!-- Side-by-side product images -->
                <div class="grid grid-cols-2 gap-8 mt-16 max-w-2xl mx-auto items-end">
                    <div>
                        <img src="{% if section.settings.hero_coastline_image != blank %}{{ section.settings.hero_coastline_image | image_url: width: 600 }}{% else %}https://cdn.shopify.com/s/files/1/0619/6861/3445/files/Family_Vert_-_CL_2_20aeec91-5477-425f-84e0-5ea21f9239ad.png?v=1769186113{% endif %}" alt="Coastline" class="mx-auto" style="max-height: 240px; object-fit: contain;" loading="lazy">
                        <p class="text-xs tracking-widest uppercase text-deep-ink mt-4">Coastline</p>
                        <p class="text-xs text-warm-gray mt-1">13 clinical-dose ingredients</p>
                    </div>
                    <div>
                        <img src="{% if section.settings.hero_ag1_image != blank %}{{ section.settings.hero_ag1_image | image_url: width: 600 }}{% else %}{{ 'cc-v6-ag1-product.webp' | asset_url }}{% endif %}" alt="AG1" class="mx-auto" style="max-height: 240px; object-fit: contain;" loading="lazy">
                        <p class="text-xs tracking-widest uppercase text-warm-gray mt-4">AG1</p>
                        <p class="text-xs text-warm-gray mt-1">75 ingredients, doses undisclosed</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- SECTION 2: NEUTRAL INTRO -->
    <section class="pt-2 pb-12 lg:pt-4 lg:pb-16 bg-parchment">
        <div class="max-w-2xl mx-auto px-6 sm:px-8">
            <div class="reveal" x-init="setTimeout(() => $el.classList.add('visible'), 100)" x-intersect="$el.classList.add('visible')">
                <p class="text-warm-gray text-lg leading-relaxed">
                    {{ section.settings.intro_body_1 | default: "A recent clinical trial on AG1 -- funded by AG1 themselves -- found no significant health benefits compared to placebo. In light of that study, we decided to compare AG1 side by side with Coastline, a science-first longevity supplement built on a fundamentally different approach. We looked at ingredients, clinical doses, pricing, and real customer feedback." }}
                </p>
            </div>
        </div>
    </section>

    <!-- Bridge: Intro → AG1 Clinical Evidence -->
    <section class="py-12 lg:py-16 bg-white">
        <div class="max-w-2xl mx-auto px-6 sm:px-8">
            <div class="reveal" x-init="setTimeout(() => $el.classList.add('visible'), 100)" x-intersect="$el.classList.add('visible')">
                <h3 class="font-grotesk text-2xl lg:text-3xl font-medium text-deep-ink mb-8">{{ section.settings.bridge_1_headline | default: "The study AG1 probably wishes you had not seen" }}</h3>
                <p class="text-warm-gray text-lg leading-relaxed mb-6">
                    {{ section.settings.bridge_1_p1 | default: "For years, AG1 has been the default recommendation. You have seen it everywhere -- podcast ads, YouTube sponsorships, Instagram stories. It became the supplement that people bought because everyone else seemed to be buying it." }}
                </p>
                <p class="text-warm-gray text-lg leading-relaxed mb-6">
                    {{ section.settings.bridge_1_p2 | default: "Then AG1 published its own clinical trial. The results were supposed to validate what millions of subscribers already believed. Instead, the data told a very different story." }}
                </p>
                <p class="text-deep-ink text-lg leading-relaxed font-medium">
                    {{ section.settings.bridge_1_p3 | default: "Here is what the study actually found -- and why it matters for anyone paying $79 a month." }}
                </p>
            </div>
        </div>
    </section>

    <!-- Divider Image -->
    <div class="w-full">
        <img src="{% if section.settings.breaker_image_pre_bj != blank %}{{ section.settings.breaker_image_pre_bj | image_url: width: 1600 }}{% else %}https://cdn.shopify.com/s/files/1/0619/6861/3445/files/canon-beach-haystack_1.png?v=1764011837{% endif %}" alt="" class="w-full" style="max-height: 40vh; object-fit: cover;" loading="lazy">
    </div>

    <!-- SECTION 3: AG1 CLINICAL EVIDENCE -->
    <section class="py-20 lg:py-32" style="background-color: #0A0A0A;">
        <div class="max-w-3xl mx-auto px-6 sm:px-8">
            <div class="reveal" x-init="setTimeout(() => $el.classList.add('visible'), 100)" x-intersect="$el.classList.add('visible')">
                <p class="text-xs tracking-widest uppercase mb-8" style="color: rgba(250,249,246,0.4);">The Clinical Evidence</p>
                <div style="width:60px; height:1px; background:rgba(250,249,246,0.2); margin-bottom:40px;"></div>

                <!-- Study findings first -->
                <div class="v6-study-card mb-12">
                    <p class="text-xs tracking-widest uppercase mb-6" style="color: rgba(250,249,246,0.5);">{{ section.settings.study_label | default: "AG1's Own Clinical Trial Found:" }}</p>
                    <ul>
                        <li><span style="color: #C0392B; flex-shrink: 0;">&#10007;</span> {{ section.settings.study_1 | default: 'No significant changes in blood biomarkers vs placebo' }}</li>
                        <li><span style="color: #C0392B; flex-shrink: 0;">&#10007;</span> {{ section.settings.study_2 | default: 'No statistically significant gut health improvement (p = 0.058)' }}</li>
                        <li><span style="color: #C0392B; flex-shrink: 0;">&#10007;</span> {{ section.settings.study_3 | default: 'No metabolic or inflammatory benefits detected' }}</li>
                        <li><span style="color: #C0392B; flex-shrink: 0;">&#10007;</span> {{ section.settings.study_4 | default: 'Microbiome changes were clinically irrelevant' }}</li>
                        <li><span style="color: #C0392B; flex-shrink: 0;">&#10007;</span> {{ section.settings.study_5 | default: 'Placebo showed similar or larger shifts' }}</li>
                    </ul>
                </div>

                <!-- Bryan Johnson quote as supporting evidence -->
                <div class="flex flex-col md:flex-row items-center gap-8 md:gap-12 mt-12 mb-12" style="padding: 32px; background: rgba(255,255,255,0.03); border: 1px solid rgba(250,249,246,0.08); border-radius: 4px;">
                    <div class="flex-shrink-0">
                        <img src="{% if section.settings.bj_portrait != blank %}{{ section.settings.bj_portrait | image_url: width: 400 }}{% else %}{{ 'cc-v6-bryan-johnson.jpg' | asset_url }}{% endif %}" alt="Bryan Johnson" class="w-20 h-20 md:w-24 md:h-24 rounded-full object-cover" style="border: 2px solid rgba(250,249,246,0.15);" loading="lazy">
                    </div>
                    <div>
                        <blockquote class="font-grotesk font-medium text-xl md:text-2xl leading-snug mb-4" style="color: #FAF9F6;">
                            {{ section.settings.bj_quote | default: "&ldquo;I'd cancel your AG1 subscription.&rdquo;" }}
                        </blockquote>
                        <p class="text-sm" style="color: rgba(250,249,246,0.5);">
                            {{ section.settings.bj_attribution | default: '-- Bryan Johnson, tech entrepreneur and longevity advocate' }}
                        </p>
                    </div>
                </div>

                <div>
                    <h3 class="font-grotesk font-medium text-xl mb-4" style="color: #FAF9F6;">{{ section.settings.pixie_dust_headline | default: 'The pixie dusting problem' }}</h3>
                    <p class="leading-relaxed mb-8" style="color: #9A9A9A; font-size: 16px;">
                        {{ section.settings.pixie_dust_body | default: "AG1 contains 75 ingredients in a single scoop. That sounds impressive until you do the math. Imagine splitting a single glass of water among 75 people. Each person gets a few drops. That is what happens when you cram 75 ingredients into one serving -- most are present in trace amounts far below what clinical trials use." }}
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Bridge: Bryan Johnson → Comparison -->
    <section class="py-16 lg:py-20 bg-parchment">
        <div class="max-w-2xl mx-auto px-6 sm:px-8">
            <div class="reveal" x-init="setTimeout(() => $el.classList.add('visible'), 100)" x-intersect="$el.classList.add('visible')">
                <h3 class="font-grotesk text-2xl lg:text-3xl font-medium text-deep-ink mb-8">{{ section.settings.bridge_2_headline | default: "So we pulled the data" }}</h3>
                <p class="text-warm-gray text-lg leading-relaxed mb-6">
                    {{ section.settings.bridge_2_p1 | default: "That is a lot to take in. A product used by millions, backed by some of the biggest names on the internet, and its own clinical trial could not demonstrate significant benefits over a placebo." }}
                </p>
                <p class="text-warm-gray text-lg leading-relaxed mb-6">
                    {{ section.settings.bridge_2_p2 | default: "So we did what any rational person would do. We pulled the publicly available data on both AG1 and Coastline and laid them side by side. Not marketing claims. Just the ingredients, the doses, the clinical evidence, and the price." }}
                </p>
                <p class="text-deep-ink text-lg leading-relaxed font-medium mb-8">
                    {{ section.settings.bridge_2_p3 | default: "Here is exactly what we found when we compared them head to head." }}
                </p>
                <div class="text-center">
                    <a href="#v6-offer-anchor" class="link-underline" style="font-size:12px; color:var(--warm-gray);">SKIP AHEAD TO PRICING</a>
                </div>
            </div>
        </div>
    </section>

