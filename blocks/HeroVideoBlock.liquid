{% assign ai_gen_id = section.id | replace: '_', '' | downcase %}

{% liquid
  if block.settings.section_height == 'adapt'
    assign section_height_desktop = 'auto'
  elsif block.settings.section_height == 'fullscreen'
    assign section_height_desktop = '100vh'
  else
    assign section_height_desktop = block.settings.section_height_custom | append: 'px'
  endif

  if block.settings.section_height_mobile == 'adapt'
    assign section_height_mobile = 'auto'
  elsif block.settings.section_height_mobile == 'fullscreen'
    assign section_height_mobile = '100vh'
  else
    assign section_height_mobile = block.settings.section_height_mobile_custom | append: 'px'
  endif
%}

{% style %}
  .ai-hero-section-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    width: 100%;
    overflow: hidden;
    position: relative;
  }

  {% if block.settings.transparent_header %}
    .shopify-section-header-sticky + * .ai-hero-section-{{ ai_gen_id }},
    .shopify-section-header-hidden + * .ai-hero-section-{{ ai_gen_id }},
    .shopify-section:first-child .ai-hero-section-{{ ai_gen_id }} {
      margin-top: calc(-1 * var(--header-height, 100px));
    }
    .ai-hero-container-{{ ai_gen_id }} {
      padding-top: var(--header-height, 100px);
    }
  {% endif %}

  .ai-hero-container-{{ ai_gen_id }} {
    display: flex;
    width: 100%;
    min-height: {{ section_height_desktop }};
    height: {{ section_height_desktop }};
  }

  .ai-hero-video-column-{{ ai_gen_id }} {
    flex: 0 0 50%;
    position: relative;
    overflow: hidden;
    height: {{ section_height_desktop }};
  }

  .ai-hero-video-wrapper-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    position: relative;
    background-color: {{ block.settings.video_background_color }};
  }

  .ai-hero-video-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: {{ block.settings.video_crop_position }};
  }

  .ai-hero-video-mobile-{{ ai_gen_id }} {
    display: none;
  }

  .ai-hero-video-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.video_background_color }};
  }

  .ai-hero-video-placeholder-{{ ai_gen_id }} svg {
    max-width: 300px;
    max-height: 300px;
    opacity: 0.3;
  }

  .ai-hero-content-column-{{ ai_gen_id }} {
    flex: 0 0 50%;
    display: flex;
    align-items: center;
    padding: 40px 60px {{ block.settings.section_padding_bottom }}px;
  }

  .ai-hero-content-wrapper-{{ ai_gen_id }} {
    max-width: 600px;
    width: 100%;
  }

  .ai-hero-content-wrapper-{{ ai_gen_id }} > * {
    margin-bottom: {{ block.settings.element_spacing_desktop }}px;
  }

  .ai-hero-content-wrapper-{{ ai_gen_id }} > *:last-child {
    margin-bottom: 0;
  }

  .ai-hero-content-wrapper-{{ ai_gen_id }} > .ai-hero-headline-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.headline_margin_bottom }}px !important;
  }

  .ai-hero-badge-{{ ai_gen_id }} {
    display: none;
  }

  .ai-hero-badge-desktop-{{ ai_gen_id }} {
    display: inline-block;
    padding: 8px 16px;
    background-color: {{ block.settings.badge_background_color }};
    color: {{ block.settings.badge_text_color }};
    font-size: {{ block.settings.badge_font_size_desktop }}px;
    border-radius: {{ block.settings.badge_border_radius }}px;
    width: {{ block.settings.badge_width }}%;
    text-align: center;
  }

  .ai-hero-review-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ai-hero-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 6px;
    color: {{ block.settings.star_color }};
  }

  .ai-hero-stars-{{ ai_gen_id }} svg {
    width: {{ block.settings.star_size_desktop }}px;
    height: {{ block.settings.star_size_desktop }}px;
  }

  .ai-hero-review-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.review_font_size_desktop }}px;
    color: {{ block.settings.review_text_color }};
  }

  .ai-hero-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_font_size_desktop }}px;
    color: {{ block.settings.headline_color }};
    margin: 0 0 {{ block.settings.headline_margin_bottom }}px 0 !important;
    line-height: {{ block.settings.headline_line_height }};
  }

  .ai-hero-headline-{{ ai_gen_id }} p {
    margin: 0;
  }

  .ai-hero-subheadline-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheadline_font_size_desktop }}px;
    color: {{ block.settings.subheadline_color }};
    line-height: 1.5;
  }

  .ai-hero-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: clamp(10px, 1.5vw, 14px) clamp(16px, 2.2vw, 24px);
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size_desktop }}px;
    font-weight: 700;
    line-height: 1.1;
    transition: all 0.3s ease;
    width: {{ block.settings.button_width }}%;
    text-align: center;
    margin-bottom: {{ block.settings.button_margin_bottom }}px;
  }

  .ai-hero-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .ai-hero-callouts-{{ ai_gen_id }} {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: {{ block.settings.callout_gap }}px;
    margin-top: {{ block.settings.button_margin_bottom }}px;
  }

  .ai-hero-callout-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    flex: 1 1 48%;
  }

  .ai-hero-callout-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    color: {{ block.settings.callout_icon_color }};
    flex-shrink: 0;
  }

  .ai-hero-callout-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.callout_font_size_desktop }}px;
    color: {{ block.settings.callout_text_color }};
  }

  .ai-hero-trust-badges-{{ ai_gen_id }} {
    display: flex;
    justify-content: flex-start;
    align-items: center;
    gap: 15px;
    padding-top: {{ block.settings.trust_badges_padding_top }}px;
    margin-top: {{ block.settings.trust_badges_spacing_top }}px;
    {% if block.settings.trust_badges_border_width > 0 %}
      border-top: {{ block.settings.trust_badges_border_width }}px solid {{ block.settings.trust_badges_border_color }};
    {% endif %}
  }

  .ai-hero-trust-badge-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    flex: 1 1 auto;
  }

  .ai-hero-trust-badge-icon-{{ ai_gen_id }} {
    width: {{ block.settings.trust_badge_icon_size_desktop }}px;
    height: {{ block.settings.trust_badge_icon_size_desktop }}px;
    color: {{ block.settings.trust_badge_icon_color }};
    flex-shrink: 0;
  }

  .ai-hero-trust-badge-icon-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-hero-trust-badge-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.trust_badge_font_size_desktop }}px;
    font-weight: {{ block.settings.trust_badge_font_weight }};
    color: {{ block.settings.trust_badge_text_color }};
    line-height: 1.3;
    white-space: normal;
  }

  @media (max-width: 749px) {
    {% if block.settings.transparent_header %}
      .shopify-section:first-child .ai-hero-section-{{ ai_gen_id }} {
        margin-top: calc(-1 * var(--header-height, 60px));
      }
      .ai-hero-container-{{ ai_gen_id }} {
        padding-top: var(--header-height, 60px);
      }
    {% endif %}

    .ai-hero-container-{{ ai_gen_id }} {
      flex-direction: column;
      height: auto;
      min-height: auto;
    }

    .ai-hero-video-column-{{ ai_gen_id }} {
      flex: 0 0 auto;
      width: 100%;
      height: {{ section_height_mobile }} !important;
      min-height: {{ section_height_mobile }} !important;
      max-height: {{ section_height_mobile }} !important;
    }

    .ai-hero-video-wrapper-{{ ai_gen_id }} {
      width: 100%;
      height: {{ section_height_mobile }} !important;
      min-height: {{ section_height_mobile }} !important;
      max-height: {{ section_height_mobile }} !important;
      overflow: hidden;
    }

    .ai-hero-video-desktop-{{ ai_gen_id }} {
      display: none;
    }

    .ai-hero-video-mobile-{{ ai_gen_id }} {
      display: block;
    }

    .ai-hero-video-{{ ai_gen_id }} {
      object-position: {{ block.settings.video_crop_position_mobile }};
      height: 100% !important;
      width: 100% !important;
    }

    .ai-hero-content-column-{{ ai_gen_id }} {
      flex: 0 0 auto;
      width: 100%;
      padding: 40px 20px {{ block.settings.section_padding_bottom_mobile }}px;
      text-align: center;
      min-height: auto;
    }

    .ai-hero-content-wrapper-{{ ai_gen_id }} {
      margin-top: -55px;
      position: relative;
      z-index: 5;
    }

    .ai-hero-content-wrapper-{{ ai_gen_id }} > * {
      margin-bottom: {{ block.settings.element_spacing_mobile }}px;
    }

    .ai-hero-content-wrapper-{{ ai_gen_id }} > *:last-child {
      margin-bottom: 0;
    }

    .ai-hero-content-wrapper-{{ ai_gen_id }} > .ai-hero-headline-{{ ai_gen_id }} {
      margin-bottom: {{ block.settings.headline_margin_bottom }}px !important;
    }

    .ai-hero-badge-desktop-{{ ai_gen_id }} {
      display: none;
    }

    .ai-hero-badge-{{ ai_gen_id }} {
      display: inline-block;
      padding: 8px 16px;
      background-color: {{ block.settings.badge_background_color }};
      color: {{ block.settings.badge_text_color }};
      font-size: {{ block.settings.badge_font_size_mobile }}px;
      border-radius: {{ block.settings.badge_border_radius }}px;
      width: {{ block.settings.badge_width }}%;
      text-align: center;
    }

    .ai-hero-button-{{ ai_gen_id }} {
      display: block;
      margin-left: auto;
      margin-right: auto;
      margin-bottom: {{ block.settings.button_margin_bottom }}px !important;
      font-size: {{ block.settings.button_font_size_mobile }}px;
    }

    .ai-hero-review-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.review_font_size_mobile }}px;
    }

    .ai-hero-stars-{{ ai_gen_id }} svg {
      width: {{ block.settings.star_size_mobile }}px;
      height: {{ block.settings.star_size_mobile }}px;
    }

    .ai-hero-callout-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.callout_font_size_mobile }}px;
    }

    .ai-hero-trust-badge-icon-{{ ai_gen_id }} {
      width: {{ block.settings.trust_badge_icon_size_mobile }}px;
      height: {{ block.settings.trust_badge_icon_size_mobile }}px;
    }

    .ai-hero-trust-badge-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.trust_badge_font_size_mobile }}px;
    }

    .ai-hero-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_font_size_mobile }}px;
    }

    .ai-hero-subheadline-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheadline_font_size_mobile }}px;
    }

    .ai-hero-review-{{ ai_gen_id }},
    .ai-hero-callouts-{{ ai_gen_id }},
    .ai-hero-trust-badges-{{ ai_gen_id }} {
      justify-content: center;
    }

    .ai-hero-callouts-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: center;
    }

    .ai-hero-callout-{{ ai_gen_id }} {
      justify-content: center;
    }

    .ai-hero-trust-badges-{{ ai_gen_id }} {
      flex-direction: row;
      flex-wrap: nowrap;
      gap: 10px;
      justify-content: center;
    }

    .ai-hero-trust-badge-{{ ai_gen_id }} {
      justify-content: center;
      flex: 1 1 auto;
      gap: 4px;
    }
  }

  @media (min-width: 750px) {
    .ai-hero-content-column-{{ ai_gen_id }} {
      padding-bottom: 20px !important;
    }
  }

  @media (min-width: 990px) {
    .ai-hero-callouts-{{ ai_gen_id }} {
      flex-direction: row;
      flex-wrap: wrap;
      column-gap: 8px;
      row-gap: 10px;
    }
    .ai-hero-callout-{{ ai_gen_id }} {
      flex: 1 1 48%;
      max-width: 48%;
    }
  }
{% endstyle %}

<div class="ai-hero-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-container-{{ ai_gen_id }}">
    <div class="ai-hero-video-column-{{ ai_gen_id }}">
      <div class="ai-hero-video-wrapper-{{ ai_gen_id }}">
        {% if block.settings.hero_video_desktop != blank or block.settings.hero_video_mobile != blank %}
          {% if block.settings.hero_video_desktop != blank %}
            <video class="ai-hero-video-{{ ai_gen_id }} ai-hero-video-desktop-{{ ai_gen_id }}"
              {% if block.settings.video_autoplay %}autoplay{% endif %}
              {% if block.settings.video_loop %}loop{% endif %} muted playsinline>
              <source src="{{ block.settings.hero_video_desktop.sources[1].url }}" type="{{ block.settings.hero_video_desktop.sources[1].mime_type }}">
            </video>
          {% endif %}
          {% if block.settings.hero_video_mobile != blank %}
            <video class="ai-hero-video-{{ ai_gen_id }} ai-hero-video-mobile-{{ ai_gen_id }}"
              {% if block.settings.video_autoplay %}autoplay{% endif %}
              {% if block.settings.video_loop %}loop{% endif %} muted playsinline>
              <source src="{{ block.settings.hero_video_mobile.sources[1].url }}" type="{{ block.settings.hero_video_mobile.sources[1].mime_type }}">
            </video>
          {% elsif block.settings.hero_video_desktop != blank %}
            <video class="ai-hero-video-{{ ai_gen_id }} ai-hero-video-mobile-{{ ai_gen_id }}"
              {% if block.settings.video_autoplay %}autoplay{% endif %}
              {% if block.settings.video_loop %}loop{% endif %} muted playsinline>
              <source src="{{ block.settings.hero_video_desktop.sources[1].url }}" type="{{ block.settings.hero_video_desktop.sources[1].mime_type }}">
            </video>
          {% endif %}
        {% else %}
          <div class="ai-hero-video-placeholder-{{ ai_gen_id }}">
            {{ 'hero-apparel-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
    </div>

    <div class="ai-hero-content-column-{{ ai_gen_id }}">
      <div class="ai-hero-content-wrapper-{{ ai_gen_id }}">
        {% if block.settings.badge_text != blank %}
          <div class="ai-hero-badge-{{ ai_gen_id }}">{{ block.settings.badge_text }}</div>
          <div class="ai-hero-badge-desktop-{{ ai_gen_id }}">{{ block.settings.badge_text }}</div>
        {% endif %}

        {% if block.settings.show_review %}
          <div class="ai-hero-review-{{ ai_gen_id }}">
            <div class="ai-hero-stars-{{ ai_gen_id }}">
              {% for i in (1..5) %}
                <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M10 0L12.2451 6.90983H19.5106L13.6327 11.1803L15.8779 18.0902L10 13.8197L4.12215 18.0902L6.36729 11.1803L0.489435 6.90983H7.75486L10 0Z"/>
                </svg>
              {% endfor %}
            </div>
            {% if block.settings.review_text != blank %}
              <span class="ai-hero-review-text-{{ ai_gen_id }}">{{ block.settings.review_text }}</span>
            {% endif %}
          </div>
        {% endif %}

        {% if block.settings.headline != blank %}
          <div class="ai-hero-headline-{{ ai_gen_id }} {{ block.settings.headline_tag }}">
            {{ block.settings.headline }}
          </div>
        {% endif %}

        {% if block.settings.subheadline != blank %}
          <div class="ai-hero-subheadline-{{ ai_gen_id }}">{{ block.settings.subheadline }}</div>
        {% endif %}

        {% if block.settings.button_text != blank %}
          <a href="{{ block.settings.button_link }}" class="ai-hero-button-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
          </a>
        {% endif %}

        {% if block.settings.callout_1_text != blank or block.settings.callout_2_text != blank or block.settings.callout_3_text != blank %}
          <div class="ai-hero-callouts-{{ ai_gen_id }}">
            {% if block.settings.callout_1_text != blank %}
              <div class="ai-hero-callout-{{ ai_gen_id }}">
                <svg class="ai-hero-callout-icon-{{ ai_gen_id }}" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <span class="ai-hero-callout-text-{{ ai_gen_id }}">{{ block.settings.callout_1_text }}</span>
              </div>
            {% endif %}
            {% if block.settings.callout_2_text != blank %}
              <div class="ai-hero-callout-{{ ai_gen_id }}">
                <svg class="ai-hero-callout-icon-{{ ai_gen_id }}" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <span class="ai-hero-callout-text-{{ ai_gen_id }}">{{ block.settings.callout_2_text }}</span>
              </div>
            {% endif %}
            {% if block.settings.callout_3_text != blank %}
              <div class="ai-hero-callout-{{ ai_gen_id }}">
                <svg class="ai-hero-callout-icon-{{ ai_gen_id }}" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <span class="ai-hero-callout-text-{{ ai_gen_id }}">{{ block.settings.callout_3_text }}</span>
              </div>
            {% endif %}
          </div>
        {% endif %}

        {% if block.settings.show_trust_badges %}
          <div class="ai-hero-trust-badges-{{ ai_gen_id }}">
            <div class="ai-hero-trust-badge-{{ ai_gen_id }}">
              <div class="ai-hero-trust-badge-icon-{{ ai_gen_id }}">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                  <polyline points="22 4 12 14.01 9 11.01"></polyline>
                </svg>
              </div>
              <div class="ai-hero-trust-badge-text-{{ ai_gen_id }}">{{ block.settings.trust_badge_1_text }}</div>
            </div>
            <div class="ai-hero-trust-badge-{{ ai_gen_id }}">
              <div class="ai-hero-trust-badge-icon-{{ ai_gen_id }}">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M9 11l3 3L22 4"></path>
                  <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"></path>
                </svg>
              </div>
              <div class="ai-hero-trust-badge-text-{{ ai_gen_id }}">{{ block.settings.trust_badge_2_text }}</div>
            </div>
            <div class="ai-hero-trust-badge-{{ ai_gen_id }}">
              <div class="ai-hero-trust-badge-icon-{{ ai_gen_id }}">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                  <polyline points="14 2 14 8 20 8"></polyline>
                  <line x1="16" y1="13" x2="8" y2="13"></line>
                  <line x1="16" y1="17" x2="8" y2="17"></line>
                </svg>
              </div>
              <div class="ai-hero-trust-badge-text-{{ ai_gen_id }}">{{ block.settings.trust_badge_3_text }}</div>
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hero video section",
  "settings": [
    {"type": "header", "content": "Layout"},
    {"type": "checkbox", "id": "transparent_header", "label": "Transparent header", "default": false},
    {"type": "range", "id": "element_spacing_desktop", "min": 10, "max": 60, "step": 5, "unit": "px", "label": "Element spacing (desktop)", "default": 30},
    {"type": "range", "id": "element_spacing_mobile", "min": 10, "max": 60, "step": 5, "unit": "px", "label": "Element spacing (mobile)", "default": 25},
    {"type": "range", "id": "section_padding_bottom", "min": 20, "max": 100, "step": 5, "unit": "px", "label": "Section padding bottom (desktop)", "default": 60},
    {"type": "range", "id": "section_padding_bottom_mobile", "min": 20, "max": 100, "step": 5, "unit": "px", "label": "Section padding bottom (mobile)", "default": 20},
    {"type": "header", "content": "Desktop Video"},
    {"type": "video", "id": "hero_video_desktop", "label": "Desktop video"},
    {"type": "select", "id": "section_height", "label": "Desktop height", "options": [{"value": "adapt", "label": "Adapt"}, {"value": "fullscreen", "label": "Fullscreen"}, {"value": "custom", "label": "Custom"}], "default": "custom"},
    {"type": "range", "id": "section_height_custom", "min": 400, "max": 1000, "step": 50, "unit": "px", "label": "Custom height", "default": 700},
    {"type": "header", "content": "Mobile Video"},
    {"type": "video", "id": "hero_video_mobile", "label": "Mobile video"},
    {"type": "select", "id": "section_height_mobile", "label": "Mobile height", "options": [{"value": "adapt", "label": "Adapt"}, {"value": "fullscreen", "label": "Fullscreen"}, {"value": "custom", "label": "Custom"}], "default": "custom"},
    {"type": "range", "id": "section_height_mobile_custom", "min": 300, "max": 800, "step": 50, "unit": "px", "label": "Custom height", "default": 500},
