        "layout": "default",
        "image_ratio": "portrait",
        "image_ratio_mobile": "landscape",
        "columns_mobile": "1",
        "swipe_on_mobile": false,
        "heading": "Morning Blend Ingredients",
        "heading_size": "title-md",
